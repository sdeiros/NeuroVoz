---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RoutineWidget from '../components/RoutineWidget.astro';
import RoutineModal from '../components/RoutineModal.astro';
import RoutineCelebration from '../components/RoutineCelebration.astro';

interface Props {
  title?: string;
  description?: string;
  fullbleed?: boolean;
}
const {
  title = 'NeuroVoz — Autismo e Comunicação Alternativa',
  description = 'Plataforma educacional e acessível sobre autismo (TEA) e Comunicação Aumentativa e Alternativa (CAA). Toda criança tem algo a dizer.',
  fullbleed = false,
} = Astro.props;
---
<!doctype html>
<html lang="pt-BR" class="bg-background">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#5b8def" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="NeuroVoz" />
    <link rel="apple-touch-icon" href="/apple-icon.png" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <a href="#main" class="skip-link">Pular para o conteúdo principal</a>
    <Header />
    <main id="main" class={fullbleed ? 'fullbleed' : ''}>
      <slot />
    </main>
    {!fullbleed && <Footer />}

    {/* ── Central Inteligente do Dia (v2) ─────────────────────────────── */}
    <RoutineWidget />
    <RoutineModal />
    <RoutineCelebration />

    {/* Reveal-on-scroll util (mantido do projeto anterior) */}
    <script>
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
    </script>

    {/* Bootstrap único do módulo de rotina */}
    <script>
      import '../data/main.ts';
    </script>
  </body>
</html>
