---
const { letter, lower, word, examplePronunciation, emoji, extras = [] } = Astro.props;
const __uid = `nv-al-${letter}-${Math.random().toString(36).slice(2,8)}`;
---

<div id={__uid} class="nv-alphabet-letter" role="group" aria-label={`Letra ${letter}`}>
  <div class="nv-letter-card">
    <div class="nv-letter-upper">{letter}</div>
    <div class="nv-letter-lower">{lower}</div>
  </div>
  <div class="nv-illustration">{emoji || '🔤'}</div>
  <div class="nv-word">{word}</div>
  {extras.length ? (
    <div class="nv-extras">{extras.join(' · ')}</div>
  ) : null}
  <div class="nv-actions">
    <button class="btn btn-ghost nv-tts-letter" type="button">🔊 Letra</button>
    <button class="btn btn-ghost nv-tts-word" type="button">🔊 Palavra</button>
    <button class="btn btn-ghost nv-tts-example" type="button" data-example={examplePronunciation}>{'🔊 Exemplo'}</button>
  </div>

  <script type="module">
    if (!window.nvSpeak) {
      window.nvSpeak = (text, lang = 'pt-BR') => {
        try {
          const u = new SpeechSynthesisUtterance(text);
          u.lang = lang;
          speechSynthesis.cancel();
          speechSynthesis.speak(u);
        } catch (e) {
          console.warn('TTS unavailable', e);
        }
      };
    }
    if (!window.recordLearningEvent) {
      window.recordLearningEvent = (evt) => {
        try {
          const key = 'nv-learning-history';
          const cur = JSON.parse(localStorage.getItem(key) || '[]');
          cur.push(evt);
          localStorage.setItem(key, JSON.stringify(cur));
        } catch (e) {
          console.warn('Failed to persist learning event', e);
        }
      };
    }

    // Initialize listeners once for all alphabet cards to avoid relying on document.currentScript
    if (!window.nvAlphabetInitialized) {
      window.nvAlphabetInitialized = true;
      document.querySelectorAll('.nv-alphabet-letter').forEach((root) => {
        if (root.dataset.nvInit) return;
        const btnLetter = root.querySelector('.nv-tts-letter');
        const btnWord = root.querySelector('.nv-tts-word');
        const btnExample = root.querySelector('.nv-tts-example');
        const l = root.querySelector('.nv-letter-upper')?.textContent?.trim() || '';
        const w = root.querySelector('.nv-word')?.textContent?.trim() || '';
        const exampleTxt = btnExample ? (btnExample.dataset ? btnExample.dataset.example : null) : null;

        btnLetter?.addEventListener('click', () => {
          window.nvSpeak(l);
          window.recordLearningEvent && window.recordLearningEvent({ type: 'alphabet', action: 'letter', letter: l, word: w || null, time: Date.now() });
          root.classList.add('nv-play');
          setTimeout(() => root.classList.remove('nv-play'), 900);
        });
        btnWord?.addEventListener('click', () => {
          window.nvSpeak(w || l);
          window.recordLearningEvent && window.recordLearningEvent({ type: 'alphabet', action: 'word', letter: l, word: w || null, time: Date.now() });
          root.classList.add('nv-play-word');
          setTimeout(() => root.classList.remove('nv-play-word'), 900);
        });
        btnExample?.addEventListener('click', () => {
          const ex = btnExample.dataset && btnExample.dataset.example ? btnExample.dataset.example : null;
          const txt = ex || `${l} de ${w || ''}`;
          window.nvSpeak(txt);
          window.recordLearningEvent && window.recordLearningEvent({ type: 'alphabet', action: 'example', letter: l, example: txt, time: Date.now() });
          root.classList.add('nv-play-example');
          setTimeout(() => root.classList.remove('nv-play-example'), 900);
        });

        root.dataset.nvInit = '1';
      });
    }
  </script>

  <style>
    .nv-alphabet-letter { display:flex; flex-direction:column; gap:10px; align-items:center; padding:14px; padding-bottom:18px; border-radius:12px; background:var(--surface); border:1px solid var(--border); box-shadow:var(--shadow-sm); min-width:140px; max-width:260px; width:100%; box-sizing:border-box; overflow:hidden; position:relative; justify-content:space-between; }
    .nv-letter-card { display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%; flex:1 1 auto }
    .nv-letter-upper { font-size:3.2rem; font-family:var(--font-head); font-weight:900; }
    .nv-letter-lower { font-size:1.2rem; color:var(--text-soft); margin-top:4px }
    .nv-illustration { font-size:2.6rem }
    .nv-word { font-weight:800; color:var(--blue); }
    .nv-actions { display:flex; gap:8px; margin-top:8px; flex-wrap:wrap; justify-content:center; align-items:center; width:100%; }
    .nv-actions .btn { min-width:0; flex:1 1 auto; padding:8px 10px; max-width:100%; box-sizing:border-box }
    .nv-extras { color: var(--text-soft); font-size: 0.86rem; text-align: center; line-height: 1.3; margin-top: 6px; padding: 0 6px; }
    .nv-alphabet-letter.nv-play { transform:translateY(-4px); transition:transform .18s ease }
    .nv-alphabet-letter.nv-play-word { transform:scale(1.02); transition:transform .18s ease }
    .nv-alphabet-letter.nv-play-example { box-shadow:0 10px 30px rgba(41,128,185,0.12); transform:translateY(-6px) scale(1.01) }
  </style>
</div>
