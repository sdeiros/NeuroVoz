---
const nav = [
  { href: '/autismo', label: 'Entendendo o Autismo' },
  { href: '/pedagogos', label: 'Guia para Pedagogos' },
  { href: '/pranchas', label: 'Criar Prancha' },
  { href: '/assistente', label: 'Assistente IA' },
  { href: '/tablet', label: 'Tablet Comunicador' },
  { href: '/historico', label: 'Histórico' },
  { href: '/recursos', label: 'Recursos' },
  { href: '/sobre', label: 'Sobre' },
];
const path = Astro.url.pathname;
---

<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label="NeuroVoz - página inicial">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
        </svg>
      </span>
      <span class="brand-text">Neuro<strong>Voz</strong></span>
    </a>

    <nav class="nav-links" aria-label="Navegação principal">
      {nav.map((item) => (
        <a href={item.href} class={`nav-link ${path === item.href ? 'active' : ''}`}>{item.label}</a>
      ))}
    </nav>

    <div class="nav-tools">
      <button id="a11y-toggle" class="tool-btn" aria-expanded="false" aria-controls="a11y-panel" title="Acessibilidade">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="4" r="2"/><path d="M19 13c-1.5.5-3.5 1-7 1s-5.5-.5-7-1"/><path d="M12 6v9m0 0l-3 6m3-6l3 6"/></svg>
        <span class="sr-only">Opções de acessibilidade</span>
      </button>
      <button id="menu-toggle" class="tool-btn menu-only" aria-expanded="false" aria-controls="mobile-nav" title="Menu">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <span class="sr-only">Abrir menu</span>
      </button>
    </div>
  </div>

  <!-- Painel de acessibilidade -->
  <div id="a11y-panel" class="a11y-panel" hidden>
    <div class="container a11y-inner">
      <div class="a11y-group">
        <span class="a11y-label">Tamanho do texto</span>
        <div class="a11y-buttons">
          <button data-font="normal" class="chip">A</button>
          <button data-font="lg" class="chip">A+</button>
          <button data-font="xl" class="chip">A++</button>
        </div>
      </div>
      <div class="a11y-group">
        <span class="a11y-label">Contraste</span>
        <div class="a11y-buttons">
          <button data-contrast="normal" class="chip">Normal</button>
          <button data-contrast="high" class="chip">Alto contraste</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Navegação mobile -->
  <nav id="mobile-nav" class="mobile-nav" aria-label="Navegação mobile" hidden>
    {nav.map((item) => (
      <a href={item.href} class={`mobile-link ${path === item.href ? 'active' : ''}`}>{item.label}</a>
    ))}
  </nav>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(255,255,255,0.85); backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  :root[data-contrast='high'] .nav { background: var(--surface); }
  .nav-inner { display: flex; align-items: center; gap: 16px; height: 70px; }
  .brand { display: flex; align-items: center; gap: 10px; font-family: var(--font-head); font-size: 1.35rem; font-weight: 900; }
  .brand-mark { display: grid; place-items: center; width: 40px; height: 40px; border-radius: 12px; background: var(--blue); color: #fff; box-shadow: var(--shadow-sm); }
  .brand-text strong { color: var(--blue); }
  .nav-links { display: flex; gap: 2px; margin-left: auto; flex-wrap: nowrap; }
  .nav-link { padding: 8px 11px; border-radius: 999px; font-weight: 600; font-size: 0.86rem; white-space: nowrap; color: var(--text-soft); transition: background 0.15s, color 0.15s; }
  .nav-link:hover { background: var(--bg-alt); color: var(--text); }
  .nav-link.active { background: var(--blue); color: #fff; }
  .nav-tools { display: flex; gap: 8px; margin-left: 8px; }
  .tool-btn { display: grid; place-items: center; width: 42px; height: 42px; border-radius: 12px; border: 2px solid var(--border); background: var(--surface); color: var(--text); }
  .tool-btn:hover { border-color: var(--blue-soft); }
  .menu-only { display: none; }

  .a11y-panel { border-top: 1px solid var(--border); background: var(--surface); }
  .a11y-inner { display: flex; gap: 32px; flex-wrap: wrap; padding-top: 14px; padding-bottom: 14px; }
  .a11y-group { display: flex; align-items: center; gap: 12px; }
  .a11y-label { font-family: var(--font-head); font-weight: 700; font-size: 0.9rem; }
  .a11y-buttons { display: flex; gap: 6px; }
  .chip { padding: 6px 14px; border-radius: 999px; border: 2px solid var(--border); background: var(--surface-2); font-weight: 700; font-family: var(--font-head); color: var(--text); }
  .chip.on { background: var(--blue); color: #fff; border-color: var(--blue); }

  .mobile-nav { display: none; flex-direction: column; padding: 12px 20px 20px; border-top: 1px solid var(--border); background: var(--surface); }
  .mobile-link { padding: 12px; border-radius: 12px; font-weight: 700; font-family: var(--font-head); color: var(--text-soft); }
  .mobile-link.active, .mobile-link:hover { background: var(--bg-alt); color: var(--text); }

  @media (max-width: 1180px) {
    .nav-links { display: none; }
    .menu-only { display: grid; }
    .mobile-nav[data-open] { display: flex; }
  }
</style>

<script>
  const root = document.documentElement;
  // Acessibilidade persistente
  const savedFont = localStorage.getItem('nv-font');
  const savedContrast = localStorage.getItem('nv-contrast');
  if (savedFont && savedFont !== 'normal') root.setAttribute('data-fontscale', savedFont);
  if (savedContrast === 'high') root.setAttribute('data-contrast', 'high');

  const a11yToggle = document.getElementById('a11y-toggle');
  const a11yPanel = document.getElementById('a11y-panel');
  a11yToggle?.addEventListener('click', () => {
    const open = a11yPanel?.hasAttribute('hidden');
    if (open) { a11yPanel?.removeAttribute('hidden'); } else { a11yPanel?.setAttribute('hidden', ''); }
    a11yToggle.setAttribute('aria-expanded', String(open));
  });

  function syncChips() {
    const f = localStorage.getItem('nv-font') || 'normal';
    const c = localStorage.getItem('nv-contrast') || 'normal';
    document.querySelectorAll('[data-font]').forEach((b) => b.classList.toggle('on', (b as HTMLElement).dataset.font === f));
    document.querySelectorAll('[data-contrast]').forEach((b) => b.classList.toggle('on', (b as HTMLElement).dataset.contrast === c));
  }
  document.querySelectorAll('[data-font]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const v = (btn as HTMLElement).dataset.font!;
      if (v === 'normal') root.removeAttribute('data-fontscale'); else root.setAttribute('data-fontscale', v);
      localStorage.setItem('nv-font', v); syncChips();
    });
  });
  document.querySelectorAll('[data-contrast]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const v = (btn as HTMLElement).dataset.contrast!;
      if (v === 'high') root.setAttribute('data-contrast', 'high'); else root.removeAttribute('data-contrast');
      localStorage.setItem('nv-contrast', v); syncChips();
    });
  });
  syncChips();

  // Menu mobile
  const menuToggle = document.getElementById('menu-toggle');
  const mobileNav = document.getElementById('mobile-nav');
  menuToggle?.addEventListener('click', () => {
    const open = mobileNav?.hasAttribute('data-open');
    if (open) { mobileNav?.removeAttribute('data-open'); mobileNav?.setAttribute('hidden', ''); }
    else { mobileNav?.setAttribute('data-open', ''); mobileNav?.removeAttribute('hidden'); }
    menuToggle.setAttribute('aria-expanded', String(!open));
  });
</script>
