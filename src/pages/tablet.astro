---
import Base from '../layouts/Base.astro';
import { categories, vocabulary } from '../data/vocabulary';
---

<Base title="Tablet Comunicador — NeuroVoz" description="Comunicador AAC com construção de frases, voz sintetizada, feedback visual e modo tela cheia." fullbleed={false}>
  <section class="tablet-page">
    <div class="container">
      <div class="tablet-head">
        <div>
          <span class="eyebrow">Tablet Comunicador</span>
          <h1 class="t-title" id="t-title">Comunicador</h1>
        </div>
        <div class="t-controls">
          <label class="ctrl">
            <span>Voz</span>
            <select id="voice-select">
              <optgroup label="Crianças">
                <option value="menina">👧 Menina</option>
                <option value="menina2">👧 Menina animada</option>
                <option value="menino">👦 Menino</option>
                <option value="menino2">👦 Menino travesso</option>
              </optgroup>
              <optgroup label="Adultos">
                <option value="mulher">👩 Mulher</option>
                <option value="homem">👨 Homem</option>
              </optgroup>
              <optgroup label="Personagens mágicos">
                <option value="princesa">👸 Princesa</option>
                <option value="principe">🤴 Príncipe</option>
                <option value="rainha">👑 Rainha</option>
                <option value="rei">🦁 Rei</option>
                <option value="fada">🧚 Fadinha</option>
                <option value="bruxa">🧙‍♀️ Bruxa</option>
                <option value="anjo">😇 Anjo</option>
              </optgroup>
              <optgroup label="Heróis e aventura">
                <option value="heroina">🦸‍♀️ Super-heroína</option>
                <option value="heroi">🦸 Super-herói</option>
                <option value="pirata">🏴‍☠️ Pirata</option>
                <option value="cowboy">🤠 Cowboy</option>
                <option value="ninja">🥷 Ninja</option>
              </optgroup>
              <optgroup label="Criaturas e robôs">
                <option value="robo">🤖 Robô</option>
                <option value="robo2">🤖 Robô alienígena</option>
                <option value="gigante">👹 Gigante</option>
                <option value="alien">👽 Alienígena</option>
                <option value="duende">🧝 Duende</option>
              </optgroup>
              <optgroup label="Outros">
                <option value="silencioso">🔇 Modo silencioso</option>
              </optgroup>
            </select>
          </label>
          <label class="ctrl">
            <span>Velocidade</span>
            <input id="rate" type="range" min="0.5" max="1.5" step="0.1" value="1" />
          </label>
          <label class="ctrl">
            <span>Volume</span>
            <input id="volume" type="range" min="0" max="1" step="0.1" value="1" />
          </label>
          <button class="btn btn-ghost" id="btn-fullscreen" title="Tela cheia">⛶ Tela cheia</button>
        </div>
      </div>

      <!-- Barra de frase -->
      <div class="sentence-bar">
        <div class="sentence-strip" id="sentence-strip" aria-live="polite">
          <span class="sentence-placeholder" id="sentence-placeholder">Toque nos botões para montar uma frase...</span>
        </div>
        <div class="sentence-actions">
          <button class="sb-btn speak" id="btn-speak" title="Falar frase" aria-label="Falar a frase completa">🔊</button>
          <button class="sb-btn back" id="btn-back" title="Apagar último" aria-label="Apagar último cartão">⌫</button>
          <button class="sb-btn clear" id="btn-clear-sentence" title="Limpar frase" aria-label="Limpar frase">🗑️</button>
        </div>
      </div>

      <!-- Frequentes -->
      <section class="freq-section" id="freq-section" hidden>
        <div class="section-head">
          <div>
            <span class="eyebrow">Frequentes</span>
            <p>Usados mais de uma vez</p>
          </div>
        </div>
        <div class="freq-grid" id="freq-grid"></div>
      </section>

      <!-- Categorias -->
      <div class="cat-bar" id="cat-bar" role="tablist" aria-label="Categorias">
        <button class="cat-pill active" data-cat="all" role="tab" aria-selected="true">
          <span aria-hidden="true">🔠</span> Todos
        </button>
        {categories.map((c) => (
          <button class="cat-pill" data-cat={c.id} role="tab" aria-selected="false" style={`--cc:${c.color}`}>
            <span aria-hidden="true">{c.icon}</span> {c.name}
          </button>
        ))}
      </div>

      <!-- Grade de botões -->
      <div class="aac-grid" id="aac-grid"></div>
    </div>
  </section>

  <!-- Overlay de flash de cor semântica -->
  <div class="flash-overlay" id="flash-overlay" aria-hidden="true"></div>
</Base>

<script define:vars={{ vocabulary, categories }}>
  const grid = document.getElementById('aac-grid');
  const freqSection = document.getElementById('freq-section');
  const freqGrid = document.getElementById('freq-grid');
  const strip = document.getElementById('sentence-strip');
  const placeholder = document.getElementById('sentence-placeholder');
  let activeCat = 'all';
  let sentence = [];

  // ─── Cores semânticas ────────────────────────────────────────────────────────
  const SEMANTIC_COLORS = {
    'sim': '#22c55e', 'eu-quero': '#22c55e', 'mais': '#22c55e', 'obrigado': '#22c55e',
    'por-favor': '#22c55e', 'amor': '#22c55e', 'feliz': '#22c55e', 'terminei': '#22c55e',
    'nao': '#ef4444', 'eu-nao-quero': '#ef4444', 'acabou': '#ef4444', 'bravo': '#ef4444',
    'dor': '#ef4444', 'doente': '#ef4444',
    'banheiro': '#3b82f6', 'agua': '#3b82f6', 'lavar-maos': '#3b82f6', 'banho': '#3b82f6',
    'escovar': '#3b82f6', 'trocar': '#3b82f6',
    'ajuda': '#f59e0b', 'professor': '#f59e0b', 'esperar': '#f59e0b', 'medo': '#f59e0b',
    'comida': '#f97316', 'fome': '#f97316', 'comer': '#f97316', 'fruta': '#f97316',
    'pao': '#f97316', 'bolacha': '#f97316',
  };
  function semanticColor(item) {
    return SEMANTIC_COLORS[item.id] || catColor(item.category);
  }

  // ─── Flash overlay ────────────────────────────────────────────────────────────
  const flashOverlay = document.getElementById('flash-overlay');
  function flashScreen(color) {
    if (!flashOverlay) return;
    flashOverlay.style.background = color;
    flashOverlay.classList.remove('flash-on');
    void flashOverlay.offsetWidth;
    flashOverlay.classList.add('flash-on');
  }

  // ─── Config personalizada ─────────────────────────────────────────────────────
  let custom = null;
  try { custom = JSON.parse(localStorage.getItem('nv-tablet-config') || 'null'); } catch (e) {}
  if (custom && custom.nome) {
    document.getElementById('t-title').textContent = `Comunicador de ${custom.nome}`;
  }

  function catColor(id) { return (categories.find((c) => c.id === id) || {}).color || '#5b8def'; }

  function topFrequentIds() {
    let hist = [];
    try { hist = JSON.parse(localStorage.getItem('nv-history') || '[]'); } catch (e) {}
    const counts = hist.reduce((acc, entry) => {
      if (entry?.id) acc[entry.id] = (acc[entry.id] || 0) + 1;
      return acc;
    }, {});
    return Object.entries(counts)
      .filter(([, count]) => count > 1)
      .sort(([, aCount], [, bCount]) => bCount - aCount)
      .map(([id]) => id);
  }

  function frequentItems() {
    return topFrequentIds()
      .map((id) => vocabulary.find((item) => item.id === id))
      .filter(Boolean);
  }

  function visibleItems() {
    if (activeCat !== 'all') {
      return vocabulary.filter((v) => v.category === activeCat);
    }

    const frequentIds = new Set(topFrequentIds());
    let items = vocabulary.filter((v) => !frequentIds.has(v.id));
    if (custom && custom.cards) {
      const set = new Set(custom.cards);
      const priority = items.filter((v) => set.has(v.id));
      const rest = items.filter((v) => !set.has(v.id));
      items = [...priority, ...rest];
    }
    return items;
  }

  function makeAacButton(item) {
    const btn = document.createElement('button');
    btn.setAttribute('type', 'button');
    const isPriority = custom && custom.cards && custom.cards.includes(item.id) && activeCat === 'all';
    btn.className = 'aac-btn' + (isPriority ? ' priority' : '');
    btn.style.setProperty('--cc', semanticColor(item));
    btn.innerHTML = `
      <span class="aac-accent" aria-hidden="true"></span>
      <span class="aac-body">
        <span class="aac-icon" aria-hidden="true">${item.icon}</span>
        <span class="aac-label">${item.label}</span>
      </span>`;
    btn.setAttribute('aria-label', item.label);
    btn.addEventListener('click', () => onPress(item, btn));
    return btn;
  }

  function renderGrid() {
    grid.innerHTML = '';
    visibleItems().forEach((item) => {
      grid.appendChild(makeAacButton(item));
    });
  }

  function renderFrequent() {
    const items = frequentItems();
    if (!freqSection || !freqGrid) return;
    if (!items.length) {
      freqSection.hidden = true;
      freqGrid.innerHTML = '';
      return;
    }

    freqSection.hidden = false;
    freqGrid.innerHTML = '';
    items.forEach((item) => freqGrid.appendChild(makeAacButton(item)));
  }

  function onPress(item, btn) {
    btn.classList.remove('pressed');
    void btn.offsetWidth;
    btn.classList.add('pressed');
    setTimeout(() => btn.classList.remove('pressed'), 500);
    flashScreen(semanticColor(item));
    addToSentence(item);
    speak(item.phrase || item.label);
    logHistory(item);
  }

  function addToSentence(item) {
    sentence.push(item);
    renderSentence();
  }

  function renderSentence() {
    strip.querySelectorAll('.s-chip').forEach((n) => n.remove());
    placeholder.style.display = sentence.length ? 'none' : 'block';
    sentence.forEach((it) => {
      const chip = document.createElement('span');
      chip.className = 's-chip';
      chip.innerHTML = `<span aria-hidden="true">${it.icon}</span> ${it.label}`;
      strip.appendChild(chip);
    });
  }

  function sentenceText() {
    return sentence.map((s) => s.phrase || s.label).join(' ');
  }

  // ═══════════════════════════════════════════════════════════════════════════════
  // TTS ENGINE — Web Speech API + Web Audio API effects
  // ═══════════════════════════════════════════════════════════════════════════════

  let voices = [];
  function loadVoices() { voices = window.speechSynthesis ? window.speechSynthesis.getVoices() : []; }
  if ('speechSynthesis' in window) {
    loadVoices();
    window.speechSynthesis.onvoiceschanged = loadVoices;
  }

  function pickVoice(gender) {
    const pt = voices.filter((v) => /pt(-|_)?BR/i.test(v.lang) || /portug/i.test(v.name) || /pt/i.test(v.lang));
    const pool = pt.length ? pt : voices;
    if (!pool.length) return null;
    if (gender === 'female') return pool.find((v) => /female|mulher|fem|luciana|maria|francisca|google|helena|raquel/i.test(v.name)) || pool[0];
    if (gender === 'male')   return pool.find((v) => /male|homem|masc|daniel|felipe|ricardo|antonio/i.test(v.name)) || pool[0];
    return pool[0];
  }

  /*
   * VOICE_PROFILES — each entry describes:
   *   gender  : which browser voice to pick ('female' | 'male')
   *   pitch   : SpeechSynthesisUtterance pitch (0.1–2)
   *   rate    : base speaking rate multiplier
   *   fx      : Web Audio effect chain applied to the MediaStream output
   *             'none' | 'robot' | 'alien' | 'echo' | 'deep' | 'chipmunk' | 'pirate'
   *             Note: fx only works in browsers that support AudioContext.createMediaStreamSource
   *             with speech synthesis output (Chrome/Edge). Falls back gracefully elsewhere.
   */
  const VOICE_PROFILES = {
    menina:   { gender: 'female', pitch: 1.7,  rate: 1.05, fx: 'chipmunk' },
    menina2:  { gender: 'female', pitch: 1.9,  rate: 1.15, fx: 'echo'     },
    menino:   { gender: 'male',   pitch: 1.5,  rate: 1.05, fx: 'none'     },
    menino2:  { gender: 'male',   pitch: 1.6,  rate: 1.2,  fx: 'none'     },
    mulher:   { gender: 'female', pitch: 1.1,  rate: 1.0,  fx: 'none'     },
    homem:    { gender: 'male',   pitch: 0.85, rate: 1.0,  fx: 'none'     },
    princesa: { gender: 'female', pitch: 1.9,  rate: 0.95, fx: 'echo'     },
    principe: { gender: 'male',   pitch: 1.3,  rate: 0.95, fx: 'none'     },
    rainha:   { gender: 'female', pitch: 1.15, rate: 0.88, fx: 'deep'     },
    rei:      { gender: 'male',   pitch: 0.55, rate: 0.85, fx: 'deep'     },
    fada:     { gender: 'female', pitch: 2.0,  rate: 1.15, fx: 'chipmunk' },
    bruxa:    { gender: 'female', pitch: 0.65, rate: 0.82, fx: 'deep'     },
    anjo:     { gender: 'female', pitch: 1.8,  rate: 0.9,  fx: 'echo'     },
    heroina:  { gender: 'female', pitch: 1.35, rate: 1.1,  fx: 'none'     },
    heroi:    { gender: 'male',   pitch: 0.72, rate: 1.05, fx: 'none'     },
    pirata:   { gender: 'male',   pitch: 0.75, rate: 0.9,  fx: 'pirate'   },
    cowboy:   { gender: 'male',   pitch: 0.8,  rate: 0.88, fx: 'none'     },
    ninja:    { gender: 'male',   pitch: 1.0,  rate: 1.3,  fx: 'none'     },
    robo:     { gender: 'male',   pitch: 0.5,  rate: 0.7,  fx: 'robot'    },
    robo2:    { gender: 'male',   pitch: 0.4,  rate: 0.65, fx: 'alien'    },
    gigante:  { gender: 'male',   pitch: 0.3,  rate: 0.75, fx: 'deep'     },
    alien:    { gender: 'male',   pitch: 1.6,  rate: 0.8,  fx: 'alien'    },
    duende:   { gender: 'male',   pitch: 1.8,  rate: 1.1,  fx: 'chipmunk' },
  };

  // ─── Web Audio effect builder ──────────────────────────────────────────────
  let audioCtx = null;

  function getAudioCtx() {
    if (!audioCtx || audioCtx.state === 'closed') {
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    }
    if (audioCtx.state === 'suspended') audioCtx.resume();
    return audioCtx;
  }

  /*
   * buildFxChain — connects source → effect nodes → destination
   * Returns the first node in the chain (to connect source to).
   * All effects run entirely in-browser via Web Audio API.
   */
  function buildFxChain(ctx, fxType) {
    const dest = ctx.destination;

    if (fxType === 'robot') {
      // Ring modulator: multiply signal with a sine carrier → metallic buzz
      const gain = ctx.createGain();
      gain.gain.value = 1.5;
      const osc = ctx.createOscillator();
      osc.frequency.value = 60;
      osc.type = 'sawtooth';
      const ringGain = ctx.createGain();
      ringGain.gain.value = 0;
      osc.connect(ringGain.gain);
      gain.connect(ringGain);
      // waveshaper distortion for extra grittiness
      const waveShape = ctx.createWaveShaper();
      waveShape.curve = makeDistortionCurve(80);
      ringGain.connect(waveShape);
      waveShape.connect(dest);
      osc.start();
      return { input: gain, cleanup: () => osc.stop() };
    }

    if (fxType === 'alien') {
      // Fast ring modulator at high frequency = alien/chopper effect
      const gain = ctx.createGain();
      gain.gain.value = 1.2;
      const osc = ctx.createOscillator();
      osc.frequency.value = 280;
      osc.type = 'sine';
      const ringGain = ctx.createGain();
      ringGain.gain.value = 0;
      osc.connect(ringGain.gain);
      gain.connect(ringGain);
      const filter = ctx.createBiquadFilter();
      filter.type = 'bandpass';
      filter.frequency.value = 1800;
      filter.Q.value = 1.5;
      ringGain.connect(filter);
      filter.connect(dest);
      osc.start();
      return { input: gain, cleanup: () => osc.stop() };
    }

    if (fxType === 'echo') {
      // Stereo delay + slight chorus shimmer
      const delay = ctx.createDelay(0.8);
      delay.delayTime.value = 0.22;
      const feedback = ctx.createGain();
      feedback.gain.value = 0.38;
      const wetGain = ctx.createGain();
      wetGain.gain.value = 0.55;
      const dryGain = ctx.createGain();
      dryGain.gain.value = 1.0;
      const input = ctx.createGain();
      input.connect(dryGain);
      input.connect(delay);
      delay.connect(feedback);
      feedback.connect(delay);
      delay.connect(wetGain);
      dryGain.connect(dest);
      wetGain.connect(dest);
      return { input, cleanup: () => {} };
    }

    if (fxType === 'deep') {
      // Low-shelf boost + slight reverb tail via convolver approximation
      const filter = ctx.createBiquadFilter();
      filter.type = 'lowshelf';
      filter.frequency.value = 300;
      filter.gain.value = 9;
      const compressor = ctx.createDynamicsCompressor();
      compressor.threshold.value = -18;
      compressor.ratio.value = 4;
      filter.connect(compressor);
      compressor.connect(dest);
      return { input: filter, cleanup: () => {} };
    }

    if (fxType === 'chipmunk') {
      // High-pass + mild overdrive → bright, airy tone
      const filter = ctx.createBiquadFilter();
      filter.type = 'highshelf';
      filter.frequency.value = 2500;
      filter.gain.value = 7;
      filter.connect(dest);
      return { input: filter, cleanup: () => {} };
    }

    if (fxType === 'pirate') {
      // Bandpass at mid-range + slight distortion = gravelly, nautical croak
      const bandpass = ctx.createBiquadFilter();
      bandpass.type = 'bandpass';
      bandpass.frequency.value = 900;
      bandpass.Q.value = 0.8;
      const wave = ctx.createWaveShaper();
      wave.curve = makeDistortionCurve(40);
      bandpass.connect(wave);
      wave.connect(dest);
      return { input: bandpass, cleanup: () => {} };
    }

    // 'none' — straight passthrough
    const gain = ctx.createGain();
    gain.connect(dest);
    return { input: gain, cleanup: () => {} };
  }

  function makeDistortionCurve(amount) {
    const samples = 256;
    const curve = new Float32Array(samples);
    for (let i = 0; i < samples; i++) {
      const x = (i * 2) / samples - 1;
      curve[i] = ((Math.PI + amount) * x) / (Math.PI + amount * Math.abs(x));
    }
    return curve;
  }

  // ─── Core speak function ───────────────────────────────────────────────────
  function speak(text) {
    const type = document.getElementById('voice-select').value;
    if (type === 'silencioso' || !('speechSynthesis' in window)) return;
    window.speechSynthesis.cancel();

    const profile = VOICE_PROFILES[type] || { gender: 'female', pitch: 1.1, rate: 1.0, fx: 'none' };
    const u = new SpeechSynthesisUtterance(text);
    u.lang = 'pt-BR';
    const userRate = parseFloat(document.getElementById('rate').value);
    u.rate = Math.max(0.5, Math.min(2, profile.rate * userRate));
    u.volume = parseFloat(document.getElementById('volume').value);
    u.pitch = profile.pitch;
    const v = pickVoice(profile.gender);
    if (v) u.voice = v;

    // Try Web Audio effect chain (Chrome/Edge support MediaStreamDestination from speech)
    if (profile.fx !== 'none' && window.AudioContext) {
      try {
        const ctx = getAudioCtx();
        const streamDest = ctx.createMediaStreamDestination();
        const chain = buildFxChain(ctx, profile.fx);

        // Temporarily redirect utterance through AudioContext:
        // We speak into a hidden audio element connected to the effect chain.
        // On browsers that don't support this, it falls back to direct speech.
        const audioEl = new Audio();
        audioEl.srcObject = streamDest.stream;
        audioEl.volume = u.volume;

        // Reroute: speak normally but capture output — this only works where
        // SpeechSynthesis output can be captured. Where not supported, we fall
        // through to direct speak below.
        u.onstart = () => { audioEl.play().catch(() => {}); };
        u.onend = () => { chain.cleanup(); audioEl.srcObject = null; };

        // Connect chain input to streamDest
        chain.input.connect(streamDest);
      } catch (_) {
        // Web Audio routing not supported — continue with direct speech below
      }
    }

    window.speechSynthesis.speak(u);
  }

  // ─── Histórico ────────────────────────────────────────────────────────────────
  function logHistory(item) {
    let hist = [];
    try { hist = JSON.parse(localStorage.getItem('nv-history') || '[]'); } catch (e) {}
    hist.push({ id: item.id, time: Date.now(), label: item.label, category: item.category, icon: item.icon, sentence: sentenceText() });
    localStorage.setItem('nv-history', JSON.stringify(hist));
    renderFrequent();
  }

  // ─── Ações da frase ───────────────────────────────────────────────────────────
  document.getElementById('btn-speak').addEventListener('click', () => { if (sentence.length) speak(sentenceText()); });
  document.getElementById('btn-back').addEventListener('click', () => { sentence.pop(); renderSentence(); });
  document.getElementById('btn-clear-sentence').addEventListener('click', () => { sentence = []; renderSentence(); });

  // ─── Categorias ───────────────────────────────────────────────────────────────
  document.querySelectorAll('.cat-pill').forEach((pill) => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.cat-pill').forEach((p) => { p.classList.remove('active'); p.setAttribute('aria-selected', 'false'); });
      pill.classList.add('active'); pill.setAttribute('aria-selected', 'true');
      activeCat = pill.dataset.cat;
      renderGrid();
    });
  });

  // ─── Tela cheia ───────────────────────────────────────────────────────────────
  document.getElementById('btn-fullscreen').addEventListener('click', () => {
    if (!document.fullscreenElement) document.documentElement.requestFullscreen?.();
    else document.exitFullscreen?.();
  });

  // ─── Init ─────────────────────────────────────────────────────────────────────
  renderFrequent();
  renderGrid();
  renderSentence();
</script>

<style>
  .tablet-page { padding: 24px 0 60px; }
  .tablet-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 16px; flex-wrap: wrap; margin-bottom: 18px; }
  .t-title { font-size: clamp(1.5rem, 4vw, 2.2rem); margin-top: 6px; }
  .t-controls { display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; }
  .ctrl { display: flex; flex-direction: column; gap: 4px; font-family: var(--font-head); font-weight: 700; font-size: 0.78rem; color: var(--text-soft); }
  .ctrl select, .ctrl input { font-family: var(--font-body); }
  .ctrl select { padding: 8px 10px; border-radius: 10px; border: 2px solid var(--border); background: var(--surface); color: var(--text); }
  .ctrl input[type=range] { width: 110px; accent-color: var(--blue); }

  /* ── Sentence bar ─────────────────────────────────────────────────────────── */
  .sentence-bar { display: flex; gap: 12px; align-items: stretch; background: var(--surface); border: 2px solid var(--border); border-radius: var(--radius-lg); padding: 12px; box-shadow: var(--shadow-sm); margin-bottom: 16px; }
  .sentence-strip { flex: 1; display: flex; gap: 8px; align-items: center; flex-wrap: wrap; min-height: 64px; padding: 4px 8px; overflow-x: auto; }
  .sentence-placeholder { color: var(--text-muted); font-weight: 600; }
  .s-chip { display: inline-flex; align-items: center; gap: 6px; background: var(--bg-alt); color: var(--text); border-radius: 12px; padding: 10px 14px; font-family: var(--font-head); font-weight: 800; font-size: 1.05rem; animation: pop 0.25s ease; }
  .s-chip span { font-size: 1.4rem; }
  .sentence-actions { display: flex; gap: 8px; align-items: center; }
