<style>
  .day-page { padding: 24px 0 80px; }

  /* Header */
  .day-head {
    display: flex; justify-content: space-between; align-items: flex-end;
    gap: 20px; flex-wrap: wrap; margin-bottom: 28px;
  }
  .day-lead { color: var(--text-soft); margin-top: 6px; font-size: 1.05rem; }
  .day-head h1 { font-size: clamp(1.8rem, 4vw, 2.5rem); margin: 8px 0 0; }
  .day-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
  .day-date {
    font-family: var(--font-head); font-weight: 700; font-size: 0.82rem;
    color: var(--text-muted); text-transform: capitalize;
  }
  .day-stats {
    display: flex; align-items: center; gap: 16px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 999px; padding: 10px 22px; box-shadow: var(--shadow-sm);
  }
  .day-stat { display: flex; flex-direction: column; align-items: center; gap: 1px; }
  .day-stat strong { font-family: var(--font-head); font-size: 1.2rem; font-weight: 900; color: var(--blue-ink); }
  .day-stat span { font-size: 0.68rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }
  .day-stat-divider { width: 1px; height: 28px; background: var(--border); }

  /* ── Primeiro / Depois ───────────────────────────────────────────────────── */
  .fd-strip {
    display: grid;
    grid-template-columns: 1fr 56px 1fr;
    gap: 0; align-items: center;
    margin-bottom: 20px;
  }

  .fd-card {
    background: var(--surface);
    border: 2.5px solid var(--border);
    border-radius: 28px;
    padding: 28px 24px 24px;
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    text-align: center;
    position: relative; overflow: hidden;
    transition: border-color 0.25s, box-shadow 0.25s;
    min-height: 240px; justify-content: center;
  }
  .fd-card::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0; height: 6px;
    background: var(--ac, var(--blue));
    border-radius: 0 0 26px 26px;
    opacity: 0.5;
    transition: opacity 0.25s;
  }
  .fd-now.has-activity {
    border-color: var(--ac, var(--blue));
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--ac, var(--blue)) 12%, transparent), var(--shadow);
  }
  .fd-now.has-activity::after { opacity: 1; }

  .fd-badge {
    display: inline-flex; align-items: center;
    font-family: var(--font-head); font-weight: 900; font-size: 0.68rem;
    letter-spacing: 0.1em;
    padding: 4px 14px; border-radius: 999px;
  }
  .fd-badge-now {
    color: var(--ac, var(--blue-ink));
    background: color-mix(in srgb, var(--ac, var(--blue)) 14%, transparent);
  }
  .fd-badge-next { color: var(--text-muted); background: var(--bg-alt); }

  .fd-icon-wrap {
    width: 96px; height: 96px;
    border-radius: 28px;
    background: color-mix(in srgb, var(--ac, var(--blue)) 12%, var(--bg-alt));
    display: grid; place-items: center;
    transition: background 0.25s;
  }
  .fd-icon-wrap-next {
    width: 80px; height: 80px;
    border-radius: 24px;
    background: var(--bg-alt);
    opacity: 0.85;
  }
  .fd-icon { font-size: 3.6rem; line-height: 1; }
  .fd-icon-wrap-next .fd-icon { font-size: 2.8rem; }

  .fd-name { font-family: var(--font-head); font-weight: 900; font-size: 1.35rem; color: var(--text); line-height: 1.2; }
  .fd-next .fd-name { font-size: 1.1rem; color: var(--text-soft); }
  .fd-time { font-size: 0.88rem; color: var(--text-muted); font-weight: 700; min-height: 1.2em; }

  /* Progress bar in fd-now */
  .fd-bar-wrap { width: 100%; display: flex; flex-direction: column; gap: 5px; }
  .fd-bar-track { height: 10px; border-radius: 999px; background: var(--bg-alt); overflow: hidden; }
  .fd-bar-fill { height: 100%; border-radius: 999px; transition: width 0.5s ease; }
  .fd-bar-label { font-size: 0.8rem; font-weight: 800; color: var(--text-soft); text-align: center; }

  /* Complete button */
  .fd-complete-btn {
    margin-top: 4px;
    background: var(--ac, var(--blue)) !important;
    color: #fff !important;
    border: none !important;
    border-radius: 14px !important;
    padding: 12px 28px !important;
    font-family: var(--font-head) !important;
    font-weight: 900 !important; font-size: 1rem !important;
    cursor: pointer; transition: transform 0.15s, box-shadow 0.15s !important;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--ac, var(--blue)) 35%, transparent) !important;
    min-height: unset !important; line-height: 1.3 !important;
  }
  .fd-complete-btn:hover { transform: scale(1.04); }
  .fd-complete-btn:active { transform: scale(0.97); }

  /* Arrow divider */
  .fd-divider {
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 0;
  }
  .fd-divider-arrow {
    font-size: 2rem; color: var(--text-muted);
    font-weight: 900; animation: arrow-pulse 2s ease-in-out infinite;
  }
  @keyframes arrow-pulse {
    0%, 100% { opacity: 0.5; transform: translateX(0); }
    50% { opacity: 1; transform: translateX(4px); }
  }

  /* ── Global progress ─────────────────────────────────────────────────── */
  .global-prog {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 20px; padding: 14px 20px; margin-bottom: 20px;
    box-shadow: var(--shadow-sm);
  }
  .global-prog-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .global-prog-head span { font-weight: 800; font-size: 0.88rem; color: var(--text-soft); }
  .global-prog-head strong { font-family: var(--font-head); font-weight: 900; color: var(--blue-ink); }
  .global-prog-track {
    position: relative; height: 20px; border-radius: 999px;
    background: var(--bg-alt); overflow: visible;
  }
  .global-prog-fill {
    height: 100%; border-radius: 999px;
    background: linear-gradient(90deg, var(--mint), var(--blue));
    transition: width 0.5s ease;
  }
  .global-prog-markers { position: absolute; inset: 0; pointer-events: none; }
  .gp-marker {
    position: absolute; top: 50%; transform: translate(-50%, -50%);
    font-size: 1.1rem;
    transition: opacity 0.2s;
  }
  .gp-marker.done { opacity: 0.4; filter: grayscale(1); }
  .gp-marker.active { font-size: 1.3rem; }
  .global-prog-now {
    position: absolute; top: -4px; bottom: -4px; width: 3px;
    background: var(--coral); border-radius: 999px;
    transform: translateX(-50%);
    pointer-events: none; box-shadow: 0 0 0 2px rgba(255,155,133,.35);
  }

  /* ── Layout ──────────────────────────────────────────────────────────── */
  .routine-layout {
    display: grid;
    grid-template-columns: 340px minmax(0, 1fr);
    gap: 20px; align-items: start;
  }

  /* ── Form panel ──────────────────────────────────────────────────────── */
  .form-panel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 24px; padding: 24px; box-shadow: var(--shadow-sm);
    position: sticky; top: 88px;
  }
  .form-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .form-head h2 { font-size: 1.15rem; margin: 0; }
  .form-cancel {
    width: 34px !important; height: 34px !important; min-height: 34px !important;
    padding: 0 !important; border-radius: 10px !important;
    font-size: 1rem; font-weight: 900;
    background: var(--bg-alt) !important; border: 1px solid var(--border) !important;
    box-shadow: none !important; color: var(--text-soft) !important;
  }
  .form-cancel:hover { background: var(--coral) !important; color: #fff !important; border-color: var(--coral) !important; }

  /* Emoji quick picks */
  .emoji-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 6px; margin-bottom: 16px;
  }
  .emoji-pick {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    padding: 8px 4px; border-radius: 14px;
    background: var(--bg-alt); border: 2px solid transparent;
    cursor: pointer; font-size: 1.5rem; transition: border-color 0.15s, background 0.15s;
  }
  .emoji-pick span { font-size: 0.62rem; font-weight: 800; color: var(--text-soft); font-family: var(--font-head); white-space: nowrap; }
  .emoji-pick:hover { border-color: var(--blue); background: var(--surface); }
  .emoji-pick:active { transform: scale(0.95); }

  /* Form fields */
  .rf-label { font-family: var(--font-head); font-weight: 800; font-size: 0.78rem; color: var(--text-soft); margin-bottom: 5px; display: block; }
  .rf-field { display: flex; flex-direction: column; margin-bottom: 12px; }
  .rf-field input, .rf-field select, .rf-field textarea {
    font: inherit; font-size: 0.95rem; color: var(--text);
    background: var(--surface-2); border: 2px solid var(--border);
    border-radius: 12px; padding: 9px 12px; width: 100%;
    transition: border-color 0.15s;
  }
  .rf-field input:focus, .rf-field select:focus, .rf-field textarea:focus {
    border-color: var(--blue); outline: none;
