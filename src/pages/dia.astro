---
import Base from '../layouts/Base.astro';
---

<Base title="Plano do Dia — NeuroVoz" description="Centro de rotina visual com sequência Primeiro/Depois, progresso por tempo, arrastar para reordenar e edição de atividades.">
  <section class="day-page">
    <div class="container">

      <!-- ── Header ──────────────────────────────────────────────────────── -->
      <header class="day-head">
        <div class="day-head-text">
          <span class="eyebrow">Centro de Rotina</span>
          <h1>Plano do Dia</h1>
          <p>Monte a sequência de atividades, acompanhe o progresso e prepare transições com apoio visual.</p>
        </div>
        <div class="day-meta">
          <span class="day-date" id="day-date-label"></span>
          <div class="day-stats">
            <div class="day-stat">
              <strong id="stat-done">0</strong>
              <span>concluídas</span>
            </div>
            <div class="day-stat-divider"></div>
            <div class="day-stat">
              <strong id="stat-total">0</strong>
              <span>no plano</span>
            </div>
            <div class="day-stat-divider"></div>
            <div class="day-stat">
              <strong id="stat-pct">0%</strong>
              <span>completo</span>
            </div>
          </div>
        </div>
      </header>

      <!-- ── Primeiro / Depois ──────────────────────────────────────────── -->
      <div class="fd-strip" aria-live="polite" aria-label="Atividade atual e próxima">
        <div class="fd-card fd-now" id="fd-now">
          <span class="fd-badge">Primeiro</span>
          <div class="fd-content">
            <div class="fd-icon" id="fd-now-icon" aria-hidden="true">📍</div>
            <div class="fd-text">
              <strong id="fd-now-name">Nenhuma atividade</strong>
              <span id="fd-now-time">—</span>
            </div>
          </div>
          <div class="fd-time-bar-wrap" id="fd-now-bar-wrap">
            <div class="fd-time-bar-track">
              <div class="fd-time-bar-fill" id="fd-time-bar-fill"></div>
            </div>
            <span class="fd-time-bar-label" id="fd-time-bar-label">⏳</span>
          </div>
        </div>

        <div class="fd-arrow" aria-hidden="true">→</div>

        <div class="fd-card fd-next" id="fd-next">
          <span class="fd-badge">Depois</span>
          <div class="fd-content">
            <div class="fd-icon" id="fd-next-icon" aria-hidden="true">⏳</div>
            <div class="fd-text">
              <strong id="fd-next-name">Adicione atividades</strong>
              <span id="fd-next-time">—</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Global time progress bar ──────────────────────────────────── -->
      <div class="global-progress-wrap" id="global-progress-wrap" hidden>
        <div class="global-progress-row">
          <span class="global-progress-label" id="global-progress-label">0 de 0 concluídas</span>
          <span class="global-progress-pct" id="global-progress-pct">0%</span>
        </div>
        <div class="global-progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" id="global-progress-track">
          <div class="global-progress-fill" id="global-progress-fill"></div>
          <!-- Time markers rendered by JS -->
          <div class="global-progress-markers" id="global-progress-markers"></div>
        </div>
        <div class="global-progress-now-line" id="global-progress-now-line" aria-hidden="true"></div>
      </div>

      <!-- ── Layout ─────────────────────────────────────────────────────── -->
      <div class="routine-layout">

        <!-- Form: add / edit activity -->
        <aside class="routine-form-panel" id="routine-form-panel">
          <header class="form-panel-head">
            <h2 id="form-panel-title">Nova atividade</h2>
            <button class="form-cancel-btn" id="form-cancel-btn" hidden type="button" aria-label="Cancelar edição">×</button>
          </header>

          <form id="routine-form" autocomplete="off">
            <input type="hidden" id="edit-id" />

            <label class="rf-field">
              <span>Nome</span>
              <input id="rf-name" type="text" required placeholder="Ex.: Banho" />
            </label>

            <div class="rf-row">
              <label class="rf-field">
                <span>Ícone</span>
                <input id="rf-icon" type="text" maxlength="4" placeholder="🛁" />
              </label>
              <label class="rf-field">
                <span>Cor</span>
                <input id="rf-color" type="color" value="#5b8def" />
              </label>
            </div>

            <div class="rf-row">
              <label class="rf-field">
                <span>Horário início</span>
                <input id="rf-time-start" type="time" />
              </label>
              <label class="rf-field">
                <span>Horário fim</span>
                <input id="rf-time-end" type="time" />
              </label>
            </div>

            <label class="rf-field rf-alarm-row" id="rf-alarm-row" hidden>
              <span>Alarme no horário</span>
              <select id="rf-alarm">
                <option value="true">Ativado</option>
                <option value="false">Desativado</option>
              </select>
            </label>

            <label class="rf-field">
              <span>Observações</span>
              <textarea id="rf-notes" rows="2" placeholder="Ex.: usar apoio visual"></textarea>
            </label>

            <div class="rf-actions">
              <button class="btn btn-primary" type="submit" id="form-submit-btn">Adicionar</button>
            </div>
          </form>

          <!-- Celebration theme picker -->
          <div class="rf-divider"></div>
          <label class="rf-field">
            <span>Tema de celebração</span>
            <select id="routine-theme">
              <option value="auto">Usar interesses do perfil</option>
              <option value="confetes">🎉 Confetes</option>
              <option value="dinossauros">🦖 Dinossauros</option>
              <option value="carros">🚗 Carros</option>
              <option value="flores">🌸 Flores</option>
              <option value="estrelas">⭐ Estrelas</option>
              <option value="unicornio">🦄 Unicórnios</option>
              <option value="espaco">🚀 Espaço</option>
              <option value="animais">🐶 Animais</option>
              <option value="princesas">👑 Princesas</option>
            </select>
          </label>
        </aside>

        <!-- Activity list -->
        <div class="routine-panel">
          <div class="routine-panel-head">
            <h2>Atividades de hoje</h2>
            <div class="routine-panel-tools">
              <button class="btn btn-ghost rpt-btn" id="btn-clear-done" type="button" title="Remover concluídas">Limpar concluídas</button>
              <button class="btn btn-ghost rpt-btn" id="btn-reset-day" type="button" title="Reiniciar dia">Reiniciar dia</button>
            </div>
          </div>

          <div class="routine-drag-hint" id="drag-hint" hidden>
            <span>Segure e arraste para reordenar</span>
          </div>

          <ul class="routine-list" id="routine-list" aria-live="polite" aria-label="Lista de atividades"></ul>
        </div>
      </div>

      <!-- ── Stats row ─────────────────────────────────────────────────── -->
      <div class="routine-reports">
        <article>
          <span id="routine-report-done">0</span>
          <strong>Concluídas hoje</strong>
        </article>
        <article>
          <span id="routine-report-rate">0%</span>
          <strong>Taxa diária</strong>
        </article>
        <article>
          <span id="routine-report-peak">--:--</span>
          <strong>Maior participação</strong>
        </article>
        <article>
          <span id="routine-report-week">0</span>
          <strong>Histórico semanal</strong>
        </article>
      </div>

    </div>
  </section>
</Base>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<script>
  // @ts-nocheck
  const ROUTINE_KEY = 'nv-routine-plan';
  const ROUTINE_HISTORY_KEY = 'nv-routine-history';
  const ROUTINE_SETTINGS_KEY = 'nv-routine-settings';

  // ─── Utils ──────────────────────────────────────────────────────────────
  function readJson(key, fallback) {
    try { return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback)); } catch { return fallback; }
  }
  function writeJson(key, value) {
    localStorage.setItem(key, JSON.stringify(value));
    window.dispatchEvent(new Event('nv-routine-updated'));
    window.NVRoutine?.refreshUI?.();
  }
  function escHtml(v) {
    return String(v ?? '').replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }
  function todayKey() { return new Date().toISOString().slice(0, 10); }
  function nowMs() { return Date.now(); }

  function minutesOf(t) {
    if (!t) return null;
    const [h, m] = t.split(':').map(Number);
    return (isNaN(h) || isNaN(m)) ? null : h * 60 + m;
  }
  function targetMs(act) {
    if (!act?.timeStart) return null;
    const [h, m] = String(act.timeStart).split(':').map(Number);
    if (isNaN(h) || isNaN(m)) return null;
    const d = new Date(); d.setHours(h, m, 0, 0);
    return d.getTime();
  }
  function endMs(act) {
    if (!act?.timeEnd) return null;
    const [h, m] = String(act.timeEnd).split(':').map(Number);
    if (isNaN(h) || isNaN(m)) return null;
    const d = new Date(); d.setHours(h, m, 0, 0);
    return d.getTime();
  }

  // ─── Persistence ────────────────────────────────────────────────────────
  function loadRoutine() {
    const saved = readJson(ROUTINE_KEY, null);
    if (saved?.day === todayKey() && Array.isArray(saved.activities)) return saved.activities;
    writeJson(ROUTINE_KEY, { day: todayKey(), activities: [] });
    return [];
  }
  function saveRoutine(acts) { writeJson(ROUTINE_KEY, { day: todayKey(), activities: acts }); }
  function loadSettings() { return readJson(ROUTINE_SETTINGS_KEY, { hidden: false, theme: 'auto' }); }
  function saveSettings(s) { writeJson(ROUTINE_SETTINGS_KEY, s); }
  function loadHistory() { return readJson(ROUTINE_HISTORY_KEY, []); }
  function saveHistory(h) { writeJson(ROUTINE_HISTORY_KEY, h.slice(0, 240)); }

  // ─── Sorting ─────────────────────────────────────────────────────────────
  function sortedActivities() {
    return loadRoutine().sort((a, b) => {
      const at = targetMs(a), bt = targetMs(b);
      if (at === null && bt === null) return (a.order ?? 0) - (b.order ?? 0);
      if (at === null) return 1;
      if (bt === null) return -1;
      return at - bt;
    });
  }

  function getSnapshot() {
    const activities = sortedActivities();
    const now = nowMs();
    const timed = activities.filter((i) => targetMs(i) !== null);
    let current = timed.filter((i) => targetMs(i) <= now && !i.completed).at(-1)
      || activities.find((i) => !i.completed && targetMs(i) === null) || null;
    if (!current) current = activities.find((i) => !i.completed) || null;
    const next = activities.find((i) => !i.completed && i.id !== current?.id && (targetMs(i) ?? Infinity) > now)
      || activities.find((i) => !i.completed && i.id !== current?.id) || null;
    return { activities, current, next };
  }

  function formatUntil(act) {
    const t = targetMs(act);
    if (t === null) return 'Sem horário';
    let diff = Math.floor((t - nowMs()) / 1000);
    if (diff <= 0) return 'Agora';
    const h = Math.floor(diff / 3600), m = Math.floor((diff % 3600) / 60), s = diff % 60;
    if (h > 0) return `Faltam ${h}h ${String(m).padStart(2,'0')}m`;
    if (m > 0) return `Faltam ${m}m ${String(s).padStart(2,'0')}s`;
    return `Faltam ${s}s`;
  }

  // ─── Icon auto-detection ─────────────────────────────────────────────────
  function guessIcon(raw) {
    const t = (raw || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    const rules = [
      [/banho|chuveiro|ducha/, '🛁'], [/escovar|dente/, '🪥'], [/dormir|cama|soneca/, '🛏️'],
      [/acordar|levantar/, '⏰'], [/comer|refeicao|almoco|janta|lanche|merenda/, '🍎'],
      [/cafe|desjejum/, '☕'], [/agua|beber/, '💧'], [/escola|aula|professor/, '👩‍🏫'],
      [/tarefa|dever|estudo|ler|livro/, '📚'], [/brincar|jogo|jogar/, '🎮'],
      [/parque|playground/, '🛝'], [/caminhar|passeio|correr/, '🚶'],
      [/natacao|nadar|piscina/, '🏊'], [/bicicleta|pedalar/, '🚴'],
      [/desenho|pintar|arte/, '🎨'], [/musica|cantar/, '🎵'],
      [/terapia|fono|psicologo/, '🧩'], [/remedio|medicacao/, '💊'],
      [/banheiro|xixi/, '🚽'], [/roupa|vestir/, '👕'],
      [/carro|onibus/, '🚗'], [/compras|mercado/, '🛒'],
      [/limpar|arrumar|organizar/, '🧹'], [/yoga|meditacao|respirar/, '🧘'],
      [/tv|filme|serie|assistir/, '📺'], [/festa|aniversario/, '🎉'],
    ];
    return rules.find(([re]) => re.test(t))?.[1] || '';
  }

  // ─── TTS ─────────────────────────────────────────────────────────────────
  function speak(text) {
    if (!('speechSynthesis' in window)) return;
    window.speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance(text);
    u.lang = 'pt-BR';
    window.speechSynthesis.speak(u);
  }

  // ─── Celebration ─────────────────────────────────────────────────────────
  function inferTheme() {
    const s = loadSettings();
    if (s.theme && s.theme !== 'auto') return s.theme;
    const c = readJson('nv-tablet-config', {});
    const txt = `${c.interesses||''} ${c.hiperfocos||''} ${c.brincadeiras||''} ${c.personagens||''}`.toLowerCase();
    const rules = [
      ['dinossauros', ['dinossauro', 'dino']], ['carros', ['carro', 'caminhao', 'onibus']],
      ['princesas', ['princesa', 'coroa']], ['animais', ['animal', 'cachorro', 'gato']],
      ['espaco', ['espaco', 'foguete', 'planeta']], ['flores', ['flor']], ['unicornio', ['unicornio']],
    ];
    return rules.find(([, ws]) => ws.some((w) => txt.includes(w)))?.[0] || 'confetes';
  }
  const THEME_ICONS = { dinossauros:'🦖', carros:'🚗', flores:'🌸', estrelas:'⭐', unicornio:'🦄', espaco:'🚀', animais:'🐶', confetes:'🎉', princesas:'👑' };

  function celebrate(msg = '🎉 Muito bem!') {
    const el = document.getElementById('nv-timer-celebration');
    if (!el) return;
    const sym = THEME_ICONS[inferTheme()] || '🎉';
    el.innerHTML = '';
    el.removeAttribute('hidden');
    el.classList.add('active');
    for (let i = 0; i < 24; i++) {
      const d = document.createElement('span');
      d.className = 'rain-item';
      d.textContent = sym;
      d.style.left = `${Math.random() * 94}%`;
      d.style.animationDelay = `${Math.random() * 1.4}s`;
      d.style.fontSize = `${18 + Math.random() * 22}px`;
      el.appendChild(d);
    }
    const card = document.createElement('div');
    card.className = 'celebration-message';
    card.innerHTML = `<strong>${msg}</strong><p>Vamos para a próxima atividade!</p>`;
    el.appendChild(card);
    setTimeout(() => { el.classList.remove('active'); el.setAttribute('hidden', ''); el.innerHTML = ''; }, 5200);
  }

  // ─── Complete / Remove ────────────────────────────────────────────────────
  function completeActivity(id) {
    const acts = loadRoutine();
    const item = acts.find((a) => a.id === id);
    if (!item || item.completed) return;
    item.completed = true;
    item.completedAt = new Date().toISOString();
    const hist = loadHistory();
    hist.unshift({
      id: item.id, name: item.name, icon: item.icon,
      time: item.timeStart, completedAt: new Date().toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}),
      date: todayKey(), type: 'completed',
    });
    saveHistory(hist);
    saveRoutine(acts);
    speak(`${item.name} concluído. Muito bem!`);
    celebrate('🎉 Muito bem!');
    render();
  }

  function removeActivity(id) {
    saveRoutine(loadRoutine().filter((a) => a.id !== id));
    render();
  }

  // ─── Alarm / tick ─────────────────────────────────────────────────────────
  function notify(title, body) {
    try {
      if ('Notification' in window && Notification.permission === 'granted')
        new Notification(title, { body, icon: '/icon.svg', tag: `nv-${title}` });
    } catch {}
  }

  function tick() {
    const acts = loadRoutine();
    const now = nowMs();
    let changed = false;
    acts.forEach((item) => {
      const t = targetMs(item);
      if (t === null || item.completed) return;
      const cdMs = (Number(item.countdown) || 5) * 60 * 1000;
      if (cdMs > 0 && !item.countdownFired && now >= t - cdMs && now < t) {
        item.countdownFired = true; changed = true;
        const diff = Math.round((t - now) / 60000);
        const label = diff < 1 ? `Falta menos de um minuto para ${item.name}` : `Faltam ${diff} minutos para ${item.name}`;
        speak(label); celebrate('⏳ Prepare-se!'); notify('⏳ Prepare-se', label);
      }
      if (item.alarm && !item.alarmFired && now >= t) {
        item.alarmFired = true; changed = true;
        speak(`Hora de ${item.name}`); celebrate(`${item.icon||'📍'} Hora de ${item.name}!`);
        notify(`${item.icon||'📍'} ${item.name}`, `Hora de ${item.name}`);
      }
    });
    if (changed) saveRoutine(acts);
    render();
  }

  // ─── Render ───────────────────────────────────────────────────────────────
  function render() {
    const { activities, current, next } = getSnapshot();
    const done = activities.filter((a) => a.completed).length;
    const total = activities.length;
    const pct = total ? Math.round((done / total) * 100) : 0;

    // Date label
    const dateLabel = document.getElementById('day-date-label');
    if (dateLabel) {
      const d = new Date();
      dateLabel.textContent = d.toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long' });
    }

    // Stats
    document.getElementById('stat-done').textContent = String(done);
    document.getElementById('stat-total').textContent = String(total);
    document.getElementById('stat-pct').textContent = `${pct}%`;

    // Primeiro / Depois cards
    const nowIcon = document.getElementById('fd-now-icon');
    const nowName = document.getElementById('fd-now-name');
    const nowTime = document.getElementById('fd-now-time');
    const nextIcon = document.getElementById('fd-next-icon');
    const nextName = document.getElementById('fd-next-name');
    const nextTime = document.getElementById('fd-next-time');
    const nowCard = document.getElementById('fd-now');
    const nextCard = document.getElementById('fd-next');

    if (current) {
      nowIcon.textContent = current.icon || '📍';
      nowName.textContent = current.name;
      nowTime.textContent = current.timeStart ? `${current.timeStart}${current.timeEnd ? ' – '+current.timeEnd : ''}` : 'Sem horário';
      nowCard.style.setProperty('--act-color', current.color || '#5b8def');
      nowCard.classList.toggle('has-time', !!current.timeStart);
    } else {
      nowIcon.textContent = total ? '🎉' : '📍';
      nowName.textContent = total ? 'Tudo concluído!' : 'Nenhuma atividade';
      nowTime.textContent = '—';
      nowCard.style.removeProperty('--act-color');
    }

    if (next) {
      nextIcon.textContent = next.icon || '⏳';
      nextName.textContent = next.name;
      nextTime.textContent = next.timeStart ? `${next.timeStart}${next.timeEnd ? ' – '+next.timeEnd : ''}` : formatUntil(next);
      nextCard.style.setProperty('--act-color', next.color || '#5b8def');
    } else {
      nextIcon.textContent = '—';
      nextName.textContent = total ? 'Última atividade' : 'Adicione atividades';
      nextTime.textContent = '—';
      nextCard.style.removeProperty('--act-color');
    }

    // Time-based progress bar for current activity
    const barWrap = document.getElementById('fd-now-bar-wrap');
    const barFill = document.getElementById('fd-time-bar-fill');
    const barLabel = document.getElementById('fd-time-bar-label');
    if (current && current.timeStart && current.timeEnd) {
      barWrap.hidden = false;
      const start = targetMs(current);
      const end = endMs(current);
      const now2 = nowMs();
      const elapsed = Math.max(0, Math.min(1, (now2 - start) / (end - start)));
      barFill.style.width = `${elapsed * 100}%`;
      barLabel.textContent = elapsed >= 1 ? '✅ Tempo esgotado' : formatUntil({timeStart: current.timeEnd});
    } else if (current && current.timeStart) {
      barWrap.hidden = false;
      barFill.style.width = '100%';
      barLabel.textContent = formatUntil(current);
    } else {
      barWrap.hidden = true;
    }

    // Global timeline bar
    const globalWrap = document.getElementById('global-progress-wrap');
    const globalFill = document.getElementById('global-progress-fill');
    const globalLabel = document.getElementById('global-progress-label');
    const globalPct = document.getElementById('global-progress-pct');
    const globalTrack = document.getElementById('global-progress-track');
    const globalMarkers = document.getElementById('global-progress-markers');
    const nowLine = document.getElementById('global-progress-now-line');

    const timedActs = activities.filter((a) => a.timeStart);
    if (timedActs.length >= 2) {
      globalWrap.hidden = false;
      const earliest = Math.min(...timedActs.map((a) => targetMs(a)));
      const latest = Math.max(...timedActs.map((a) => endMs(a) || targetMs(a)));
      const span = latest - earliest;
      const nowPos = span > 0 ? Math.max(0, Math.min(100, ((nowMs() - earliest) / span) * 100)) : 0;

      globalFill.style.width = `${pct}%`;
      globalFill.style.background = `linear-gradient(90deg, var(--mint), var(--blue))`;
      globalLabel.textContent = `${done} de ${total} concluídas`;
      globalPct.textContent = `${pct}%`;
      globalTrack.setAttribute('aria-valuenow', String(pct));

      // Render time markers
      globalMarkers.innerHTML = '';
      timedActs.forEach((a) => {
        if (span <= 0) return;
        const pos = ((targetMs(a) - earliest) / span) * 100;
        const mk = document.createElement('span');
        mk.className = `gp-marker${a.completed ? ' done' : ''}${a.id === current?.id ? ' active' : ''}`;
        mk.style.left = `${pos}%`;
        mk.title = `${a.icon||'📍'} ${a.name} (${a.timeStart})`;
        mk.setAttribute('aria-hidden', 'true');
        mk.textContent = a.icon || '📍';
        globalMarkers.appendChild(mk);
      });

      // Now line
      nowLine.style.left = `calc(${nowPos}% + 0px)`;
      nowLine.hidden = false;
    } else {
      globalWrap.hidden = timedActs.length === 0;
      globalFill.style.width = `${pct}%`;
      globalLabel.textContent = `${done} de ${total} concluídas`;
      globalPct.textContent = `${pct}%`;
      globalMarkers.innerHTML = '';
      nowLine.hidden = true;
    }

    // Drag hint
    document.getElementById('drag-hint').hidden = total < 2;

    // List
    renderList(activities, current);

    // Reports
    const hist = loadHistory();
    const todayDone = hist.filter((e) => e.date === todayKey() && e.type === 'completed');
    const weekAgo = Date.now() - 7 * 24 * 60 * 60 * 1000;
    const weekDone = hist.filter((e) => e.type === 'completed' && new Date(e.date).getTime() >= weekAgo);
    const peak = todayDone.reduce((acc, e) => {
      const h = (e.completedAt||'').slice(0,2); if (h) acc[h] = (acc[h]||0) + 1; return acc;
    }, {});
    const peakHour = Object.entries(peak).sort(([,a],[,b]) => b-a)[0]?.[0];
    document.getElementById('routine-report-done').textContent = String(todayDone.length);
    document.getElementById('routine-report-rate').textContent = `${pct}%`;
    document.getElementById('routine-report-peak').textContent = peakHour ? `${peakHour}:00` : '--:--';
    document.getElementById('routine-report-week').textContent = String(weekDone.length);

    // Theme select sync
    const themeEl = document.getElementById('routine-theme');
    if (themeEl) themeEl.value = loadSettings().theme || 'auto';
  }

  // ─── List rendering ────────────────────────────────────────────────────────
  function renderList(activities, current) {
    const list = document.getElementById('routine-list');
    if (!list) return;

    if (!activities.length) {
      list.innerHTML = `
        <li class="routine-empty">
          <strong>Plano vazio.</strong>
          <span>Adicione a primeira atividade no formulário ao lado.</span>
        </li>`;
      return;
    }

    // Preserve drag state
    const draggingId = list.querySelector('[draggable][aria-grabbed="true"]')?.dataset.id;
    list.innerHTML = '';

    activities.forEach((item, idx) => {
      const isCurrent = item.id === current?.id && !item.completed;
      const li = document.createElement('li');
      li.className = `routine-item${item.completed ? ' done' : ''}${isCurrent ? ' current' : ''}`;
      li.dataset.id = item.id;
      li.draggable = !item.completed;
      li.setAttribute('aria-grabbed', 'false');
      li.style.setProperty('--rc', item.color || '#5b8def');

      // Time-based progress for each item with start+end
      let itemBarHtml = '';
      if (item.timeStart && item.timeEnd && !item.completed) {
        const start = targetMs(item), end = endMs(item), now = nowMs();
        const pct2 = Math.max(0, Math.min(100, ((now - start) / (end - start)) * 100));
        itemBarHtml = `<div class="item-time-bar"><div class="item-time-bar-fill" style="width:${pct2}%"></div></div>`;
      }

      const timeLabel = item.timeStart
        ? `${item.timeStart}${item.timeEnd ? ' – '+item.timeEnd : ''}`
        : 'Sem horário';
      const statusLabel = item.completed ? '✅ Concluída' : isCurrent ? '🔵 Agora' : '⏳ Próxima';

      li.innerHTML = `
        <div class="ri-drag" aria-label="Arrastar para reordenar" title="Arrastar">⠿</div>
        <div class="ri-icon" aria-hidden="true">${escHtml(item.icon||'📍')}</div>
        <div class="ri-info">
          <div class="ri-name">${escHtml(item.name)}</div>
          <div class="ri-sub">${escHtml(timeLabel)} · ${statusLabel}</div>
          ${item.notes ? `<div class="ri-notes">${escHtml(item.notes)}</div>` : ''}
          ${itemBarHtml}
        </div>
        <div class="ri-actions">
          <button class="ri-btn ri-complete" data-id="${item.id}" title="Marcar como concluída" aria-label="Concluir ${escHtml(item.name)}">✓</button>
          <button class="ri-btn ri-edit" data-id="${item.id}" title="Editar" aria-label="Editar ${escHtml(item.name)}">✎</button>
          <button class="ri-btn ri-remove" data-id="${item.id}" title="Remover" aria-label="Remover ${escHtml(item.name)}">×</button>
        </div>`;
      list.appendChild(li);
    });

    // Wire buttons
    list.querySelectorAll('.ri-complete').forEach((btn) => btn.addEventListener('click', () => completeActivity(btn.dataset.id)));
    list.querySelectorAll('.ri-remove').forEach((btn) => btn.addEventListener('click', () => removeActivity(btn.dataset.id)));
    list.querySelectorAll('.ri-edit').forEach((btn) => btn.addEventListener('click', () => startEdit(btn.dataset.id)));

    // Drag-and-drop
    setupDnd(list);
  }

  // ─── Drag-and-drop ────────────────────────────────────────────────────────
  let dragSrc = null;

  function setupDnd(list) {
    list.querySelectorAll('li[draggable]').forEach((li) => {
      li.addEventListener('dragstart', (e) => {
        dragSrc = li;
        li.setAttribute('aria-grabbed', 'true');
        li.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', li.dataset.id);
      });
      li.addEventListener('dragend', () => {
        li.setAttribute('aria-grabbed', 'false');
        li.classList.remove('dragging');
        list.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over'));
        dragSrc = null;
      });
      li.addEventListener('dragover', (e) => {
        if (!dragSrc || dragSrc === li) return;
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        list.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over'));
        li.classList.add('drag-over');
      });
      li.addEventListener('drop', (e) => {
        if (!dragSrc || dragSrc === li) return;
        e.preventDefault();
        const acts = loadRoutine();
        const srcIdx = acts.findIndex((a) => a.id === dragSrc.dataset.id);
        const dstIdx = acts.findIndex((a) => a.id === li.dataset.id);
        if (srcIdx === -1 || dstIdx === -1) return;
        const [moved] = acts.splice(srcIdx, 1);
        acts.splice(dstIdx, 0, moved);
        // Reassign order
        acts.forEach((a, i) => { a.order = i; });
        saveRoutine(acts);
        render();
      });
    });

    // Touch drag (mobile)
    let touchItem = null, touchClone = null, startY = 0;
    list.querySelectorAll('li[draggable]').forEach((li) => {
      li.addEventListener('touchstart', (e) => {
        touchItem = li;
        startY = e.touches[0].clientY;
        touchClone = li.cloneNode(true);
        touchClone.style.cssText = `position:fixed;left:${li.getBoundingClientRect().left}px;top:${li.getBoundingClientRect().top}px;width:${li.offsetWidth}px;opacity:0.88;z-index:200;pointer-events:none;transition:none;box-shadow:0 12px 36px rgba(0,0,0,0.22)`;
        document.body.appendChild(touchClone);
        li.classList.add('dragging');
      }, { passive: true });
      li.addEventListener('touchmove', (e) => {
        if (!touchItem || !touchClone) return;
        const dy = e.touches[0].clientY - startY;
        touchClone.style.top = `${touchItem.getBoundingClientRect().top + dy}px`;
        // Find target under touch
        const target = document.elementFromPoint(e.touches[0].clientX, e.touches[0].clientY)?.closest('li.routine-item');
        list.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over'));
        if (target && target !== touchItem) target.classList.add('drag-over');
      }, { passive: true });
      li.addEventListener('touchend', (e) => {
        if (!touchItem) return;
        const target = document.elementFromPoint(e.changedTouches[0].clientX, e.changedTouches[0].clientY)?.closest('li.routine-item');
        if (target && target !== touchItem) {
          const acts = loadRoutine();
          const srcIdx = acts.findIndex((a) => a.id === touchItem.dataset.id);
          const dstIdx = acts.findIndex((a) => a.id === target.dataset.id);
          if (srcIdx !== -1 && dstIdx !== -1) {
            const [moved] = acts.splice(srcIdx, 1);
            acts.splice(dstIdx, 0, moved);
            acts.forEach((a, i) => { a.order = i; });
            saveRoutine(acts);
          }
        }
        touchClone?.remove(); touchClone = null;
        touchItem.classList.remove('dragging');
        list.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over'));
        touchItem = null;
        render();
      }, { passive: true });
    });
  }

  // ─── Edit ─────────────────────────────────────────────────────────────────
  function startEdit(id) {
    const acts = loadRoutine();
    const item = acts.find((a) => a.id === id);
    if (!item) return;
    document.getElementById('edit-id').value = item.id;
    document.getElementById('rf-name').value = item.name;
    document.getElementById('rf-icon').value = item.icon || '';
    document.getElementById('rf-color').value = item.color || '#5b8def';
    document.getElementById('rf-time-start').value = item.timeStart || '';
    document.getElementById('rf-time-end').value = item.timeEnd || '';
    document.getElementById('rf-notes').value = item.notes || '';
    document.getElementById('rf-alarm').value = String(item.alarm ?? false);
    document.getElementById('rf-alarm-row').hidden = !item.timeStart;
    document.getElementById('form-panel-title').textContent = `Editar: ${item.name}`;
    document.getElementById('form-submit-btn').textContent = 'Salvar alterações';
    document.getElementById('form-cancel-btn').hidden = false;
    document.getElementById('rf-name').focus();
    // Scroll form into view on mobile
    document.getElementById('routine-form-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function cancelEdit() {
    document.getElementById('edit-id').value = '';
    document.getElementById('routine-form').reset();
    document.getElementById('rf-color').value = '#5b8def';
    document.getElementById('rf-alarm-row').hidden = true;
    document.getElementById('form-panel-title').textContent = 'Nova atividade';
    document.getElementById('form-submit-btn').textContent = 'Adicionar';
    document.getElementById('form-cancel-btn').hidden = true;
  }

  // ─── Form wiring ──────────────────────────────────────────────────────────
  const nameInput = document.getElementById('rf-name');
  const iconInput = document.getElementById('rf-icon');
  const timeStartInput = document.getElementById('rf-time-start');
  const alarmRow = document.getElementById('rf-alarm-row');

  // Pre-fill start time with current time for new activities
  function setCurrentTime() {
    if (!timeStartInput.value) {
      const now = new Date();
      timeStartInput.value = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
      alarmRow.hidden = false;
    }
  }
  setCurrentTime();

  nameInput?.addEventListener('input', () => {
    const g = guessIcon(nameInput.value);
    if (g) iconInput.placeholder = g;
  });

  timeStartInput?.addEventListener('input', () => {
    alarmRow.hidden = !timeStartInput.value;
  });

  document.getElementById('routine-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const editId = document.getElementById('edit-id').value;
    const acts = loadRoutine();
    const data = {
      name: document.getElementById('rf-name').value.trim(),
      icon: document.getElementById('rf-icon').value.trim() || guessIcon(document.getElementById('rf-name').value) || '📍',
      color: document.getElementById('rf-color').value,
      timeStart: document.getElementById('rf-time-start').value || '',
      timeEnd: document.getElementById('rf-time-end').value || '',
      notes: document.getElementById('rf-notes').value.trim(),
      alarm: document.getElementById('rf-time-start').value ? document.getElementById('rf-alarm').value === 'true' : false,
      countdown: 5,
      completed: false,
      completedAt: null,
      alarmFired: false,
      countdownFired: false,
    };

    if (editId) {
      const idx = acts.findIndex((a) => a.id === editId);
      if (idx !== -1) {
        // Preserve completion state on edit
        data.completed = acts[idx].completed;
        data.completedAt = acts[idx].completedAt;
        data.alarmFired = acts[idx].alarmFired;
        data.countdownFired = acts[idx].countdownFired;
        data.order = acts[idx].order;
        acts[idx] = { ...acts[idx], ...data };
      }
    } else {
      data.id = `r-${Date.now()}`;
      data.order = acts.length;
      acts.push(data);
    }

    saveRoutine(acts);
    cancelEdit();
    setCurrentTime();
    render();
  });

  document.getElementById('form-cancel-btn')?.addEventListener('click', () => { cancelEdit(); setCurrentTime(); });

  document.getElementById('routine-theme')?.addEventListener('change', (e) => {
    saveSettings({ ...loadSettings(), theme: e.target.value });
  });

  document.getElementById('btn-clear-done')?.addEventListener('click', () => {
    saveRoutine(loadRoutine().filter((a) => !a.completed));
    render();
  });

  document.getElementById('btn-reset-day')?.addEventListener('click', () => {
    if (!confirm('Reiniciar o plano do dia? As atividades serão mantidas mas marcadas como pendentes.')) return;
    const acts = loadRoutine().map((a) => ({ ...a, completed: false, completedAt: null, alarmFired: false, countdownFired: false }));
    saveRoutine(acts);
    render();
  });

  // ─── Init ─────────────────────────────────────────────────────────────────
  if ('Notification' in window && Notification.permission === 'default') {
    try { Notification.requestPermission(); } catch {}
  }
  render();
  setInterval(tick, 500);
</script>

