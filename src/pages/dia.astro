  }
  .fd-text { flex: 1; min-width: 0; }
  .fd-text strong { display: block; font-size: 1.2rem; font-family: var(--font-head); font-weight: 900; margin-bottom: 4px; }
  .fd-text span { font-size: 0.9rem; color: var(--text-soft); font-weight: 700; }
  .fd-arrow {
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; color: var(--text-muted); font-weight: 900;
    padding: 0 4px;
  }

  /* Time bar inside fd-now */
  .fd-time-bar-wrap { display: flex; flex-direction: column; gap: 6px; }
  .fd-time-bar-track {
    height: 10px; border-radius: 999px;
    background: var(--bg-alt); overflow: hidden;
  }
  .fd-time-bar-fill {
    height: 100%; border-radius: 999px;
    background: linear-gradient(90deg, var(--act-color, var(--mint)), color-mix(in srgb, var(--act-color, var(--blue)) 80%, white));
    transition: width 0.5s ease;
  }
  .fd-time-bar-label { font-size: 0.8rem; font-weight: 800; color: var(--text-soft); }

  /* ── Global timeline bar ─────────────────────────────────────────────────── */
  .global-progress-wrap {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 18px; padding: 16px 20px; margin-bottom: 20px;
    box-shadow: var(--shadow-sm);
  }
