---
import Base from "../layouts/Base.astro";
---

<Base
  title="Tarefas do Dia — NeuroVoz"
  description="Organize as tarefas do dia com clareza, leveza e acolhimento."
>
  <section class="td-page" id="td-page">
    <div class="td-shell">

      {/* ─── Cabeçalho ───────────────────────────────────────── */}
      <header class="td-header reveal">
        <div class="td-header-top">
          <p class="td-date" id="td-date">—</p>
        </div>
        <h1 class="td-title">Tarefas do Dia</h1>
        <p class="td-sub">Uma lista simples, no seu ritmo.</p>

        <div class="td-overview">
          <div class="td-stats" id="td-stats" role="status" aria-live="polite">
            <span class="td-stat">
              <b id="td-stat-pending">0</b>
              <small>pendentes</small>
            </span>
            <span class="td-stat td-stat--done">
              <b id="td-stat-done">0</b>
              <small>concluídas</small>
            </span>
            <span class="td-stat">
              <b id="td-stat-total">0</b>
              <small>no total</small>
            </span>
          </div>

          <div class="td-progress-wrap" aria-hidden="true">
            <div class="td-progress">
              <span id="td-progress-bar" style="width:0%"></span>
            </div>
          </div>
        </div>
      </header>

      {/* ─── Composer (nova tarefa) ─────────────────────────── */}
      <form class="td-composer reveal" id="td-composer" autocomplete="off">
        <div class="td-row td-row-main">
          <div class="td-input-shell">
            <span class="td-input-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="20" height="20">
                <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </span>
            <input
              class="td-input td-input-title"
              id="td-input-title"
              type="text"
              placeholder="O que precisa ser feito?"
              maxlength="120"
              required
              aria-label="Título da tarefa"
            />
          </div>
          <button class="td-btn td-btn-primary" type="submit" aria-label="Adicionar tarefa">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
            <span>Adicionar</span>
          </button>
        </div>

        <details class="td-advanced">
          <summary>Adicionar descrição ou horários (opcional)</summary>
          <div class="td-row td-row-extra">
            <input
              class="td-input"
              id="td-input-desc"
              type="text"
              placeholder="Descrição (opcional)"
              maxlength="240"
              aria-label="Descrição"
            />
            <label class="td-time">
              <span>Início</span>
              <input class="td-input" id="td-input-start" type="time" aria-label="Horário de início"/>
            </label>
            <label class="td-time">
              <span>Término</span>
              <input class="td-input" id="td-input-end" type="time" aria-label="Horário de término"/>
            </label>
          </div>
        </details>
      </form>

      {/* ─── Toolbar (busca + filtros) ──────────────────────── */}
      <div class="td-toolbar reveal">
        <div class="td-search">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
            <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2"/>
            <path d="m20 20-3.5-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <input
            class="td-input td-input-search"
            id="td-search"
            type="search"
            placeholder="Buscar tarefas…"
            aria-label="Buscar tarefas"
          />
        </div>
        <div class="td-filters" role="tablist" aria-label="Filtrar tarefas">
          <button class="td-filter is-active" data-filter="all"     type="button" role="tab" aria-selected="true">Todas</button>
          <button class="td-filter"           data-filter="pending" type="button" role="tab" aria-selected="false">Pendentes</button>
          <button class="td-filter"           data-filter="done"    type="button" role="tab" aria-selected="false">Concluídas</button>
        </div>
      </div>

      {/* ─── Lista ──────────────────────────────────────────── */}
      <ul class="td-list" id="td-list" aria-label="Lista de tarefas"></ul>

      {/* ─── Estado vazio ───────────────────────────────────── */}
      <div class="td-empty" id="td-empty" hidden>
        <div class="td-empty-emoji" aria-hidden="true">🌱</div>
        <h2>Tudo tranquilo por aqui</h2>
        <p>Quando quiser, adicione sua primeira tarefa do dia acima.</p>
      </div>
    </div>
  </section>

  {/* ─── Modal de edição ─────────────────────────────────── */}
  <div class="td-modal" id="td-modal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="td-modal-title">
    <div class="td-modal-backdrop" data-td-close></div>
    <form class="td-modal-sheet" id="td-edit-form" role="document">
      <header class="td-modal-head">
        <h2 id="td-modal-title">Editar tarefa</h2>
        <button type="button" class="td-modal-close" data-td-close aria-label="Fechar">✕</button>
      </header>
      <div class="td-modal-body">
        <label class="td-field">
          <span>Título</span>
          <input class="td-input" id="td-edit-title" type="text" maxlength="120" required/>
        </label>
        <label class="td-field">
          <span>Descrição</span>
          <textarea class="td-input td-textarea" id="td-edit-desc" rows="3" maxlength="240"></textarea>
        </label>
        <div class="td-row td-row-extra">
          <label class="td-time">
            <span>Início</span>
            <input class="td-input" id="td-edit-start" type="time"/>
          </label>
          <label class="td-time">
            <span>Término</span>
            <input class="td-input" id="td-edit-end" type="time"/>
          </label>
        </div>
      </div>
      <footer class="td-modal-foot">
        <button type="button" class="td-btn td-btn-ghost td-btn-danger" id="td-edit-delete">Excluir</button>
        <div class="td-modal-foot-right">
          <button type="button" class="td-btn td-btn-ghost" data-td-close>Cancelar</button>
          <button type="submit" class="td-btn td-btn-primary">Salvar</button>
        </div>
      </footer>
    </form>
  </div>
</Base>

<style is:global>
  :root {
    --td-bg: #f4f6fb;
    --td-surface: rgba(255, 255, 255, 0.72);
    --td-surface-strong: #ffffff;
    --td-border: rgba(15, 23, 42, 0.08);
    --td-border-strong: rgba(15, 23, 42, 0.12);
    --td-text: #0f172a;
    --td-muted: #64748b;
    --td-faint: #94a3b8;
    --td-primary: #5b8def;
    --td-primary-strong: #3b6fe0;
    --td-primary-soft: rgba(91, 141, 239, 0.12);
    --td-success: #16a34a;
    --td-success-soft: rgba(22, 163, 74, 0.12);
    --td-warning: #d97706;
    --td-warning-soft: rgba(217, 119, 6, 0.12);
    --td-danger: #dc2626;
    --td-radius: 18px;
    --td-radius-sm: 12px;
    --td-radius-card: 16px;
    --td-shadow-xs: 0 1px 2px rgba(15, 23, 42, 0.04);
    --td-shadow-sm: 0 1px 3px rgba(15, 23, 42, 0.06), 0 1px 2px rgba(15, 23, 42, 0.04);
    --td-shadow: 0 4px 16px rgba(15, 23, 42, 0.06);
    --td-shadow-md: 0 8px 28px rgba(15, 23, 42, 0.10);
    --td-shadow-lg: 0 20px 60px rgba(15, 23, 42, 0.14);
    --td-blur: saturate(160%) blur(12px);
    --td-ease: cubic-bezier(.22, .68, 0, 1);
  }

  .td-page {
    min-height: calc(100vh - 64px);
    background:
      radial-gradient(1100px 560px at 8% -12%, rgba(91,141,239,0.12), transparent 55%),
      radial-gradient(900px 500px at 112% 4%, rgba(120, 200, 255, 0.10), transparent 55%),
      var(--td-bg);
    padding: clamp(20px, 4vw, 48px) clamp(14px, 4vw, 32px) 140px;
    color: var(--td-text);
    -webkit-font-smoothing: antialiased;
  }
  .td-shell { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: 22px; }

  /* ── Reveal-on-scroll (usa o IntersectionObserver da Base) ── */
  .reveal { opacity: 0; transform: translateY(14px); transition: opacity .55s var(--td-ease), transform .55s var(--td-ease); }
  .reveal.is-visible { opacity: 1; transform: none; }

  /* ─────────── Header ─────────── */
  .td-header { text-align: center; padding: 4px 4px 0; }
  .td-header-top { display: flex; justify-content: center; }
  .td-date {
    margin: 0; color: var(--td-primary-strong); font-size: 0.82rem; font-weight: 600;
    text-transform: capitalize; letter-spacing: 0.01em;
    background: var(--td-primary-soft); padding: 5px 14px; border-radius: 999px;
    display: inline-block;
  }
  .td-title { margin: 14px 0 4px; font-size: clamp(1.7rem, 3.4vw, 2.35rem); font-weight: 800; letter-spacing: -0.025em; }
  .td-sub { margin: 0 0 22px; color: var(--td-muted); font-size: 1.02rem; }

  .td-overview {
    background: var(--td-surface); backdrop-filter: var(--td-blur); -webkit-backdrop-filter: var(--td-blur);
    border: 1px solid var(--td-border); border-radius: var(--td-radius);
    box-shadow: var(--td-shadow); padding: 16px 18px;
    display: flex; flex-direction: column; gap: 14px;
  }
  .td-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .td-stat {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    padding: 10px 8px; border-radius: var(--td-radius-sm);
    background: var(--td-surface-strong); border: 1px solid var(--td-border);
    box-shadow: var(--td-shadow-xs);
  }
  .td-stat b { font-size: 1.45rem; font-weight: 800; line-height: 1; letter-spacing: -0.02em; }
  .td-stat small { color: var(--td-muted); font-size: 0.76rem; font-weight: 500; }
  .td-stat--done b { color: var(--td-success); }

  .td-progress-wrap { padding: 0 2px; }
  .td-progress {
    height: 8px; border-radius: 999px; background: rgba(15, 23, 42, 0.07);
    overflow: hidden;
  }
  .td-progress > span {
    display: block; height: 100%; width: 0%;
    background: linear-gradient(90deg, var(--td-primary), #7aa6ff);
    border-radius: 999px;
    transition: width .6s var(--td-ease);
  }

  /* ─────────── Composer ─────────── */
  .td-composer {
    background: var(--td-surface-strong);
    border: 1px solid var(--td-border); border-radius: var(--td-radius);
    box-shadow: var(--td-shadow); padding: 16px;
    transition: box-shadow .25s var(--td-ease), border-color .25s var(--td-ease);
  }
  .td-composer:focus-within { box-shadow: var(--td-shadow-md); border-color: var(--td-border-strong); }

  .td-row { display: flex; gap: 10px; flex-wrap: wrap; }
  .td-row-main { align-items: stretch; }
  .td-input-shell {
    position: relative; flex: 1 1 280px; display: flex; align-items: center;
  }
  .td-input-icon {
    position: absolute; left: 14px; color: var(--td-faint); pointer-events: none;
    display: grid; place-items: center;
  }
  .td-input-shell .td-input-title { padding-left: 42px; }

  .td-input {
    width: 100%; min-height: 46px; padding: 11px 14px;
    background: var(--td-surface-strong);
    border: 1px solid var(--td-border-strong); border-radius: var(--td-radius-sm);
    font: inherit; color: inherit; transition: border-color .18s, box-shadow .18s, background .18s;
  }
  .td-input::placeholder { color: var(--td-faint); }
  .td-input:focus { outline: none; border-color: var(--td-primary); box-shadow: 0 0 0 4px var(--td-primary-soft); }
  .td-textarea { min-height: 90px; resize: vertical; line-height: 1.5; }

  .td-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    min-height: 46px; padding: 10px 18px; border-radius: var(--td-radius-sm);
    border: 1px solid transparent; font: inherit; font-weight: 600; cursor: pointer;
    transition: transform .14s var(--td-ease), background .18s, color .18s, border-color .18s, box-shadow .18s;
  }
  .td-btn:active { transform: translateY(1px) scale(.99); }
  .td-btn-primary { background: var(--td-primary); color: #fff; box-shadow: 0 6px 16px rgba(91,141,239,0.32); }
  .td-btn-primary:hover { background: var(--td-primary-strong); box-shadow: 0 8px 22px rgba(91,141,239,0.42); }
  .td-btn-ghost { background: transparent; color: var(--td-text); border-color: var(--td-border-strong); }
  .td-btn-ghost:hover { background: rgba(15,23,42,0.05); }
  .td-btn-danger { color: var(--td-danger); border-color: rgba(220,38,38,0.25); }
  .td-btn-danger:hover { background: rgba(220,38,38,0.08); }

  .td-advanced { margin-top: 12px; border-top: 1px solid var(--td-border); padding-top: 4px; }
  .td-advanced > summary {
    cursor: pointer; color: var(--td-muted); font-size: 0.9rem; font-weight: 500; padding: 8px 4px 4px;
    border-radius: 8px; list-style: none; transition: color .15s;
  }
  .td-advanced > summary:hover { color: var(--td-text); }
  .td-advanced > summary::-webkit-details-marker { display: none; }
  .td-advanced > summary::before { content: "＋ "; color: var(--td-primary); font-weight: 700; }
  .td-advanced[open] > summary::before { content: "− "; }
  .td-advanced[open] .td-row-extra { animation: td-in .3s var(--td-ease) both; }

  .td-time { display: flex; flex-direction: column; gap: 4px; flex: 1 1 140px; }
  .td-time > span { font-size: 0.76rem; color: var(--td-muted); padding-left: 4px; font-weight: 500; }

  /* ─────────── Toolbar ─────────── */
  .td-toolbar {
    display: flex; gap: 12px; flex-wrap: wrap; align-items: center; justify-content: space-between;
  }
  .td-search { position: relative; flex: 1 1 240px; }
  .td-search > svg {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--td-faint);
  }
  .td-input-search {
    padding-left: 40px; background: var(--td-surface); backdrop-filter: var(--td-blur);
    -webkit-backdrop-filter: var(--td-blur); box-shadow: var(--td-shadow-xs);
  }

  .td-filters {
    display: inline-flex; padding: 4px; gap: 2px;
    background: var(--td-surface); backdrop-filter: var(--td-blur); -webkit-backdrop-filter: var(--td-blur);
    border: 1px solid var(--td-border); border-radius: 999px; box-shadow: var(--td-shadow-xs);
  }
  .td-filter {
    border: none; background: transparent; cursor: pointer; font: inherit; font-weight: 600; font-size: 0.88rem;
    color: var(--td-muted); padding: 8px 15px; border-radius: 999px;
    transition: background .2s var(--td-ease), color .2s var(--td-ease);
  }
  .td-filter:hover { color: var(--td-text); }
  .td-filter.is-active { background: var(--td-primary); color: #fff; box-shadow: 0 4px 12px rgba(91,141,239,0.32); }

  /* ─────────── Lista ─────────── */
  .td-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }

  .td-card {
    --accent: var(--td-primary);
    position: relative;
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    gap: 14px; align-items: center;
    padding: 16px 18px;
    background: var(--td-surface-strong);
    border: 1px solid var(--td-border);
    border-radius: var(--td-radius-card);
    box-shadow: var(--td-shadow-sm);
    animation: td-in .32s var(--td-ease) both;
    transition: transform .22s var(--td-ease), box-shadow .22s var(--td-ease), border-color .22s var(--td-ease), opacity .22s var(--td-ease);
  }
  /* faixa de acento à esquerda */
  .td-card::before {
    content: ""; position: absolute; left: 0; top: 12px; bottom: 12px; width: 4px;
    border-radius: 0 4px 4px 0; background: var(--accent); opacity: .85;
    transition: opacity .2s, top .2s, bottom .2s;
  }
  .td-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--td-shadow-md);
    border-color: color-mix(in oklab, var(--accent) 22%, var(--td-border));
  }
  .td-card:hover::before { top: 8px; bottom: 8px; opacity: 1; }

  .td-card.is-done { opacity: 0.72; background: #fbfcfe; }
  .td-card.is-done::before { opacity: .35; }
  .td-card.is-done .td-card-title-text { text-decoration: line-through; color: var(--td-muted); }

  .td-card.is-current {
    border-color: color-mix(in oklab, var(--accent) 35%, var(--td-border));
    box-shadow: var(--td-shadow-md), 0 0 0 1px color-mix(in oklab, var(--accent) 22%, transparent);
    background: linear-gradient(180deg, color-mix(in oklab, var(--accent) 5%, #ffffff), #ffffff);
  }

  /* Drag handle */
  .td-drag {
    width: 24px; height: 38px;
    display: grid; place-items: center;
    border: none; background: transparent; color: var(--td-faint);
    cursor: grab; border-radius: 8px; padding: 0;
    opacity: .45; transform: none;
    transition: opacity .2s var(--td-ease), background .15s, color .15s;
    touch-action: none;
  }
  .td-drag svg { display: block; width: 18px !important; height: 18px !important; flex: none; }
  .td-card:hover .td-drag, .td-drag:focus-visible { opacity: 1; }
  .td-drag:hover { background: rgba(15,23,42,0.06); color: var(--td-text); }
  .td-drag:active { cursor: grabbing; }
  .td-card.td-dragging {
    opacity: 0.6; transform: scale(.99) rotate(-.4deg);
    box-shadow: var(--td-shadow-lg);
    border-color: var(--accent);
  }

  /* Emoji tile */
  .td-emoji-tile {
    width: 46px; height: 46px; border-radius: 13px;
    display: grid; place-items: center;
    background: color-mix(in oklab, var(--accent) 14%, #f1f3f8);
    color: var(--td-text);
    font-size: 1.4rem; line-height: 1;
    flex-shrink: 0;
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--accent) 38%, transparent);
    transition: transform .22s var(--td-ease);
  }
  .td-card:hover .td-emoji-tile { transform: scale(1.06) rotate(-2deg); }

  .td-card-main { min-width: 0; display: flex; flex-direction: column; gap: 4px; }
  .td-card-title { margin: 0; font-weight: 700; font-size: 1.04rem; word-break: break-word; line-height: 1.3; }
  .td-card-title-text { min-width: 0; }
  .td-card-desc { margin: 0; color: var(--td-muted); font-size: 0.9rem; word-break: break-word; line-height: 1.4; }

  .td-card-meta { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; font-size: 0.76rem; }
  .td-meta-chip {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 999px; font-weight: 500;
    background: rgba(15,23,42,0.04); color: var(--td-muted);
    border: 1px solid var(--td-border);
  }
  .td-meta-chip.is-now      { background: var(--td-primary-soft); color: var(--td-primary-strong); border-color: transparent; }
  .td-meta-chip.is-upcoming { background: rgba(120,120,140,0.08); }
  .td-meta-chip.is-overtime { background: var(--td-warning-soft); color: var(--td-warning); border-color: transparent; }

  .td-card-bar {
    grid-column: 1 / -1;
    height: 5px; border-radius: 999px; background: rgba(15,23,42,0.06); overflow: hidden;
    margin-top: 2px;
  }
  .td-card-bar > span {
    display: block; height: 100%; width: 0%;
    background: linear-gradient(90deg, var(--accent), color-mix(in oklab, var(--accent) 50%, #ffffff));
    border-radius: 999px;
    transition: width 1s linear;
  }

  /* Ações: concluir + editar + excluir */
  .td-card-actions { display: flex; gap: 6px; align-items: center; }
  .td-icon-btn {
    width: 38px; height: 38px; display: grid; place-items: center;
    border-radius: 11px; border: 1px solid var(--td-border); background: var(--td-surface-strong);
    cursor: pointer; color: var(--td-text);
    transition: background .16s, color .16s, border-color .16s, transform .14s var(--td-ease), box-shadow .16s;
  }
  .td-icon-btn svg { display: block; width: 20px !important; height: 20px !important; flex: none; }
  .td-icon-btn:hover { background: rgba(15,23,42,0.04); color: var(--td-text); transform: translateY(-1px); box-shadow: var(--td-shadow-xs); }
  .td-icon-btn:active { transform: scale(.94); }
  .td-icon-btn.is-success { color: color-mix(in oklab, var(--accent) 70%, #1f9d55); border-color: color-mix(in oklab, var(--accent) 28%, var(--td-border)); }
  .td-icon-btn.is-success:hover { background: color-mix(in oklab, var(--accent) 12%, #ffffff); color: var(--accent); }
  .td-icon-btn.is-success.is-on {
    background: linear-gradient(135deg, var(--accent), color-mix(in oklab, var(--accent) 60%, #ffffff));
    color: #fff; border-color: transparent;
    box-shadow: 0 6px 14px color-mix(in oklab, var(--accent) 35%, transparent);
  }
  .td-icon-btn.is-danger:hover { background: rgba(220,38,38,0.08); color: var(--td-danger); border-color: color-mix(in oklab, var(--td-danger) 32%, var(--td-border)); }

  .td-card.td-leaving { animation: td-out .25s var(--td-ease) both; }

  @keyframes td-in  { from { opacity: 0; transform: translateY(8px) scale(.99); } to { opacity: 1; transform: none; } }
  @keyframes td-out { to   { opacity: 0; transform: translateY(-6px) scale(.97); } }
  @keyframes td-pop { 0% { transform: scale(1); } 45% { transform: scale(1.025); } 100% { transform: scale(1); } }
  .td-card.td-pop { animation: td-pop .38s var(--td-ease); }

  /* ─────────── Estado vazio ─────────── */
  .td-empty {
    text-align: center; padding: 48px 20px; color: var(--td-muted);
    background: var(--td-surface); backdrop-filter: var(--td-blur); -webkit-backdrop-filter: var(--td-blur);
    border: 1px dashed var(--td-border-strong); border-radius: var(--td-radius);
    animation: td-in .35s var(--td-ease) both;
  }
  .td-empty-emoji { font-size: 2.6rem; margin-bottom: 8px; }
  .td-empty h2 { margin: 6px 0 4px; color: var(--td-text); font-size: 1.18rem; font-weight: 700; }
  .td-empty p { margin: 0; font-size: 0.95rem; }

  /* ─────────── Modal ─────────── */
  .td-modal { position: fixed; inset: 0; z-index: 80; display: grid; place-items: center; padding: 16px; }
  .td-modal[hidden] { display: none; }
  .td-modal-backdrop {
    position: absolute; inset: 0; background: rgba(15,23,42,0.45);
    backdrop-filter: blur(4px); animation: td-fade .2s ease;
  }
  .td-modal-sheet {
    position: relative; width: 100%; max-width: 520px;
    background: var(--td-surface-strong); border-radius: 22px;
    box-shadow: var(--td-shadow-lg); border: 1px solid var(--td-border);
    overflow: hidden; animation: td-rise .28s var(--td-ease);
  }
  .td-modal-head, .td-modal-foot { padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .td-modal-head { border-bottom: 1px solid var(--td-border); }
  .td-modal-head h2 { margin: 0; font-size: 1.18rem; font-weight: 800; letter-spacing: -0.01em; }
  .td-modal-foot { border-top: 1px solid var(--td-border); background: rgba(15,23,42,0.02); }
  .td-modal-foot-right { display: flex; gap: 8px; }
  .td-modal-close { border: none; background: transparent; font-size: 1.1rem; cursor: pointer; padding: 6px 10px; border-radius: 8px; color: var(--td-muted); transition: background .15s, color .15s; }
  .td-modal-close:hover { background: rgba(15,23,42,0.06); color: var(--td-text); }
  .td-modal-body { padding: 18px 20px; display: flex; flex-direction: column; gap: 14px; }
  .td-field { display: flex; flex-direction: column; gap: 6px; }
  .td-field > span { font-size: 0.8rem; color: var(--td-muted); padding-left: 4px; font-weight: 500; }

  @keyframes td-fade { from { opacity: 0 } to { opacity: 1 } }
  @keyframes td-rise { from { opacity: 0; transform: translateY(12px) scale(.98); } to { opacity: 1; transform: none; } }

  /* ─────────── Responsivo ─────────── */
  @media (max-width: 560px) {
    .td-row-main { flex-direction: column; }
    .td-btn-primary { width: 100%; }
    .td-toolbar { flex-direction: column; align-items: stretch; }
    .td-filters { justify-content: center; }

    .td-card {
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "emoji main"
        "actions actions";
      gap: 12px 14px; padding: 14px 16px;
    }
    .td-drag { display: none; }
    .td-emoji-tile { grid-area: emoji; }
    .td-card-main { grid-area: main; }
    .td-card-actions { grid-area: actions; justify-content: flex-end; border-top: 1px solid var(--td-border); padding-top: 10px; margin-top: 2px; }
    .td-card-bar { grid-area: auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation: none !important; transition: none !important; }
    .reveal { opacity: 1; transform: none; }
  }

  /* ─────────── Tema escuro (se a Base aplicar .dark) ─────────── */
  :global(.dark) .td-page {
    --td-bg: #0b1020;
    --td-surface: rgba(20, 28, 48, 0.6);
    --td-surface-strong: #131a2e;
    --td-border: rgba(255,255,255,0.08);
    --td-border-strong: rgba(255,255,255,0.14);
    --td-text: #e6ecff;
    --td-muted: #94a3b8;
    --td-faint: #6b7895;
  }
  :global(.dark) .td-card.is-done { background: #10162a; }
  :global(.dark) .td-icon-btn { background: #1a2240; }
  :global(.dark) .td-modal-foot { background: rgba(255,255,255,0.02); }
</style>

{/* ──────────────────────────────────────────────────────────
   Script da página — vanilla TS. Sem dependências externas.
   Lógica preservada integralmente do arquivo original.
   ────────────────────────────────────────────────────────── */}
<script>
  // ---------- Tipos ----------
  interface Task {
    id: string;
    title: string;
    desc?: string;
    start?: string;   // "HH:MM"
    end?: string;     // "HH:MM"
    done: boolean;
    completedAt?: number;
    createdAt: number;
    order?: number;   // ordem manual (drag & drop)
  }
  type Filter = "all" | "pending" | "done";

  // ---------- Storage ----------
  const STORE_KEY = "neurovoz.tasks.v1";

  const loadTasks = (): Task[] => {
    try {
      const raw = localStorage.getItem(STORE_KEY);
      if (!raw) return [];
      const parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed : [];
    } catch { return []; }
  };
  const saveTasks = (tasks: Task[]) => {
    try { localStorage.setItem(STORE_KEY, JSON.stringify(tasks)); } catch {}
    // Notifica o widget global (se existir)
    window.dispatchEvent(new CustomEvent("nv:tasks:updated", { detail: { tasks } }));
  };

  // ---------- Histórico da Rotina (lido pelo Dashboard / PDF / CSV) ----------
  // O dashboard (historico.astro) lê de "nv-routine-history". Toda tarefa
  // concluída no Plano do Dia é registrada aqui para aparecer no histórico,
  // nos gráficos e nos relatórios exportados.
  const ROUTINE_HISTORY_KEY = "nv-routine-history";

  interface RoutineHistoryEntry {
    id: string;          // referência estável (taskId + data)
    taskId: string;
    type: "completed";
    name: string;
    icon: string;
    date: string;        // YYYY-MM-DD
    time: string;        // horário previsto (HH:MM) ou ""
    completedAt: string; // hora em que foi concluída (HH:MM)
    label: string;
  }

  const loadRoutineHistory = (): RoutineHistoryEntry[] => {
    try {
      const raw = localStorage.getItem(ROUTINE_HISTORY_KEY);
      const parsed = raw ? JSON.parse(raw) : [];
      return Array.isArray(parsed) ? parsed : [];
    } catch { return []; }
  };

  const saveRoutineHistory = (entries: RoutineHistoryEntry[]) => {
    try { localStorage.setItem(ROUTINE_HISTORY_KEY, JSON.stringify(entries)); } catch {}
    window.dispatchEvent(new CustomEvent("nv:routine-history:updated", { detail: { entries } }));
  };

  const dayKey = (ts = Date.now()) => {
    const d = new Date(ts);
    const off = d.getTimezoneOffset() * 60000;
    return new Date(ts - off).toISOString().slice(0, 10);
  };
  const hhmm = (ts = Date.now()) =>
    new Date(ts).toLocaleTimeString("pt-BR", { hour: "2-digit", minute: "2-digit" });

  const routineEntryId = (taskId: string, date: string) => `${taskId}@${date}`;

  const logRoutineCompletion = (t: Task) => {
    const completedTs = t.completedAt || Date.now();
    const date = dayKey(completedTs);
    const entries = loadRoutineHistory();
    const entryId = routineEntryId(t.id, date);
    const icon = pickEmoji(t.title, t.desc);
    const entry: RoutineHistoryEntry = {
      id: entryId,
      taskId: t.id,
      type: "completed",
      name: t.title,
      icon,
      date,
      time: t.start || "",
      completedAt: hhmm(completedTs),
      label: `${t.title} — concluída`,
    };
    const idx = entries.findIndex((e) => e.id === entryId);
    if (idx >= 0) entries[idx] = entry; else entries.push(entry);
    saveRoutineHistory(entries);
  };

  const unlogRoutineCompletion = (t: Task) => {
    const entries = loadRoutineHistory();
    // Remove qualquer registro desta tarefa (independente do dia) ao desmarcar.
    const next = entries.filter((e) => e.taskId !== t.id);
    if (next.length !== entries.length) saveRoutineHistory(next);
  };

  // ---------- Estado ----------
  let tasks: Task[] = loadTasks();
  let filter: Filter = "all";
  let search = "";
  let editingId: string | null = null;

  // ---------- Helpers ----------
  const uid = () => Math.random().toString(36).slice(2, 10) + Date.now().toString(36);

  const todayLabel = () => {
    const d = new Date();
    return d.toLocaleDateString("pt-BR", {
      weekday: "long", day: "2-digit", month: "long",
    });
  };

  const parseHM = (s?: string): number | null => {
    if (!s) return null;
    const [h, m] = s.split(":").map(Number);
    if (Number.isNaN(h) || Number.isNaN(m)) return null;
    const d = new Date();
    d.setHours(h, m, 0, 0);
    return d.getTime();
  };

  const formatDuration = (ms: number): string => {
    const total = Math.max(0, Math.round(ms / 60000));
    const h = Math.floor(total / 60);
    const m = total % 60;
    if (h <= 0) return `${m}min`;
    if (m === 0) return `${h}h`;
    return `${h}h ${m}min`;
  };

  // Paleta automática, determinística pelo título
  const PALETTE = ["#5b8def", "#22c55e", "#f59e0b", "#ef4444", "#8b5cf6", "#06b6d4", "#ec4899", "#14b8a6"];
  const colorFor = (t: Task) => {
    const s = (t.title || "").toLowerCase();
    let h = 0;
    for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
    return PALETTE[Math.abs(h) % PALETTE.length];
  };

  // Estado temporal acolhedor
  type TimeState =
    | { kind: "none" }
    | { kind: "upcoming"; msUntilStart: number }
    | { kind: "current"; msUntilEnd: number; progress: number }
    | { kind: "overtime" };

  const getTimeState = (t: Task, now = Date.now()): TimeState => {
    const start = parseHM(t.start);
    const end = parseHM(t.end);
    if (start == null || end == null) return { kind: "none" };
    if (now < start) return { kind: "upcoming", msUntilStart: start - now };
    if (now <= end) {
      const total = Math.max(1, end - start);
      return { kind: "current", msUntilEnd: end - now, progress: Math.min(1, (now - start) / total) };
    }
    return { kind: "overtime" };
  };

  // ---------- Render ----------
  const $ = <T extends Element>(sel: string, root: ParentNode = document) =>
    root.querySelector(sel) as T | null;

  const elDate     = $<HTMLElement>("#td-date")!;
  const elList     = $<HTMLUListElement>("#td-list")!;
  const elEmpty    = $<HTMLElement>("#td-empty")!;
  const elStatPend = $<HTMLElement>("#td-stat-pending")!;
  const elStatDone = $<HTMLElement>("#td-stat-done")!;
  const elStatTot  = $<HTMLElement>("#td-stat-total")!;
  const elProgress = $<HTMLElement>("#td-progress-bar")!;

  elDate.textContent = todayLabel();

  const renderStats = () => {
    const total = tasks.length;
    const done  = tasks.filter(t => t.done).length;
    const pend  = total - done;
    elStatTot.textContent  = String(total);
    elStatDone.textContent = String(done);
    elStatPend.textContent = String(pend);
    elProgress.style.width = total ? `${Math.round((done / total) * 100)}%` : "0%";
  };

  const escapeHTML = (s: string) =>
    s.replace(/[&<>"']/g, c => ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;" }[c]!));

  // Normaliza: minúsculas + sem acentos
  const normalize = (s: string) =>
    s.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");

  // Categorias de emoji por palavras-chave (já normalizadas: sem acento, minúsculas)
  const EMOJI_RULES: Array<{ emoji: string; keywords: string[] }> = [
    { emoji: "❤️", keywords: ["psicolog", "medic", "dentist", "terapia", "terapeut", "hospital", "exame", "consulta", "remedio", "fono", "neuro", "saude", "vacina"] },
    { emoji: "🍽️", keywords: ["comer", "lanch", "recreio", "almoc", "jantar", "cafe da manha", "cafe", "refeic", "merenda", "cozinhar", "jantinha"] },
    { emoji: "🏫", keywords: ["atividade", "escola", "aula", "professor", "professora", "prof", "profa", "licao", "tarefa de casa", "estud", "prova", "trabalho escolar", "colegio", "faculdade", "universidade"] },
    { emoji: "💼", keywords: ["reuniao", "escritorio", "trabalho", "expediente", "cliente", "projeto"] },
    { emoji: "🛒", keywords: ["comprar", "mercado", "supermercado", "farmacia", "buscar", "feira", "padaria"] },
    { emoji: "🏃", keywords: ["corrida", "correr", "academia", "treino", "exercicio", "caminhada", "caminhar", "yoga", "pilates", "natacao", "bike", "ciclismo"] },
    { emoji: "🛁", keywords: ["banho", "tomar banho", "higiene", "escovar"] },
    { emoji: "💧", keywords: ["agua", "beber agua", "hidrat"] },
    { emoji: "😴", keywords: ["dormir", "sono", "soneca", "descansar", "cochilo"] },
    { emoji: "🧘", keywords: ["meditar", "meditac", "respirar", "mindfulness"] },
    { emoji: "📞", keywords: ["ligar", "telefon", "chamada", "ligacao", "videochamada", "video call"] },
    { emoji: "💬", keywords: ["mensagem", "responder", "whats", "conversar"] },
    { emoji: "📧", keywords: ["email", "e-mail", "enviar email"] },
    { emoji: "🎉", keywords: ["festa", "aniversario", "comemora", "celebra"] },
    { emoji: "🎮", keywords: ["jogar", "game", "videogame", "brincar"] },
    { emoji: "🚗", keywords: ["dirigir", "carro", "viagem", "viajar", "onibus", "uber", "transporte", "metro"] },
    { emoji: "🐶", keywords: ["cachorro", "cao", "passear com", "gato", "pet", "animal"] },
    { emoji: "🧹", keywords: ["limpar", "limpeza", "arrumar", "organizar", "lavar", "louca", "roupa"] },
    { emoji: "📚", keywords: ["ler", "leitura", "livro"] },
    { emoji: "💊", keywords: ["remedio", "medicament", "tomar remedio"] },
    { emoji: "💰", keywords: ["pagar", "conta", "boleto", "banco", "dinheiro"] },
    { emoji: "🎵", keywords: ["musica", "tocar", "instrumento", "violao", "piano"] },
    { emoji: "✍️", keywords: ["escrever", "anotar", "diario"] },
  ];

  const pickEmoji = (title: string, desc?: string): string => {
    const text = " " + normalize(`${title} ${desc ?? ""}`) + " ";
    for (const { emoji, keywords } of EMOJI_RULES) {
      for (const k of keywords) {
        if (text.includes(k)) return emoji;
      }
    }
    return "📝";
  };

  const cardHTML = (t: Task): string => {
    const state = getTimeState(t);
    const accent = colorFor(t);

    let chips = "";
    if (t.start && t.end) chips += `<span class="td-meta-chip">🕒 ${t.start}–${t.end}</span>`;
    else if (t.start)     chips += `<span class="td-meta-chip">🕒 Começa ${t.start}</span>`;
    else if (t.end)       chips += `<span class="td-meta-chip">🕒 Termina ${t.end}</span>`;

    if (!t.done) {
      if (state.kind === "upcoming")  chips += `<span class="td-meta-chip is-upcoming">Começa em ${formatDuration(state.msUntilStart)}</span>`;
      if (state.kind === "current")   chips += `<span class="td-meta-chip is-now">Termina em ${formatDuration(state.msUntilEnd)}</span>`;
      if (state.kind === "overtime")  chips += `<span class="td-meta-chip is-overtime">Marque como concluída quando terminar</span>`;
    } else {
      chips += `<span class="td-meta-chip">✅ Concluída</span>`;
    }

    const showBar = !t.done && state.kind === "current";
    const barHTML = showBar
      ? `<div class="td-card-bar" aria-hidden="true"><span style="width:${Math.round((state as any).progress * 100)}%"></span></div>`
      : "";

    return `
      <li class="td-card ${t.done ? "is-done" : ""} ${state.kind === "current" && !t.done ? "is-current" : ""}"
          style="--accent:${accent}" data-id="${t.id}" draggable="true">
        <button class="td-drag" type="button" aria-label="Arrastar para reordenar" title="Arrastar para reordenar">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
            <circle cx="9"  cy="6"  r="1.9" fill="currentColor"/>
            <circle cx="15" cy="6"  r="1.9" fill="currentColor"/>
            <circle cx="9"  cy="12" r="1.9" fill="currentColor"/>
            <circle cx="15" cy="12" r="1.9" fill="currentColor"/>
            <circle cx="9"  cy="18" r="1.9" fill="currentColor"/>
            <circle cx="15" cy="18" r="1.9" fill="currentColor"/>
          </svg>
        </button>
        <div class="td-emoji-tile" aria-hidden="true">${pickEmoji(t.title, t.desc)}</div>
        <div class="td-card-main">
          <p class="td-card-title">
            <span class="td-card-title-text">${escapeHTML(t.title)}</span>
          </p>
          ${t.desc ? `<p class="td-card-desc">${escapeHTML(t.desc)}</p>` : ""}
          ${chips ? `<div class="td-card-meta">${chips}</div>` : ""}
        </div>
        <div class="td-card-actions">
          <button class="td-icon-btn is-success ${t.done ? "is-on" : ""}" data-act="toggle" type="button"
                  aria-label="${t.done ? "Desmarcar tarefa" : "Concluir tarefa"}" aria-pressed="${t.done ? "true" : "false"}"
                  title="${t.done ? "Desmarcar" : "Concluir"}">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M4.5 12.5l4.8 4.8L19.5 7" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="td-icon-btn" data-act="edit" type="button" aria-label="Editar tarefa" title="Editar">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M14.5 5.5l4 4M4 20l1-4.2L15.4 5.4a1.8 1.8 0 0 1 2.5 0l.7.7a1.8 1.8 0 0 1 0 2.5L8.2 19 4 20Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="td-icon-btn is-danger" data-act="delete" type="button" aria-label="Excluir tarefa" title="Excluir">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M5 7h14M10 7V5.5A1.5 1.5 0 0 1 11.5 4h1A1.5 1.5 0 0 1 14 5.5V7m3 0-.7 12.1a1.8 1.8 0 0 1-1.8 1.7H9.5a1.8 1.8 0 0 1-1.8-1.7L7 7m3.2 4v6m3.6-6v6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
        ${barHTML}
      </li>`;
  };

  const orderOf = (t: Task) => (typeof t.order === "number" ? t.order : t.createdAt);

  const filteredTasks = (): Task[] => {
    const q = search.trim().toLowerCase();
    return tasks
      .filter(t => filter === "all" ? true : filter === "done" ? t.done : !t.done)
      .filter(t => !q || t.title.toLowerCase().includes(q) || (t.desc ?? "").toLowerCase().includes(q))
      .sort((a, b) => {
        // Pendentes primeiro, depois pela ordem manual (ou createdAt como fallback)
        if (a.done !== b.done) return a.done ? 1 : -1;
        return orderOf(a) - orderOf(b);
      });
  };

  const render = () => {
    const list = filteredTasks();
    elList.innerHTML = list.map(cardHTML).join("");
    elEmpty.hidden = tasks.length !== 0;
    if (tasks.length && list.length === 0) {
      elEmpty.hidden = false;
      elEmpty.querySelector("h2")!.textContent = "Nada por aqui";
      elEmpty.querySelector("p")!.textContent  = "Tente outro filtro ou termo de busca.";
    } else if (tasks.length === 0) {
      elEmpty.querySelector("h2")!.textContent = "Tudo tranquilo por aqui";
      elEmpty.querySelector("p")!.textContent  = "Quando quiser, adicione sua primeira tarefa do dia acima.";
    }
    renderStats();
  };

  // ---------- Mutações ----------
  const nextOrder = () =>
    (tasks.length ? Math.max(...tasks.map(orderOf)) : 0) + 1;

  const addTask = (t: Omit<Task, "id" | "createdAt" | "done" | "order">) => {
    const task: Task = { id: uid(), createdAt: Date.now(), done: false, order: nextOrder(), ...t };
    tasks.push(task);
    saveTasks(tasks);
    render();
  };
  const updateTask = (id: string, patch: Partial<Task>) => {
    tasks = tasks.map(t => t.id === id ? { ...t, ...patch } : t);
    saveTasks(tasks); render();
  };
  const removeTask = (id: string) => {
    const t = tasks.find(x => x.id === id);
    if (t) unlogRoutineCompletion(t);
    const card = elList.querySelector<HTMLLIElement>(`li[data-id="${id}"]`);
    const finish = () => { tasks = tasks.filter(t => t.id !== id); saveTasks(tasks); render(); };
    if (card) { card.classList.add("td-leaving"); setTimeout(finish, 220); } else finish();
  };
  const toggleTask = (id: string) => {
    const t = tasks.find(x => x.id === id); if (!t) return;
    const done = !t.done;
    const completedAt = done ? Date.now() : undefined;
    updateTask(id, { done, completedAt });
    if (done) {
      // Registra no histórico da rotina (Dashboard / PDF / CSV)
      logRoutineCompletion({ ...t, done: true, completedAt });
      const card = elList.querySelector<HTMLLIElement>(`li[data-id="${id}"]`);
      card?.classList.add("td-pop");
      // Dispara celebração (mesmo evento usado pelo widget e pelo modal)
      window.dispatchEvent(new CustomEvent("nv:task:completed", { detail: { task: { ...t, done: true } } }));
    } else {
      unlogRoutineCompletion(t);
    }
  };

  // ---------- Eventos ----------
  // Composer
  const composer = $<HTMLFormElement>("#td-composer")!;
  composer.addEventListener("submit", (e) => {
    e.preventDefault();
    const title = $<HTMLInputElement>("#td-input-title")!.value.trim();
    if (!title) return;
    const desc  = $<HTMLInputElement>("#td-input-desc")?.value.trim() || undefined;
    const start = $<HTMLInputElement>("#td-input-start")?.value || undefined;
    const end   = $<HTMLInputElement>("#td-input-end")?.value || undefined;
    addTask({ title, desc, start, end });
    composer.reset();
    $<HTMLInputElement>("#td-input-title")!.focus();
  });

  // Lista (delegação)
  elList.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const card = target.closest<HTMLLIElement>("li.td-card");
    if (!card) return;
    const id = card.dataset.id!;
    const actBtn = target.closest<HTMLButtonElement>("[data-act]");
    if (!actBtn) return;
    const act = actBtn.dataset.act;
    if (act === "toggle") toggleTask(id);
    if (act === "delete") removeTask(id);
    if (act === "edit")   openEdit(id);
  });

  // ---------- Drag & Drop (reordenar) ----------
  let dragId: string | null = null;

  const getCardAfter = (y: number): HTMLLIElement | null => {
    const cards = [...elList.querySelectorAll<HTMLLIElement>("li.td-card:not(.td-dragging)")];
    let closest: { offset: number; el: HTMLLIElement | null } = { offset: Number.NEGATIVE_INFINITY, el: null };
    for (const c of cards) {
      const box = c.getBoundingClientRect();
      const offset = y - (box.top + box.height / 2);
      if (offset < 0 && offset > closest.offset) closest = { offset, el: c };
    }
    return closest.el;
  };

  elList.addEventListener("dragstart", (e) => {
    const card = (e.target as HTMLElement).closest<HTMLLIElement>("li.td-card");
    if (!card) return;
    dragId = card.dataset.id!;
    card.classList.add("td-dragging");
    e.dataTransfer?.setData("text/plain", dragId);
    if (e.dataTransfer) e.dataTransfer.effectAllowed = "move";
  });

  elList.addEventListener("dragover", (e) => {
    if (!dragId) return;
    e.preventDefault();
    if (e.dataTransfer) e.dataTransfer.dropEffect = "move";
    const dragging = elList.querySelector<HTMLLIElement>("li.td-dragging");
    if (!dragging) return;
    const after = getCardAfter(e.clientY);
    if (after == null) elList.appendChild(dragging);
    else elList.insertBefore(dragging, after);
  });

  const persistOrder = () => {
    const newIds = [...elList.querySelectorAll<HTMLLIElement>("li.td-card")].map(li => li.dataset.id!);
    // Atribui ordens incrementais às tarefas visíveis, preservando a ordem das demais
    let i = 1;
    const visible = new Set(newIds);
    const others = tasks.filter(t => !visible.has(t.id)).sort((a, b) => orderOf(a) - orderOf(b));
    const byId = new Map(tasks.map(t => [t.id, t]));
    const reordered: Task[] = [];
    for (const id of newIds) {
      const t = byId.get(id)!; t.order = i++; reordered.push(t);
    }
    for (const t of others) { t.order = i++; reordered.push(t); }
    tasks = reordered;
    saveTasks(tasks);
  };

  elList.addEventListener("dragend", () => {
    const dragging = elList.querySelector<HTMLLIElement>("li.td-dragging");
    dragging?.classList.remove("td-dragging");
    if (dragId) { persistOrder(); render(); }
    dragId = null;
  });

  // Busca
  const searchInput = $<HTMLInputElement>("#td-search")!;
  searchInput.addEventListener("input", () => { search = searchInput.value; render(); });

  // Filtros
  document.querySelectorAll<HTMLButtonElement>(".td-filter").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll<HTMLButtonElement>(".td-filter").forEach(b => {
        b.classList.remove("is-active"); b.setAttribute("aria-selected", "false");
      });
      btn.classList.add("is-active"); btn.setAttribute("aria-selected", "true");
      filter = (btn.dataset.filter as Filter) || "all";
      render();
    });
  });

  // Modal edit
  const modal    = $<HTMLElement>("#td-modal")!;
  const editForm = $<HTMLFormElement>("#td-edit-form")!;
  const openEdit = (id: string) => {
    const t = tasks.find(x => x.id === id); if (!t) return;
    editingId = id;
    $<HTMLInputElement>("#td-edit-title")!.value = t.title;
    $<HTMLTextAreaElement>("#td-edit-desc")!.value = t.desc ?? "";
    $<HTMLInputElement>("#td-edit-start")!.value = t.start ?? "";
    $<HTMLInputElement>("#td-edit-end")!.value   = t.end ?? "";
    modal.hidden = false; modal.setAttribute("aria-hidden", "false");
    setTimeout(() => $<HTMLInputElement>("#td-edit-title")!.focus(), 30);
  };
  const closeEdit = () => { editingId = null; modal.hidden = true; modal.setAttribute("aria-hidden", "true"); };

  modal.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).hasAttribute("data-td-close")) closeEdit();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.hidden) closeEdit();
  });
  editForm.addEventListener("submit", (e) => {
    e.preventDefault(); if (!editingId) return;
    const title = $<HTMLInputElement>("#td-edit-title")!.value.trim();
    if (!title) return;
    updateTask(editingId, {
      title,
      desc:  $<HTMLTextAreaElement>("#td-edit-desc")!.value.trim() || undefined,
      start: $<HTMLInputElement>("#td-edit-start")!.value || undefined,
      end:   $<HTMLInputElement>("#td-edit-end")!.value   || undefined,
    });
    closeEdit();
  });
  $<HTMLButtonElement>("#td-edit-delete")!.addEventListener("click", () => {
    if (!editingId) return;
    const id = editingId; closeEdit(); removeTask(id);
  });

  // Sync entre abas
  window.addEventListener("storage", (e) => {
    if (e.key === STORE_KEY) { tasks = loadTasks(); render(); }
  });

  // Atualização temporal a cada 30s (para chips "começa em…" e barra de progresso)
  setInterval(() => {
    // Só re-renderiza se houver alguma tarefa pendente com horário
    if (tasks.some(t => !t.done && (t.start || t.end))) render();
  }, 30_000);

  // Sincroniza tarefas já concluídas com o histórico da rotina (backfill).
  // Garante que conclusões anteriores a esta versão também apareçam no Dashboard.
  const syncRoutineHistory = () => {
    const entries = loadRoutineHistory();
    const known = new Set(entries.map((e) => e.taskId));
    let changed = false;
    tasks.forEach((t) => {
      if (t.done && !known.has(t.id)) {
        logRoutineCompletion(t);
        changed = true;
      }
    });
    return changed;
  };
  syncRoutineHistory();

  // Primeiro render
  render();
</script>