    background: var(--coral); border-radius: 999px;
    transform: translateX(-50%);
    pointer-events: none;
    box-shadow: 0 0 0 2px rgba(255,155,133,.3);
  }

  /* ── Layout ─────────────────────────────────────────────────────────────── */
  .routine-layout {
    display: grid;
    grid-template-columns: 320px minmax(0, 1fr);
    gap: 20px; align-items: start;
    margin-bottom: 20px;
  }

  /* ── Form panel ──────────────────────────────────────────────────────────── */
  .routine-form-panel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 22px; padding: 22px; box-shadow: var(--shadow-sm);
    position: sticky; top: 88px;
  }
  .form-panel-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .form-panel-head h2 { font-size: 1.15rem; margin: 0; }
  .form-cancel-btn {
    width: 34px !important; height: 34px !important; min-height: 34px !important;
    padding: 0 !important; border-radius: 10px !important;
    font-size: 1.2rem; font-weight: 900;
    background: var(--bg-alt) !important; border: 1px solid var(--border) !important;
    box-shadow: none !important; color: var(--text-soft) !important;
  }
  .form-cancel-btn:hover { background: var(--coral) !important; color: #fff !important; border-color: var(--coral) !important; }

  .rf-field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 12px; }
  .rf-field span { font-family: var(--font-head); font-weight: 800; font-size: 0.8rem; color: var(--text-soft); }
  .rf-field input, .rf-field select, .rf-field textarea {
    font: inherit; font-size: 0.95rem; color: var(--text);
    background: var(--surface-2); border: 2px solid var(--border);
    border-radius: 12px; padding: 9px 12px; width: 100%;
    transition: border-color 0.15s;
  }
  .rf-field input:focus, .rf-field select:focus, .rf-field textarea:focus {
    border-color: var(--blue); outline: none;
  }
  .rf-field input[type="color"] { padding: 4px 6px; height: 42px; cursor: pointer; }
  .rf-field textarea { resize: vertical; min-height: 64px; }
  .rf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .rf-actions { margin-top: 4px; }
  .rf-actions .btn { width: 100%; }
  .rf-divider { border: none; border-top: 1px solid var(--border); margin: 16px 0; }

  /* ── Routine panel ─────────────────────────────────────────────────────── */
  .routine-panel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 22px; padding: 22px; box-shadow: var(--shadow-sm);
  }
  .routine-panel-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; gap: 12px; flex-wrap: wrap; }
  .routine-panel-head h2 { font-size: 1.15rem; margin: 0; }
  .routine-panel-tools { display: flex; gap: 8px; flex-wrap: wrap; }
  .rpt-btn { font-size: 0.82rem !important; padding: 8px 14px !important; min-height: 36px !important; }

  .routine-drag-hint {
    display: flex; align-items: center; gap: 6px;
    font-size: 0.8rem; color: var(--text-muted); font-weight: 700;
    margin-bottom: 12px; padding: 8px 12px;
    background: var(--bg-alt); border-radius: 10px;
  }
  .routine-drag-hint span::before { content: '⠿  '; font-size: 1rem; }

  /* ── Activity list ─────────────────────────────────────────────────────── */
  .routine-list {
    list-style: none; display: flex; flex-direction: column; gap: 10px;
    min-height: 200px;
  }
  .routine-empty {
    display: grid; place-items: center; align-content: center;
    gap: 6px; min-height: 200px;
    border: 2px dashed var(--border); border-radius: 18px;
    background: var(--surface-2); text-align: center;
    color: var(--text-soft); padding: 28px;
  }
  .routine-empty strong { font-family: var(--font-head); font-size: 1.05rem; color: var(--text); }

  .routine-item {
    display: grid;
    grid-template-columns: 28px 52px minmax(0, 1fr) auto;
    gap: 12px; align-items: center;
    padding: 14px 14px 14px 10px;
    border-radius: 18px;
    border: 2px solid color-mix(in srgb, var(--rc) 20%, var(--border));
    background: color-mix(in srgb, var(--rc) 5%, white);
    transition: border-color 0.15s, box-shadow 0.15s, opacity 0.2s;
    cursor: default;
  }
  .routine-item.current {
    border-color: var(--rc);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--rc) 15%, transparent);
  }
  .routine-item.done { opacity: 0.55; }
  .routine-item.dragging { opacity: 0.5; transform: scale(0.98); }
  .routine-item.drag-over {
    border-color: var(--blue);
    box-shadow: 0 0 0 4px rgba(91,141,239,.2);
  }

  .ri-drag {
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; color: var(--text-muted); cursor: grab;
    user-select: none; line-height: 1;
  }
  .ri-drag:active { cursor: grabbing; }
