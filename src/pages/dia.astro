  }
  .fd-now { border-color: color-mix(in srgb, var(--act-color, var(--blue)) 30%, var(--border)); }
  .fd-now.has-time { box-shadow: 0 0 0 3px color-mix(in srgb, var(--act-color, var(--blue)) 15%, transparent), var(--shadow-sm); }
  .fd-badge {
    display: inline-flex; align-items: center;
