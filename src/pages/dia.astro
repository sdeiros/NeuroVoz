---
import Base from '../layouts/Base.astro';
---

<Base title="Plano do Dia — NeuroVoz" description="Rotina visual com Primeiro/Depois, progresso por tempo e atividades com alarme.">
  <section class="day-page">
    <div class="container">

      <!-- ── Header ──────────────────────────────────────────────────────── -->
      <header class="day-head">
        <div>
          <span class="eyebrow">Minha Rotina</span>
          <h1>Plano do Dia</h1>
          <p class="day-lead">Veja o que vem primeiro e o que vem depois!</p>
        </div>
        <div class="day-meta">
          <span class="day-date" id="day-date-label"></span>
          <div class="day-stats">
            <div class="day-stat">
              <strong id="stat-done">0</strong>
              <span>feitas</span>
            </div>
            <div class="day-stat-divider"></div>
            <div class="day-stat">
              <strong id="stat-total">0</strong>
              <span>total</span>
            </div>
            <div class="day-stat-divider"></div>
            <div class="day-stat">
              <strong id="stat-pct">0%</strong>
              <span>pronto</span>
            </div>
          </div>
        </div>
      </header>

      <!-- ── Primeiro / Depois ──────────────────────────────────────────── -->
      <div class="fd-strip" aria-live="polite" aria-label="Atividade atual e próxima" id="fd-strip">
        <div class="fd-card fd-now" id="fd-now">
          <div class="fd-badge fd-badge-now">PRIMEIRO</div>
          <div class="fd-icon-wrap" id="fd-now-icon-wrap">
            <span class="fd-icon" id="fd-now-icon" aria-hidden="true">📍</span>
          </div>
          <strong class="fd-name" id="fd-now-name">Nenhuma atividade</strong>
          <span class="fd-time" id="fd-now-time"></span>
          <div class="fd-bar-wrap" id="fd-now-bar-wrap" hidden>
            <div class="fd-bar-track">
              <div class="fd-bar-fill" id="fd-bar-fill"></div>
            </div>
            <span class="fd-bar-label" id="fd-bar-label">⏳</span>
          </div>
          <button class="fd-complete-btn" id="fd-complete-btn" hidden type="button">✓ Concluir!</button>
        </div>

        <div class="fd-divider" aria-hidden="true">
          <span class="fd-divider-arrow">→</span>
        </div>

        <div class="fd-card fd-next" id="fd-next">
          <div class="fd-badge fd-badge-next">DEPOIS</div>
          <div class="fd-icon-wrap fd-icon-wrap-next">
            <span class="fd-icon" id="fd-next-icon" aria-hidden="true">⏳</span>
          </div>
          <strong class="fd-name" id="fd-next-name">Adicione atividades</strong>
          <span class="fd-time" id="fd-next-time"></span>
        </div>
      </div>

      <!-- ── Global progress ────────────────────────────────────────────── -->
      <div class="global-prog" id="global-prog" hidden>
        <div class="global-prog-head">
          <span id="global-prog-label">0 de 0 feitas</span>
          <strong id="global-prog-pct">0%</strong>
        </div>
        <div class="global-prog-track" id="global-prog-track">
          <div class="global-prog-fill" id="global-prog-fill"></div>
          <div class="global-prog-markers" id="global-prog-markers"></div>
          <div class="global-prog-now" id="global-prog-now" hidden></div>
        </div>
      </div>

      <!-- ── Layout ─────────────────────────────────────────────────────── -->
      <div class="routine-layout">

        <!-- Form panel -->
        <aside class="form-panel" id="form-panel">
          <header class="form-head">
            <h2 id="form-title">Nova atividade</h2>
            <button class="form-cancel" id="form-cancel" hidden type="button" aria-label="Cancelar edição">✕</button>
          </header>

          <!-- Quick emoji picks -->
          <div class="emoji-grid" id="emoji-grid" aria-label="Sugestões de atividades">
            <button type="button" class="emoji-pick" data-name="Banho" data-icon="🛁">🛁<span>Banho</span></button>
            <button type="button" class="emoji-pick" data-name="Comer" data-icon="🍎">🍎<span>Comer</span></button>
            <button type="button" class="emoji-pick" data-name="Escola" data-icon="🎒">🎒<span>Escola</span></button>
            <button type="button" class="emoji-pick" data-name="Brincar" data-icon="🎮">🎮<span>Brincar</span></button>
            <button type="button" class="emoji-pick" data-name="Dormir" data-icon="🛏️">🛏️<span>Dormir</span></button>
            <button type="button" class="emoji-pick" data-name="Terapia" data-icon="🧩">🧩<span>Terapia</span></button>
            <button type="button" class="emoji-pick" data-name="Passeio" data-icon="🚶">🚶<span>Passeio</span></button>
            <button type="button" class="emoji-pick" data-name="Remédio" data-icon="💊">💊<span>Remédio</span></button>
          </div>

          <form id="routine-form" autocomplete="off">
            <input type="hidden" id="edit-id" />

            <label class="rf-field">
              <span class="rf-label">O que vai fazer?</span>
              <div class="rf-name-row">
                <input id="rf-icon" type="text" maxlength="4" placeholder="🛁" class="rf-icon-input" aria-label="Ícone da atividade" />
                <input id="rf-name" type="text" required placeholder="Escreva a atividade..." class="rf-name-input" aria-label="Nome da atividade" />
              </div>
            </label>

            <label class="rf-field">
              <span class="rf-label">Cor</span>
              <div class="rf-color-row">
                <button type="button" class="rf-color-swatch active" data-color="#5b8def" style="background:#5b8def" aria-label="Azul"></button>
                <button type="button" class="rf-color-swatch" data-color="#5cc9b0" style="background:#5cc9b0" aria-label="Verde"></button>
                <button type="button" class="rf-color-swatch" data-color="#ff9b85" style="background:#ff9b85" aria-label="Coral"></button>
                <button type="button" class="rf-color-swatch" data-color="#ffd166" style="background:#ffd166" aria-label="Amarelo"></button>
                <button type="button" class="rf-color-swatch" data-color="#c084fc" style="background:#c084fc" aria-label="Roxo"></button>
                <button type="button" class="rf-color-swatch" data-color="#f97316" style="background:#f97316" aria-label="Laranja"></button>
                <input id="rf-color" type="color" value="#5b8def" class="rf-color-custom" title="Cor personalizada" aria-label="Escolher cor" />
              </div>
            </label>

            <div class="rf-row">
              <label class="rf-field">
                <span class="rf-label">Começa às</span>
                <input id="rf-time-start" type="time" />
              </label>
              <label class="rf-field">
                <span class="rf-label">Termina às</span>
                <input id="rf-time-end" type="time" />
              </label>
            </div>

            <label class="rf-field rf-alarm-row" id="rf-alarm-row" hidden>
              <span class="rf-label">🔔 Alarme</span>
              <select id="rf-alarm">
                <option value="true">Ativado</option>
                <option value="false">Desativado</option>
              </select>
            </label>

            <label class="rf-field">
              <span class="rf-label">Observações (opcional)</span>
              <textarea id="rf-notes" rows="2" placeholder="Ex.: usar apoio visual"></textarea>
            </label>

            <div class="rf-actions">
              <button class="btn btn-primary rf-submit" type="submit" id="form-submit-btn">+ Adicionar</button>
            </div>
          </form>

          <div class="rf-divider"></div>
          <label class="rf-field">
            <span class="rf-label">🎉 Tema de celebração</span>
            <select id="routine-theme">
              <option value="auto">Do perfil da criança</option>
              <option value="confetes">🎉 Confetes</option>
              <option value="dinossauros">🦖 Dinossauros</option>
              <option value="carros">🚗 Carros</option>
              <option value="flores">🌸 Flores</option>
              <option value="estrelas">⭐ Estrelas</option>
              <option value="unicornio">🦄 Unicórnios</option>
              <option value="espaco">🚀 Espaço</option>
              <option value="animais">🐶 Animais</option>
              <option value="princesas">👑 Princesas</option>
            </select>
          </label>
        </aside>

        <!-- Activity list -->
        <div class="act-panel">
          <div class="act-panel-head">
            <h2>Atividades de hoje</h2>
            <div class="act-panel-tools">
              <button class="btn btn-ghost rpt-btn" id="btn-clear-done" type="button">Limpar feitas</button>
              <button class="btn btn-ghost rpt-btn" id="btn-reset-day" type="button">Reiniciar</button>
            </div>
          </div>

          <div class="drag-hint" id="drag-hint" hidden>
            Segure e arraste para mudar a ordem
          </div>

          <ul class="act-list" id="routine-list" aria-live="polite" aria-label="Lista de atividades"></ul>
        </div>
      </div>

    </div>
  </section>
</Base>

<!-- ═══════════════════════════════════════════════════════════════════════ -->
<script>
  // @ts-nocheck
  const ROUTINE_KEY = 'nv-routine-plan';
  const ROUTINE_HISTORY_KEY = 'nv-routine-history';
  const ROUTINE_SETTINGS_KEY = 'nv-routine-settings';

  function readJson(key, fallback) {
    try { return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback)); } catch { return fallback; }
  }
  function writeJson(key, value) {
    localStorage.setItem(key, JSON.stringify(value));
    window.dispatchEvent(new Event('nv-routine-updated'));
    window.NVRoutine?.refreshUI?.();
  }
  function escHtml(v) {
    return String(v ?? '').replace(/[&<>"']/g, (c) => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }
  function todayKey() { return new Date().toISOString().slice(0, 10); }
  function nowMs() { return Date.now(); }

  function targetMs(act) {
    if (!act?.timeStart) return null;
    const [h, m] = String(act.timeStart).split(':').map(Number);
    if (isNaN(h) || isNaN(m)) return null;
    const d = new Date(); d.setHours(h, m, 0, 0);
    return d.getTime();
  }
  function endMs(act) {
    if (!act?.timeEnd) return null;
    const [h, m] = String(act.timeEnd).split(':').map(Number);
    if (isNaN(h) || isNaN(m)) return null;
    const d = new Date(); d.setHours(h, m, 0, 0);
    return d.getTime();
  }

  function loadRoutine() {
    const saved = readJson(ROUTINE_KEY, null);
    if (saved?.day === todayKey() && Array.isArray(saved.activities)) return saved.activities;
    writeJson(ROUTINE_KEY, { day: todayKey(), activities: [] });
    return [];
  }
  function saveRoutine(acts) { writeJson(ROUTINE_KEY, { day: todayKey(), activities: acts }); }
  function loadSettings() { return readJson(ROUTINE_SETTINGS_KEY, { hidden: false, theme: 'auto' }); }
  function saveSettings(s) { writeJson(ROUTINE_SETTINGS_KEY, s); }
  function loadHistory() { return readJson(ROUTINE_HISTORY_KEY, []); }

  function sortedActivities() {
    return loadRoutine().sort((a, b) => {
      const at = targetMs(a), bt = targetMs(b);
      if (at === null && bt === null) return (a.order ?? 0) - (b.order ?? 0);
      if (at === null) return 1;
      if (bt === null) return -1;
      return at - bt;
    });
  }

  function getSnapshot() {
    const activities = sortedActivities();
    const now = nowMs();
    const timed = activities.filter((i) => targetMs(i) !== null);
    let current = timed.filter((i) => targetMs(i) <= now && !i.completed).at(-1)
      || activities.find((i) => !i.completed && targetMs(i) === null) || null;
    if (!current) current = activities.find((i) => !i.completed) || null;
    const next = activities.find((i) => !i.completed && i.id !== current?.id && (targetMs(i) ?? Infinity) > now)
      || activities.find((i) => !i.completed && i.id !== current?.id) || null;
    return { activities, current, next };
  }

  function formatUntil(act) {
    const t = targetMs(act);
    if (t === null) return '';
    let diff = Math.floor((t - nowMs()) / 1000);
    if (diff <= 0) return 'Agora';
    const h = Math.floor(diff / 3600), m = Math.floor((diff % 3600) / 60), s = diff % 60;
    if (h > 0) return `${h}h ${String(m).padStart(2,'0')}m`;
    if (m > 0) return `${m}m ${String(s).padStart(2,'0')}s`;
    return `${s}s`;
  }

  // Icon auto-detection
  function guessIcon(raw) {
    const t = (raw || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    const rules = [
      [/banho|chuveiro|ducha/, '🛁'], [/escovar|dente/, '🪥'], [/dormir|cama|soneca/, '🛏️'],
      [/acordar|levantar/, '⏰'], [/comer|refeicao|almoco|janta|lanche|merenda/, '🍎'],
      [/cafe|desjejum/, '☕'], [/agua|beber/, '💧'], [/escola|aula|professor/, '🎒'],
      [/tarefa|dever|estudo|ler|livro/, '📚'], [/brincar|jogo|jogar/, '🎮'],
      [/parque|playground/, '🛝'], [/caminhar|passeio|correr/, '🚶'],
      [/natacao|nadar|piscina/, '🏊'], [/bicicleta|pedalar/, '🚴'],
      [/desenho|pintar|arte/, '🎨'], [/musica|cantar/, '🎵'],
      [/terapia|fono|psicologo/, '🧩'], [/remedio|medicacao/, '💊'],
      [/banheiro|xixi/, '🚽'], [/roupa|vestir/, '👕'],
      [/carro|onibus/, '🚗'], [/compras|mercado/, '🛒'],
      [/limpar|arrumar|organizar/, '🧹'], [/yoga|meditacao|respirar/, '🧘'],
      [/tv|filme|serie|assistir/, '📺'], [/festa|aniversario/, '🎉'],
    ];
    return rules.find(([re]) => re.test(t))?.[1] || '';
  }

  function speak(text) {
    if (!('speechSynthesis' in window)) return;
    window.speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance(text);
    u.lang = 'pt-BR';
    window.speechSynthesis.speak(u);
  }

  // Celebration
  function inferTheme() {
    const s = loadSettings();
    if (s.theme && s.theme !== 'auto') return s.theme;
    const c = readJson('nv-tablet-config', {});
    const txt = `${c.interesses||''} ${c.hiperfocos||''} ${c.brincadeiras||''} ${c.personagens||''}`.toLowerCase();
    const rules = [
      ['dinossauros', ['dinossauro', 'dino']], ['carros', ['carro', 'caminhao', 'onibus']],
      ['princesas', ['princesa', 'coroa']], ['animais', ['animal', 'cachorro', 'gato']],
      ['espaco', ['espaco', 'foguete', 'planeta']], ['flores', ['flor']], ['unicornio', ['unicornio']],
    ];
    return rules.find(([, ws]) => ws.some((w) => txt.includes(w)))?.[0] || 'confetes';
  }
  const THEME_ICONS = { dinossauros:'🦖', carros:'🚗', flores:'🌸', estrelas:'⭐', unicornio:'🦄', espaco:'🚀', animais:'🐶', confetes:'🎉', princesas:'👑' };

  function celebrate(msg = '🎉 Muito bem!') {
    const el = document.getElementById('nv-timer-celebration');
    if (!el) return;
    const sym = THEME_ICONS[inferTheme()] || '🎉';
    el.innerHTML = '';
    el.removeAttribute('hidden');
    el.classList.add('active');
    for (let i = 0; i < 28; i++) {
      const d = document.createElement('span');
      d.className = 'rain-item';
      d.textContent = sym;
      d.style.left = `${Math.random() * 94}%`;
      d.style.animationDelay = `${Math.random() * 1.6}s`;
      d.style.fontSize = `${20 + Math.random() * 28}px`;
      el.appendChild(d);
    }
    const card = document.createElement('div');
    card.className = 'celebration-message';
    card.innerHTML = `<strong>${msg}</strong><p>Toque na tela para continuar!</p>`;
    el.appendChild(card);

    let dismissed = false;
    const dismiss = () => {
      if (dismissed) return;
      dismissed = true;
      el.classList.add('dismissing');
      setTimeout(() => {
        el.classList.remove('active', 'dismissing');
        el.setAttribute('hidden', '');
        el.innerHTML = '';
      }, 600);
    };
    el._dismissFn = dismiss;
    setTimeout(dismiss, 6000);
  }

  // Completion
  function completeActivity(id) {
    const acts = loadRoutine();
    const item = acts.find((a) => a.id === id);
    if (!item || item.completed) return;
    item.completed = true;
    item.completedAt = new Date().toISOString();
    const hist = loadHistory();
    hist.unshift({
      id: item.id, name: item.name, icon: item.icon,
      time: item.timeStart,
      completedAt: new Date().toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}),
      date: todayKey(), type: 'completed',
    });
    writeJson(ROUTINE_HISTORY_KEY, hist.slice(0, 240));
    saveRoutine(acts);
    speak(`${item.name} concluído. Muito bem!`);
    celebrate(`${item.icon || '🎉'} Muito bem!`);
    render();
  }

  function removeActivity(id) {
    saveRoutine(loadRoutine().filter((a) => a.id !== id));
    render();
  }

  function notify(title, body) {
    try {
      if ('Notification' in window && Notification.permission === 'granted')
        new Notification(title, { body, icon: '/icon.svg', tag: `nv-${title}` });
    } catch {}
  }

  function tick() {
    const acts = loadRoutine();
    const now = nowMs();
    let changed = false;
    acts.forEach((item) => {
      const t = targetMs(item);
      if (t === null || item.completed) return;
      const cdMs = (Number(item.countdown) || 5) * 60 * 1000;
      if (cdMs > 0 && !item.countdownFired && now >= t - cdMs && now < t) {
        item.countdownFired = true; changed = true;
        const diff = Math.round((t - now) / 60000);
        const label = diff < 1 ? `Falta menos de um minuto para ${item.name}` : `Faltam ${diff} minutos para ${item.name}`;
        speak(label); celebrate('⏳ Prepare-se!'); notify('⏳ Prepare-se', label);
      }
      if (item.alarm && !item.alarmFired && now >= t) {
        item.alarmFired = true; changed = true;
        speak(`Hora de ${item.name}`); celebrate(`${item.icon||'📍'} Hora de ${item.name}!`);
        notify(`${item.icon||'📍'} ${item.name}`, `Hora de ${item.name}`);
      }
    });
    if (changed) saveRoutine(acts);
    render();
  }

  // ─── Render ───────────────────────────────────────────────────────────────
  function render() {
    const { activities, current, next } = getSnapshot();
    const done = activities.filter((a) => a.completed).length;
    const total = activities.length;
    const pct = total ? Math.round((done / total) * 100) : 0;

    // Date label
    const dateLabel = document.getElementById('day-date-label');
    if (dateLabel) {
      const d = new Date();
      dateLabel.textContent = d.toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long' });
    }

    document.getElementById('stat-done').textContent = String(done);
    document.getElementById('stat-total').textContent = String(total);
    document.getElementById('stat-pct').textContent = `${pct}%`;

    // Primeiro / Depois
    const nowIconEl = document.getElementById('fd-now-icon');
    const nowNameEl = document.getElementById('fd-now-name');
    const nowTimeEl = document.getElementById('fd-now-time');
    const nextIconEl = document.getElementById('fd-next-icon');
    const nextNameEl = document.getElementById('fd-next-name');
    const nextTimeEl = document.getElementById('fd-next-time');
    const nowCard = document.getElementById('fd-now');
    const nextCard = document.getElementById('fd-next');
    const completeBtn = document.getElementById('fd-complete-btn');

    if (current) {
      nowIconEl.textContent = current.icon || '📍';
      nowNameEl.textContent = current.name;
      nowTimeEl.textContent = current.timeStart ? `${current.timeStart}${current.timeEnd ? ' – '+current.timeEnd : ''}` : '';
      nowCard.style.setProperty('--ac', current.color || '#5b8def');
      nowCard.classList.add('has-activity');
      if (completeBtn) { completeBtn.hidden = false; completeBtn.dataset.id = current.id; }
    } else {
      nowIconEl.textContent = total ? '🎉' : '📍';
      nowNameEl.textContent = total ? 'Tudo feito!' : 'Adicione atividades';
      nowTimeEl.textContent = '';
      nowCard.style.removeProperty('--ac');
      nowCard.classList.remove('has-activity');
      if (completeBtn) completeBtn.hidden = true;
    }

    if (next) {
      nextIconEl.textContent = next.icon || '⏳';
      nextNameEl.textContent = next.name;
      nextTimeEl.textContent = next.timeStart ? `${next.timeStart}${next.timeEnd ? ' – '+next.timeEnd : ''}` : formatUntil(next);
      nextCard.style.setProperty('--ac', next.color || '#5b8def');
      nextCard.classList.add('has-activity');
    } else {
      nextIconEl.textContent = total ? '✅' : '⏳';
      nextNameEl.textContent = total ? 'Todas feitas!' : 'Adicione mais';
      nextTimeEl.textContent = '';
      nextCard.style.removeProperty('--ac');
      nextCard.classList.remove('has-activity');
    }

    // Time bar in fd-now
    const barWrap = document.getElementById('fd-now-bar-wrap');
    const barFill = document.getElementById('fd-bar-fill');
    const barLabel = document.getElementById('fd-bar-label');
    if (current && current.timeStart && current.timeEnd) {
      barWrap.hidden = false;
      const start = targetMs(current), end = endMs(current), now2 = nowMs();
      const elapsed = Math.max(0, Math.min(1, (now2 - start) / (end - start)));
      barFill.style.width = `${elapsed * 100}%`;
      barFill.style.background = `linear-gradient(90deg, ${current.color||'#5cc9b0'}, color-mix(in srgb, ${current.color||'#5b8def'} 70%, white))`;
      barLabel.textContent = elapsed >= 1 ? '✅ Concluir!' : formatUntil({timeStart: current.timeEnd});
    } else if (current && current.timeStart) {
      barWrap.hidden = false;
      barFill.style.width = '100%';
      barLabel.textContent = formatUntil(current) || 'Agora';
    } else {
      if (barWrap) barWrap.hidden = true;
    }

    // Global progress
    const globalWrap = document.getElementById('global-prog');
    const globalFill = document.getElementById('global-prog-fill');
    const globalLabel = document.getElementById('global-prog-label');
    const globalPct = document.getElementById('global-prog-pct');
    const globalMarkers = document.getElementById('global-prog-markers');
    const nowLine = document.getElementById('global-prog-now');

    const timedActs = activities.filter((a) => a.timeStart);
    if (total > 0) {
      globalWrap.hidden = false;
      globalFill.style.width = `${pct}%`;
      globalLabel.textContent = `${done} de ${total} feitas`;
      globalPct.textContent = `${pct}%`;

      if (timedActs.length >= 2) {
        const earliest = Math.min(...timedActs.map((a) => targetMs(a)));
        const latest = Math.max(...timedActs.map((a) => endMs(a) || targetMs(a)));
        const span = latest - earliest;
        const nowPos = span > 0 ? Math.max(0, Math.min(100, ((nowMs() - earliest) / span) * 100)) : 0;

        globalMarkers.innerHTML = '';
        timedActs.forEach((a) => {
          if (span <= 0) return;
          const pos = ((targetMs(a) - earliest) / span) * 100;
          const mk = document.createElement('span');
          mk.className = `gp-marker${a.completed ? ' done' : ''}${a.id === current?.id ? ' active' : ''}`;
          mk.style.left = `${pos}%`;
          mk.title = `${a.icon||'📍'} ${a.name} (${a.timeStart})`;
          mk.textContent = a.icon || '📍';
          globalMarkers.appendChild(mk);
        });
        nowLine.style.left = `${nowPos}%`;
        nowLine.hidden = false;
      } else {
        globalMarkers.innerHTML = '';
        nowLine.hidden = true;
      }
    } else {
      globalWrap.hidden = true;
    }

    document.getElementById('drag-hint').hidden = total < 2;
    renderList(activities, current);

    const themeEl = document.getElementById('routine-theme');
    if (themeEl) themeEl.value = loadSettings().theme || 'auto';
  }

  // ─── List rendering ────────────────────────────────────────────────────────
  function renderList(activities, current) {
    const list = document.getElementById('routine-list');
    if (!list) return;

    if (!activities.length) {
      list.innerHTML = `
        <li class="act-empty">
          <span class="act-empty-icon">🌟</span>
          <strong>Ainda vazio!</strong>
          <span>Use o formulário ao lado para<br>adicionar a primeira atividade.</span>
        </li>`;
      return;
    }

    list.innerHTML = '';
    activities.forEach((item) => {
      const isCurrent = item.id === current?.id && !item.completed;
      const li = document.createElement('li');
      li.className = `act-item${item.completed ? ' done' : ''}${isCurrent ? ' current' : ''}`;
      li.dataset.id = item.id;
      li.draggable = !item.completed;
      li.setAttribute('aria-grabbed', 'false');
      li.style.setProperty('--rc', item.color || '#5b8def');

      let itemBarHtml = '';
      if (item.timeStart && item.timeEnd && !item.completed) {
        const start = targetMs(item), end = endMs(item), now = nowMs();
        const p2 = Math.max(0, Math.min(100, ((now - start) / (end - start)) * 100));
        itemBarHtml = `<div class="act-time-bar"><div class="act-time-bar-fill" style="width:${p2}%;background:${item.color||'#5b8def'}"></div></div>`;
      }

      // Time rows: Início / Fim + completion timestamp
      let timeHtml = '';
      if (item.timeStart) {
        timeHtml += `<div class="act-time-row"><span class="act-time-lbl">Início</span><span class="act-time-val">${escHtml(item.timeStart)}</span></div>`;
      }
      if (item.timeEnd) {
        timeHtml += `<div class="act-time-row"><span class="act-time-lbl">Fim</span><span class="act-time-val">${escHtml(item.timeEnd)}</span></div>`;
      }

      const completedAt = item.completedAt
        ? new Date(item.completedAt).toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'})
        : null;

      let statusHtml = '';
      if (item.completed) {
        statusHtml = `<div class="act-status done-status">✅ Feita${completedAt ? `<span class="act-completed-at"> às ${completedAt}</span>` : ''}</div>`;
      } else if (isCurrent) {
        statusHtml = `<div class="act-status current-status">🔵 Agora</div>`;
      }

      li.innerHTML = `
        <div class="act-drag" aria-label="Arrastar" title="Arrastar para reordenar"><span class="drag-dots"></span></div>
        <div class="act-icon">${escHtml(item.icon||'📍')}</div>
        <div class="act-info">
          <div class="act-name">${escHtml(item.name)}</div>
          ${timeHtml ? `<div class="act-times">${timeHtml}</div>` : ''}
          ${statusHtml}
          ${item.notes ? `<div class="act-notes">${escHtml(item.notes)}</div>` : ''}
          ${itemBarHtml}
        </div>
        <div class="act-actions">
          ${!item.completed ? `<button class="act-btn act-complete" data-id="${item.id}" title="Concluir" aria-label="Concluir ${escHtml(item.name)}">✓</button>` : ''}
          <button class="act-btn act-edit" data-id="${item.id}" title="Editar" aria-label="Editar ${escHtml(item.name)}">✎</button>
          <button class="act-btn act-remove" data-id="${item.id}" title="Remover" aria-label="Remover ${escHtml(item.name)}">×</button>
        </div>`;
      list.appendChild(li);
    });

    list.querySelectorAll('.act-complete').forEach((btn) => btn.addEventListener('click', () => completeActivity(btn.dataset.id)));
    list.querySelectorAll('.act-remove').forEach((btn) => btn.addEventListener('click', () => removeActivity(btn.dataset.id)));
    list.querySelectorAll('.act-edit').forEach((btn) => btn.addEventListener('click', () => startEdit(btn.dataset.id)));
    setupDnd(list);
  }

  // ─── Drag-and-drop ────────────────────────────────────────────────────────
  let dragSrc = null;

  function setupDnd(list) {
    list.querySelectorAll('li[draggable]').forEach((li) => {
      li.addEventListener('dragstart', (e) => {
        dragSrc = li;
        li.setAttribute('aria-grabbed', 'true');
        li.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
      });
      li.addEventListener('dragend', () => {
        li.setAttribute('aria-grabbed', 'false');
        li.classList.remove('dragging');
        list.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over'));
        dragSrc = null;
      });
      li.addEventListener('dragover', (e) => {
        if (!dragSrc || dragSrc === li) return;
        e.preventDefault();
        list.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over'));
        li.classList.add('drag-over');
      });
      li.addEventListener('drop', (e) => {
        if (!dragSrc || dragSrc === li) return;
        e.preventDefault();
        const acts = loadRoutine();
        const srcIdx = acts.findIndex((a) => a.id === dragSrc.dataset.id);
        const dstIdx = acts.findIndex((a) => a.id === li.dataset.id);
        if (srcIdx === -1 || dstIdx === -1) return;
        const [moved] = acts.splice(srcIdx, 1);
        acts.splice(dstIdx, 0, moved);
        acts.forEach((a, i) => { a.order = i; });
        saveRoutine(acts);
        render();
      });
    });

    let touchItem = null, touchClone = null, touchStartY = 0;
    list.querySelectorAll('li[draggable]').forEach((li) => {
      li.addEventListener('touchstart', (e) => {
        touchItem = li;
        touchStartY = e.touches[0].clientY;
        const rect = li.getBoundingClientRect();
        touchClone = li.cloneNode(true);
        touchClone.style.cssText = `position:fixed;left:${rect.left}px;top:${rect.top}px;width:${rect.width}px;opacity:0.9;z-index:200;pointer-events:none;box-shadow:0 16px 40px rgba(0,0,0,0.24);border-radius:18px;transform:scale(1.03);`;
        document.body.appendChild(touchClone);
        li.classList.add('dragging');
      }, { passive: true });
      li.addEventListener('touchmove', (e) => {
        if (!touchItem || !touchClone) return;
        const dy = e.touches[0].clientY - touchStartY;
        touchClone.style.top = `${touchItem.getBoundingClientRect().top + dy}px`;
        const target = document.elementFromPoint(e.touches[0].clientX, e.touches[0].clientY)?.closest('li.act-item');
        list.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over'));
        if (target && target !== touchItem) target.classList.add('drag-over');
      }, { passive: true });
      li.addEventListener('touchend', (e) => {
        if (!touchItem) return;
        const target = document.elementFromPoint(e.changedTouches[0].clientX, e.changedTouches[0].clientY)?.closest('li.act-item');
        if (target && target !== touchItem) {
          const acts = loadRoutine();
          const srcIdx = acts.findIndex((a) => a.id === touchItem.dataset.id);
          const dstIdx = acts.findIndex((a) => a.id === target.dataset.id);
          if (srcIdx !== -1 && dstIdx !== -1) {
            const [moved] = acts.splice(srcIdx, 1);
            acts.splice(dstIdx, 0, moved);
            acts.forEach((a, i) => { a.order = i; });
            saveRoutine(acts);
          }
        }
        touchClone?.remove(); touchClone = null;
        touchItem.classList.remove('dragging');
        list.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over'));
        touchItem = null;
        render();
      }, { passive: true });
    });
  }

  // ─── Edit ─────────────────────────────────────────────────────────────────
  function startEdit(id) {
    const item = loadRoutine().find((a) => a.id === id);
    if (!item) return;
    document.getElementById('edit-id').value = item.id;
    document.getElementById('rf-name').value = item.name;
    document.getElementById('rf-icon').value = item.icon || '';
    setColorSwatch(item.color || '#5b8def');
    document.getElementById('rf-color').value = item.color || '#5b8def';
    document.getElementById('rf-time-start').value = item.timeStart || '';
    document.getElementById('rf-time-end').value = item.timeEnd || '';
    document.getElementById('rf-notes').value = item.notes || '';
    document.getElementById('rf-alarm').value = String(item.alarm ?? false);
    document.getElementById('rf-alarm-row').hidden = !item.timeStart;
    document.getElementById('form-title').textContent = `Editar: ${item.name}`;
    document.getElementById('form-submit-btn').textContent = 'Salvar';
    document.getElementById('form-cancel').hidden = false;
    document.getElementById('rf-name').focus();
    document.getElementById('form-panel').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function cancelEdit() {
    document.getElementById('edit-id').value = '';
    document.getElementById('routine-form').reset();
    setColorSwatch('#5b8def');
    document.getElementById('rf-color').value = '#5b8def';
    document.getElementById('rf-alarm-row').hidden = true;
    document.getElementById('form-title').textContent = 'Nova atividade';
    document.getElementById('form-submit-btn').textContent = '+ Adicionar';
    document.getElementById('form-cancel').hidden = true;
  }

  function setColorSwatch(color) {
    document.querySelectorAll('.rf-color-swatch').forEach((s) => {
      s.classList.toggle('active', s.dataset.color === color);
    });
  }

  // ─── Form wiring ──────────────────────────────────────────────────────────
  const nameInput = document.getElementById('rf-name');
  const iconInput = document.getElementById('rf-icon');
  const timeStartInput = document.getElementById('rf-time-start');
  const alarmRow = document.getElementById('rf-alarm-row');
  const colorInput = document.getElementById('rf-color');

  function setCurrentTime() {
    if (!timeStartInput.value) {
      const now = new Date();
      timeStartInput.value = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
      alarmRow.hidden = false;
    }
  }
  setCurrentTime();

  nameInput?.addEventListener('input', () => {
    const g = guessIcon(nameInput.value);
    if (g) iconInput.placeholder = g;
  });

  timeStartInput?.addEventListener('input', () => {
    alarmRow.hidden = !timeStartInput.value;
  });

  // Color swatches
  document.querySelectorAll('.rf-color-swatch').forEach((swatch) => {
    swatch.addEventListener('click', () => {
      const c = swatch.dataset.color;
      colorInput.value = c;
      setColorSwatch(c);
    });
  });

  colorInput?.addEventListener('input', () => {
    setColorSwatch(colorInput.value);
  });

  // Quick emoji picks
  document.querySelectorAll('.emoji-pick').forEach((btn) => {
    btn.addEventListener('click', () => {
      nameInput.value = btn.dataset.name;
      iconInput.value = btn.dataset.icon;
      iconInput.placeholder = btn.dataset.icon;
      nameInput.focus();
    });
  });

  // Complete button in fd-now
  document.getElementById('fd-complete-btn')?.addEventListener('click', (e) => {
    const id = e.currentTarget.dataset.id;
    if (id) completeActivity(id);
  });

  document.getElementById('routine-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const editId = document.getElementById('edit-id').value;
    const acts = loadRoutine();
    const data = {
      name: document.getElementById('rf-name').value.trim(),
      icon: document.getElementById('rf-icon').value.trim() || guessIcon(document.getElementById('rf-name').value) || '📍',
      color: colorInput.value,
      timeStart: document.getElementById('rf-time-start').value || '',
      timeEnd: document.getElementById('rf-time-end').value || '',
      notes: document.getElementById('rf-notes').value.trim(),
      alarm: document.getElementById('rf-time-start').value ? document.getElementById('rf-alarm').value === 'true' : false,
      countdown: 5,
      completed: false,
      completedAt: null,
      alarmFired: false,
      countdownFired: false,
    };

    if (editId) {
      const idx = acts.findIndex((a) => a.id === editId);
      if (idx !== -1) {
        data.completed = acts[idx].completed;
        data.completedAt = acts[idx].completedAt;
        data.alarmFired = acts[idx].alarmFired;
        data.countdownFired = acts[idx].countdownFired;
        data.order = acts[idx].order;
        acts[idx] = { ...acts[idx], ...data };
      }
    } else {
      data.id = `r-${Date.now()}`;
      data.order = acts.length;
      acts.push(data);
    }

    saveRoutine(acts);
    cancelEdit();
    setCurrentTime();
    render();
  });

  document.getElementById('form-cancel')?.addEventListener('click', () => { cancelEdit(); setCurrentTime(); });

  document.getElementById('routine-theme')?.addEventListener('change', (e) => {
    saveSettings({ ...loadSettings(), theme: e.target.value });
  });

  document.getElementById('btn-clear-done')?.addEventListener('click', () => {
    saveRoutine(loadRoutine().filter((a) => !a.completed));
    render();
  });

  document.getElementById('btn-reset-day')?.addEventListener('click', () => {
    if (!confirm('Reiniciar o plano do dia? As atividades ficam, mas serão marcadas como pendentes.')) return;
    const acts = loadRoutine().map((a) => ({ ...a, completed: false, completedAt: null, alarmFired: false, countdownFired: false }));
    saveRoutine(acts);
    render();
  });

  if ('Notification' in window && Notification.permission === 'default') {
    try { Notification.requestPermission(); } catch {}
  }
  render();
  setInterval(tick, 500);
</script>

