    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--act-color, var(--blue)); background: color-mix(in srgb, var(--act-color, var(--blue)) 12%, transparent);
    padding: 4px 12px; border-radius: 999px; width: fit-content;
  }
  .fd-next .fd-badge { color: var(--text-muted); background: var(--bg-alt); }
  .fd-content { display: flex; align-items: center; gap: 16px; }
  .fd-icon {
    width: 64px; height: 64px; flex-shrink: 0;
    display: grid; place-items: center;
    font-size: 2.4rem; border-radius: 18px;
