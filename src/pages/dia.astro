---
import Base from '../layouts/Base.astro';
---

<Base title="Plano do Dia — NeuroVoz" description="Centro de rotina visual para organizar atividades, transições, alarmes, contagens regressivas e histórico local.">
  <section class="day-page">
    <div class="container">
      <header class="day-head">
        <div>
          <span class="eyebrow">Centro de Rotina</span>
          <h1>Plano do Dia</h1>
          <p>Monte a sequência visual do dia, acompanhe o que já aconteceu e prepare transições com apoio visual e voz.</p>
        </div>
        <div class="routine-now" aria-live="polite">
          <span>📍 Agora</span>
          <strong id="routine-current">Nenhuma atividade atual</strong>
          <span>📍 Depois</span>
          <strong id="routine-next">Adicione a primeira atividade</strong>
          <em id="routine-next-time">⏳ Sem atividades no plano</em>
        </div>
      </header>

      <div class="routine-layout">
        <form class="routine-form" id="routine-form">
          <h2>Nova atividade</h2>
          <div class="routine-form-grid">
            <label class="routine-field">
              <span>Nome</span>
              <input id="routine-name" type="text" required placeholder="Ex.: Banho" />
            </label>
            <label class="routine-field">
              <span>Tipo de horário</span>
              <select id="routine-time-mode">
                <option value="none">Sem horário</option>
                <option value="time">Com horário</option>
              </select>
            </label>
            <label class="routine-field routine-time-field" id="routine-time-field">
              <span>Horário</span>
              <input id="routine-time" type="time" />
            </label>
            <label class="routine-field">
              <span>Ícone</span>
              <input id="routine-icon" type="text" maxlength="4" placeholder="🛁" />
            </label>
            <label class="routine-field">
              <span>Cor</span>
              <input id="routine-color" type="color" value="#5b8def" />
            </label>
            <label class="routine-field routine-timed-option" hidden>
              <span>Alarme</span>
              <select id="routine-alarm">
                <option value="true">Ativado</option>
                <option value="false">Desativado</option>
              </select>
            </label>
          </div>
          <label class="routine-field">
            <span>Observações</span>
            <textarea id="routine-notes" rows="3" placeholder="Ex.: usar apoio visual, avisar com antecedência"></textarea>
          </label>
          <button class="btn btn-primary" type="submit">Adicionar atividade</button>
        </form>

        <div class="routine-panel">
          <div class="routine-tools">
            <label class="routine-field compact">
              <span>Celebração</span>
              <select id="routine-theme">
                <option value="auto">Usar interesses do perfil</option>
                <option value="dinossauros">🦖 Dinossauros</option>
                <option value="carros">🚗 Carros</option>
                <option value="flores">🌸 Flores</option>
                <option value="estrelas">⭐ Estrelas</option>
                <option value="unicornio">🦄 Unicórnios</option>
                <option value="espaco">🚀 Espaço</option>
                <option value="animais">🐶 Animais</option>
                <option value="confetes">🎉 Confetes</option>
                <option value="princesas">👑 Princesas</option>
              </select>
            </label>
            <button class="btn btn-ghost" type="button" id="routine-show-widget">Mostrar widget</button>
            <button class="btn btn-ghost" type="button" id="routine-hide-widget">Ocultar widget</button>
          </div>
          <div class="routine-progress" aria-label="Progresso do plano do dia">
            <span id="routine-progress-label">0 de 0 concluídas</span>
            <div><i id="routine-progress-bar"></i></div>
          </div>
          <div class="routine-list" id="routine-list" aria-live="polite"></div>
        </div>
      </div>

      <div class="routine-reports">
        <article>
          <span id="routine-report-done">0</span>
          <strong>Concluídas hoje</strong>
        </article>
        <article>
          <span id="routine-report-rate">0%</span>
          <strong>Taxa diária</strong>
        </article>
        <article>
          <span id="routine-report-peak">--:--</span>
          <strong>Maior participação</strong>
        </article>
        <article>
          <span id="routine-report-week">0</span>
          <strong>Histórico semanal</strong>
        </article>
      </div>
    </div>
  </section>
</Base>

<script>
  // @ts-nocheck
  const ROUTINE_KEY = 'nv-routine-plan';
  const ROUTINE_HISTORY_KEY = 'nv-routine-history';
  const ROUTINE_SETTINGS_KEY = 'nv-routine-settings';

  const routineForm = document.getElementById('routine-form');
  const routineList = document.getElementById('routine-list');
  const routineTheme = document.getElementById('routine-theme');
  const routineCurrent = document.getElementById('routine-current');
  const routineNext = document.getElementById('routine-next');
  const routineNextTime = document.getElementById('routine-next-time');
  const routineProgressLabel = document.getElementById('routine-progress-label');
  const routineProgressBar = document.getElementById('routine-progress-bar');
  const routineReportDone = document.getElementById('routine-report-done');
  const routineReportRate = document.getElementById('routine-report-rate');
  const routineReportPeak = document.getElementById('routine-report-peak');
  const routineReportWeek = document.getElementById('routine-report-week');
  const routineShowWidget = document.getElementById('routine-show-widget');
  const routineHideWidget = document.getElementById('routine-hide-widget');
  const timeMode = document.getElementById('routine-time-mode');
  const timeField = document.getElementById('routine-time-field');
  const timedOptions = document.querySelectorAll('.routine-timed-option');

  function todayKey() {
    return new Date().toISOString().slice(0, 10);
  }

  function readJson(key, fallback) {
    try { return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback)); } catch (e) { return fallback; }
  }

  function writeJson(key, value) {
    localStorage.setItem(key, JSON.stringify(value));
    window.dispatchEvent(new Event('nv-routine-updated'));
    window.NVRoutine?.refreshUI?.();
  }

  function escapeHtml(value) {
    return String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    }[char]));
  }

  function isLegacyDefaultPlan(activities) {
    const legacyNames = ['Acordar', 'Café da manhã', 'Escola', 'Atividade', 'Brincar', 'Banho', 'Dormir'];
    return activities.length === legacyNames.length
      && activities.every((item, index) => item.name === legacyNames[index] && !item.completed && item.order === undefined);
  }

  function loadRoutine() {
    const saved = readJson(ROUTINE_KEY, null);
    if (saved?.day === todayKey() && Array.isArray(saved.activities)) {
      if (isLegacyDefaultPlan(saved.activities)) {
        writeJson(ROUTINE_KEY, { day: todayKey(), activities: [] });
        return [];
      }
      return saved.activities;
    }
    writeJson(ROUTINE_KEY, { day: todayKey(), activities: [] });
    return [];
  }

  function saveRoutine(activities) {
    writeJson(ROUTINE_KEY, { day: todayKey(), activities });
  }

  function loadSettings() {
    return readJson(ROUTINE_SETTINGS_KEY, { hidden: false, theme: 'auto' });
  }

  function saveSettings(settings) {
    writeJson(ROUTINE_SETTINGS_KEY, settings);
  }

  function loadRoutineHistory() {
    return readJson(ROUTINE_HISTORY_KEY, []);
  }

  function saveRoutineHistory(history) {
    writeJson(ROUTINE_HISTORY_KEY, history.slice(0, 240));
  }

  function minutesOf(time) {
    if (!time) return null;
    const [hour, minute] = time.split(':').map(Number);
    if (Number.isNaN(hour) || Number.isNaN(minute)) return null;
    return hour * 60 + minute;
  }

  function targetMs(activity) {
    if (!activity?.time) return null;
    const [hour, minute] = String(activity.time).split(':').map(Number);
    if (Number.isNaN(hour) || Number.isNaN(minute)) return null;
    const d = new Date();
    d.setHours(hour, minute, 0, 0);
    return d.getTime();
  }

  function nowMs() { return Date.now(); }

  function sortedActivities() {
    return loadRoutine().sort((a, b) => {
      const at = targetMs(a);
      const bt = targetMs(b);
      if (at === null && bt === null) return (a.order || 0) - (b.order || 0);
      if (at === null) return 1;
      if (bt === null) return -1;
      return at - bt;
    });
  }

  function getRoutineSnapshot() {
    const activities = sortedActivities();
    const now = nowMs();
    const timed = activities.filter((item) => targetMs(item) !== null);
    let current = timed.filter((item) => targetMs(item) <= now && !item.completed).at(-1)
      || activities.find((item) => !item.completed && targetMs(item) === null)
      || null;
    if (!current) current = activities.find((item) => !item.completed) || null;
    const next = activities.find((item) => !item.completed && item.id !== current?.id && (targetMs(item) ?? Infinity) > now)
      || activities.find((item) => !item.completed && item.id !== current?.id)
      || null;
    return { activities, current, next };
  }

  function formatUntil(activity) {
    const target = targetMs(activity);
    if (target === null) return '⏳ Sem horário definido';
    let diff = Math.floor((target - nowMs()) / 1000);
    if (diff <= 0) return '⏳ Agora';
    const h = Math.floor(diff / 3600);
    const m = Math.floor((diff % 3600) / 60);
    const s = diff % 60;
    if (h > 0) return `⏳ Faltam ${h}h ${String(m).padStart(2,'0')}m`;
    if (m > 0) return `⏳ Faltam ${m}m ${String(s).padStart(2,'0')}s`;
    return `⏳ Faltam ${s}s`;
  }

  function inferTheme() {
    const settings = loadSettings();
    if (settings.theme && settings.theme !== 'auto') return settings.theme;
    const config = readJson('nv-tablet-config', {});
    const text = `${config.interesses || ''} ${config.hiperfocos || ''} ${config.brincadeiras || ''} ${config.personagens || ''}`.toLowerCase();
    const rules = [
      ['dinossauros', ['dinossauro', 'dino', 'jurassic']],
      ['carros', ['carro', 'onibus', 'ônibus', 'caminhao', 'caminhão', 'moto']],
      ['princesas', ['princesa', 'coroa', 'realeza']],
      ['animais', ['animal', 'cachorro', 'gato', 'pet']],
      ['espaco', ['espaco', 'espaço', 'foguete', 'planeta']],
      ['flores', ['flor', 'jardim']],
      ['unicornio', ['unicornio', 'unicórnio']],
    ];
    return rules.find(([, words]) => words.some((word) => text.includes(word)))?.[0] || 'confetes';
  }

  function themeIcon(theme) {
    return {
      dinossauros: '🦖',
      carros: '🚗',
      flores: '🌸',
      estrelas: '⭐',
      unicornio: '🦄',
      espaco: '🚀',
      animais: '🐶',
      confetes: '🎉',
      princesas: '👑',
    }[theme] || '🎉';
  }

  function guessIconFromName(rawName) {
    const text = (rawName || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');
    if (!text.trim()) return '';
    const rules = [
      [/\b(banho|banhar|banheira|chuveiro|ducha|lavar|lavar cabelo|tomar banho)\b/, '🛁'],
      [/\b(escovar|escova|dente|dentes|dental|escovar os dentes|dentinhos|dente)\b/, '🪥'],
      [/\b(casa|lar|chegar em casa|voltar pra casa|para casa)\b/, '🏠'],
      [/\b(dormir|sono|cama|soneca|cochilo|deitar)\b/, '🛏️'],
      [/\b(acordar|despertar|levantar|intervalo)\b/, '⏰'],
      [/\b(dever|deveres|tarefa|licao|liçao|estudo|estudar|estudos|li(c|ç)ao de casa|prova|leitura|ler|livro|dever|atividade|palestra)\b/, '📚'],
      [/\b(aula|professor|professora|escola|colegio|colégio|faculdade|prof|profa)\b/, '👩‍🏫'],
      [/\b(laborat(o|ó)rio|ci(e|ê)ncia|ci(e|ê)ncias|experimento|qu(i|í)mica|biologia|f(i|í)sica)\b/, '🧠'],
      [/\b(matem(a|á)tica|conta|contas|n(u|ú)mero|n(u|ú)meros)\b/, '🔢'],
      [/\b(portugu(e|ê)s|reda(c|ç)(a|ã)o|escrever|escrita)\b/, '✍️'],
      [/\b(ingl(e|ê)s|espanhol|idioma|franc(ê|e)s|francais|aleman|alem(ã|a)o|japones|japon(ê|e)s|chines|chino|italiano)\b/, '🗣️'],
      [/\b(desenhar|desenho|pintar|pintura|colorir|arte|artes|giz)\b/, '🎨'],
      [/\b(m(u|ú)sica|musical|cantar|tocar|piano|viol(a|ã)o|guitarra|teclado|piano)\b/, '🎵'],
      [/\b(brincar|brincadeira|brinquedo|jogos|jogar|video ?game|game|console|jogo|jogos|playstation|xbox|ps|ps5)\b/, '🎮'],
      [/\b(parque|playground|escorregar|balan(c|ç)o)\b/, '🛝'],
      [/\b(correr|corrida|caminhar|caminhada|andar|passear|passeio)\b/, '🚶'],
      [/\b(esporte|futebol|bola|basquete|volei)\b/, '⚽'],
      [/\b(natacao|nata(c|ç)(a|ã)o|nadar|piscina|praia|mar|oceano)\b/, '🏊'],
      [/\b(bicicleta|bike|pedalar|ciclismo)\b/, '🚴'],
      [/\b(yoga|alongar|alongamento|medita(c|ç)(a|ã)o|meditar|respirar|respira(ç|c)(ã|a)o|relaxar)\b/, '🧘'],
      [/\b(comer|comida|refei(c|ç)(a|ã)o|almo(c|ç)o|almo(c|ç)ar|janta|jantar|lanche|lanchinho|recreio|merenda|lanchar)\b/, '🍎'],
      [/\b(caf(e|é)|caf(e|é) da manh(a|ã)|desjejum)\b/, '☕'],
      [/\b(agua|(a|á)gua|beber|hidratar|garafa)\b/, '💧'],
      [/\b(rem(e|é)dio|medica(c|ç)(a|ã)o|medicamento|comprimido|cura)\b/, '💊'],
      [/\b(m(e|é)dico|consulta|dentista|hospital)\b/, '🏥'],
      [/\b(terapia|psic(o|ó)logo|psicologa|fono|fonoaudi(o|ó)loga|to|terapeuta|psi|psico)\b/, '🧩'],
      [/\b(filme|cinema|assistir|tv|televis(a|ã)o|serie|s(e|é)rie|desenho animado)\b/, '📺'],
      [/\b(computador|pc|notebook|tablet|celular|tela|dispositivo)\b/, '💻'],
      [/\b(roupa|vestir|trocar de roupa|uniforme)\b/, '👕'],
      [/\b(banheiro|xixi|coco|c(o|ó)co|penico|vaso|mijar|mijo|banheira)\b/, '🚽'],
      [/\b(compras|mercado|supermercado|loja|shopping|centro comercial)\b/, '🛒'],
      [/\b(carro|dirigir|trajeto|viagem|viajar|carrinho)\b/, '🚗'],
      [/\b(onibus|(o|ô)nibus|transporte|metro|metrô)\b/, '🚌'],
      [/\b(arrumar|organizar|limpar|limpeza|faxina)\b/, '🧹'],
      [/\b(cachorro|cao|c(a|ã)o|gato|pet|animal|animais)\b/, '🐶'],
      [/\b(festa|aniversario|anivers(a|á)rio|comemorar|lanche coletivo|piquenique|pequinique|churrasco|parque|passeio|passear|pra(ç|c)a|pra(c|ç)inha)\b/, '🎉'],
      [/\b(presente|surpresa)\b/, '🎁'],
      [/\b(amigo|amigos|amiga|amigas|familia|fam(i|í)lia|mam(a|ã)e|m(ã|a)e)|pai|av(ó|o)|av(ó|o)|irm(a|ã)o|irma|tio|tia|padrasto|madrasta\b/, '👨‍👩‍👧'],
      [/\b(igreja|ora(c|ç)(a|ã)o|rezar|culto|deus|jesus|cristo)\b/, '⛪'],
    ];
    const found = rules.find(([re]) => re.test(text));
    return found ? found[1] : '';
  }

  function speakRoutine(text) {
    if (!('speechSynthesis' in window)) return;
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'pt-BR';
    window.speechSynthesis.speak(utterance);
  }

  function celebrateRoutine(message = '⭐ Atividade concluída!') {
    const celebration = document.getElementById('nv-timer-celebration');
    if (!celebration) return;
    const symbol = themeIcon(inferTheme());
    celebration.innerHTML = '';
    celebration.removeAttribute('hidden');
    celebration.classList.add('active');
    for (let i = 0; i < 24; i += 1) {
      const drop = document.createElement('span');
      drop.className = 'rain-item';
      drop.textContent = symbol;
      drop.style.left = `${Math.random() * 94}%`;
      drop.style.animationDelay = `${Math.random() * 1.4}s`;
      drop.style.fontSize = `${18 + Math.random() * 22}px`;
      celebration.appendChild(drop);
    }
    const card = document.createElement('div');
    card.className = 'celebration-message';
    card.innerHTML = `<strong>${message}</strong><p>Vamos para a próxima atividade!</p>`;
    celebration.appendChild(card);
    setTimeout(() => {
      celebration.classList.remove('active');
      celebration.setAttribute('hidden', '');
      celebration.innerHTML = '';
    }, 5200);
  }

  function completeActivity(id, automatic = false) {
    const activities = loadRoutine();
    const item = activities.find((activity) => activity.id === id);
    if (!item || item.completed) return;
    item.completed = true;
    item.completedAt = new Date().toISOString();
    const completedTime = new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
    const history = loadRoutineHistory();
    history.unshift({
      id: item.id,
      name: item.name,
      icon: item.icon,
      time: item.time,
      completedAt: completedTime,
      date: todayKey(),
      automatic,
      type: 'completed',
    });
    saveRoutineHistory(history);
    saveRoutine(activities);
    speakRoutine(`${item.name} concluído. Muito bem!`);
    celebrateRoutine('🎉 Muito bem!');
    renderRoutine();
  }

  function removeActivity(id) {
    saveRoutine(loadRoutine().filter((item) => item.id !== id));
    renderRoutine();
  }

  function notify(title, body) {
    try {
      if ('Notification' in window && Notification.permission === 'granted') {
        new Notification(title, { body, icon: '/icon.svg', tag: `nv-${title}` });
      }
    } catch (e) {}
  }

  function fireAlarm(item, type) {
    const history = loadRoutineHistory();
    let label;
    if (type === 'countdown') {
      const target = targetMs(item);
      const diffSec = Math.max(0, Math.floor((target - nowMs()) / 1000));
      if (diffSec < 60) {
        label = `Falta menos de um minuto para ${item.name}`;
      } else {
        const diffMin = Math.round(diffSec / 60);
        const h = Math.floor(diffMin / 60);
        const m = diffMin % 60;
        let tempo;
        if (h > 0 && m > 0) tempo = `${h} ${h === 1 ? 'hora' : 'horas'} e ${m} ${m === 1 ? 'minuto' : 'minutos'}`;
        else if (h > 0) tempo = `${h} ${h === 1 ? 'hora' : 'horas'}`;
        else tempo = `${m} ${m === 1 ? 'minuto' : 'minutos'}`;
        label = `Faltam ${tempo} para ${item.name}`;
      }
    } else {
      label = `Hora de ${item.name}`;
    }
    history.unshift({
      id: item.id,
      name: item.name,
      icon: item.icon,
      time: item.time,
      completedAt: new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }),
      date: todayKey(),
      type,
      label,
    });
    saveRoutineHistory(history);
    speakRoutine(type === 'countdown' ? label : `${item.name}. Vamos para a próxima atividade!`);
    celebrateRoutine(type === 'countdown' ? '⏳ Prepare-se!' : `${item.icon || '📍'} Hora de ${item.name}!`);
    notify(type === 'countdown' ? '⏳ Prepare-se' : `${item.icon || '📍'} ${item.name}`, label);
  }

  // Tick com precisão de segundo: usa Date.now() comparando com o alvo absoluto.
  function tickRoutine() {
    const activities = loadRoutine();
    const now = nowMs();
    let changed = false;

    activities.forEach((item) => {
      const target = targetMs(item);
      if (target === null || item.completed) return;
      const countdownMs = Number(item.countdown) * 60 * 1000;
      if (countdownMs > 0 && !item.countdownFired && now >= target - countdownMs && now < target) {
        item.countdownFired = true;
        changed = true;
        fireAlarm(item, 'countdown');
      }
      // Dispara assim que o relógio do dispositivo atinge o horário (precisão de segundo)
      if (item.alarm && !item.alarmFired && now >= target) {
        item.alarmFired = true;
        changed = true;
        fireAlarm(item, 'alarm');
      }
    });

    if (changed) saveRoutine(activities);
    renderRoutine();
  }

  function renderEmptyState() {
    routineList.innerHTML = `
      <div class="routine-empty">
        <strong>Seu plano está vazio.</strong>
        <span>Adicione as atividades na ordem em que elas devem aparecer para a criança.</span>
      </div>
    `;
  }

  function renderRoutine() {
    const { activities, current, next } = getRoutineSnapshot();
    const done = activities.filter((item) => item.completed).length;
    const total = activities.length;
    const progress = total ? Math.round((done / total) * 100) : 0;

    routineCurrent.textContent = current ? `${current.icon || '📍'} ${current.name}` : 'Nenhuma atividade atual';
    routineNext.textContent = next ? `${next.icon || '⏳'} ${next.name}` : total ? 'Plano finalizado' : 'Adicione a primeira atividade';
    routineNextTime.textContent = next ? formatUntil(next) : total ? '🎉 Tudo concluído' : '⏳ Sem atividades no plano';
    routineProgressLabel.textContent = `${done} de ${total} concluídas`;
    routineProgressBar.style.width = `${progress}%`;

    if (!total) {
      renderEmptyState();
    } else {
      routineList.innerHTML = '';
      activities.forEach((item) => {
        const isCurrent = item.id === current?.id && !item.completed;
        const row = document.createElement('article');
        row.className = `routine-item ${item.completed ? 'done' : ''} ${isCurrent ? 'current' : ''}`;
        row.style.setProperty('--routine-color', item.color || '#5b8def');
        const status = item.completed ? '✅ Concluída' : isCurrent ? '🔵 Agora' : '⏳ Próxima';
        row.innerHTML = `
          <div class="routine-icon" aria-hidden="true">${escapeHtml(item.icon || '📍')}</div>
          <div class="routine-info">
            <div>
              <strong>${escapeHtml(item.name)}</strong>
              <span>${escapeHtml(item.time || 'Sem horário')} • ${status}</span>
            </div>
            ${item.notes ? `<p>${escapeHtml(item.notes)}</p>` : ''}
            <div class="routine-countdown">
              <i style="width:${isCurrent || item.completed ? '100' : '30'}%"></i>
            </div>
          </div>
          <div class="routine-actions">
            <button type="button" data-complete="${item.id}" aria-label="Concluir ${escapeHtml(item.name)}">✓</button>
            <button type="button" data-remove="${item.id}" aria-label="Remover ${escapeHtml(item.name)}">×</button>
          </div>
        `;
        routineList.appendChild(row);
      });
    }

    routineList.querySelectorAll('[data-complete]').forEach((button) => {
      button.addEventListener('click', () => completeActivity(button.dataset.complete));
    });
    routineList.querySelectorAll('[data-remove]').forEach((button) => {
      button.addEventListener('click', () => removeActivity(button.dataset.remove));
    });

    const history = loadRoutineHistory();
    const todayDone = history.filter((entry) => entry.date === todayKey() && entry.type === 'completed');
    const weekAgo = Date.now() - 7 * 24 * 60 * 60 * 1000;
    const weekDone = history.filter((entry) => entry.type === 'completed' && new Date(entry.date).getTime() >= weekAgo);
    const peak = todayDone.reduce((acc, entry) => {
      const hour = (entry.completedAt || '').slice(0, 2);
      if (!hour) return acc;
      acc[hour] = (acc[hour] || 0) + 1;
      return acc;
    }, {});
    const peakHour = Object.entries(peak).sort(([, a], [, b]) => b - a)[0]?.[0];
    routineReportDone.textContent = String(todayDone.length);
    routineReportRate.textContent = `${progress}%`;
    routineReportPeak.textContent = peakHour ? `${peakHour}:00` : '--:--';
    routineReportWeek.textContent = String(weekDone.length);

    routineTheme.value = loadSettings().theme || 'auto';
    window.NVRoutine?.refreshUI?.();
  }

  function updateTimeMode() {
    const hasTime = timeMode.value === 'time';
    timeField.hidden = false; // sempre visível para permitir digitar direto
    timedOptions.forEach((field) => { field.hidden = !hasTime; });
    if (!hasTime) {
      document.getElementById('routine-time').value = '';
      document.getElementById('routine-alarm').value = 'false';
    }
  }

  timeMode?.addEventListener('change', updateTimeMode);

  // Se o usuário digitar/escolher um horário direto, já assume "Com horário".
  document.getElementById('routine-time')?.addEventListener('input', (event) => {
    if (event.target.value && timeMode.value !== 'time') {
      timeMode.value = 'time';
      updateTimeMode();
    }
  });

  const routineNameInput = document.getElementById('routine-name');
  const routineIconInput = document.getElementById('routine-icon');
  routineNameInput?.addEventListener('input', () => {
    const guess = guessIconFromName(routineNameInput.value);
    if (routineIconInput) routineIconInput.placeholder = guess || '📍';
  });

  routineForm?.addEventListener('submit', (event) => {
    event.preventDefault();
    const activities = loadRoutine();
    const hasTime = timeMode.value === 'time';
    activities.push({
      id: `routine-${Date.now()}`,
      order: activities.length,
      name: document.getElementById('routine-name').value.trim(),
      time: hasTime ? document.getElementById('routine-time').value : '',
      icon: document.getElementById('routine-icon').value.trim() || guessIconFromName(document.getElementById('routine-name').value) || '📍',
      color: document.getElementById('routine-color').value,
      notes: document.getElementById('routine-notes').value.trim(),
      alarm: hasTime && document.getElementById('routine-alarm').value === 'true',
      countdown: hasTime ? 5 : 0,
      completed: false,
      completedAt: null,
      alarmFired: false,
      countdownFired: false,
    });
    saveRoutine(activities);
    routineForm.reset();
    document.getElementById('routine-color').value = '#5b8def';
    updateTimeMode();
    renderRoutine();
  });

  routineTheme?.addEventListener('change', () => {
    saveSettings({ ...loadSettings(), theme: routineTheme.value });
    renderRoutine();
  });

  routineShowWidget?.addEventListener('click', () => {
    saveSettings({ ...loadSettings(), hidden: false });
    window.NVRoutine?.refreshUI?.();
  });

  routineHideWidget?.addEventListener('click', () => {
    saveSettings({ ...loadSettings(), hidden: true });
    window.NVRoutine?.refreshUI?.();
  });

  updateTimeMode();
  renderRoutine();
  // Pede permissão de notificação para alertas no horário exato
  if ('Notification' in window && Notification.permission === 'default') {
    try { Notification.requestPermission(); } catch (e) {}
  }
  // 500ms mantém o cronômetro "Faltam Xs" preciso na própria página /dia.
  // A checagem global de alarmes vive no Base.astro e usa as mesmas flags
  // (alarmFired/countdownFired) gravadas em localStorage, então não há
  // disparo duplicado.
  setInterval(tickRoutine, 500);
</script>

