<style>
  .day-page { padding: 28px 0 72px; }

  /* ── Header ─────────────────────────────────────────────────────────────── */
  .day-head {
    display: flex; justify-content: space-between; align-items: flex-end;
    gap: 20px; flex-wrap: wrap; margin-bottom: 24px;
