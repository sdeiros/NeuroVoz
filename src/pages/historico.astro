    const typedWordTop = countBy(typedWordEvents, "word").slice(0, 8);
    const totalInteractions = history.length + alphaEvents.length;
    const combinedVocabulary = new Set([
      ...history.map((h) => h.label),
      ...typedWordEvents.map((e) => e.word),
