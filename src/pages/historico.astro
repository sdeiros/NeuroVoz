  window.addEventListener("nv:routine-history:updated", renderRoutineHistory);
  window.addEventListener("nv:task:completed", renderRoutineHistory);
  window.addEventListener("storage", (e) => {
    if (e.key === "nv-routine-history") renderRoutineHistory();
    if (e.key === "neurovoz.tasks.v1") {
      // Tarefas do Plano do Dia atualizadas em outra aba — re-sincroniza
      renderRoutineHistory();
    }
    if (e.key === "nv-history") {
      history = load();
      renderDashboard();
      renderTimeline();
    }
  });

