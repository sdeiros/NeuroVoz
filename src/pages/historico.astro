---
import Base from "../layouts/Base.astro";
import { categories } from "../data/vocabulary";
---

<Base
  title="Histórico e Dashboard — NeuroVoz"
  description="Linha do tempo de comunicação, dashboard pedagógico com gráficos e relatório exportável. Tudo armazenado localmente."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Histórico & Dashboard</span>
      <h1 class="page-title">Acompanhe a evolução comunicativa</h1>
      <p class="page-lead">
        Registro local de cada interação no comunicador, com indicadores
        automáticos e relatório pedagógico. Nenhum dado sai do seu dispositivo.
      </p>

      <div class="student-info" id="student-info">
        <div class="si-left">
          <strong id="student-name">—</strong>
          <span class="si-meta" id="student-age">Nenhum aluno configurado</span>
          <span class="si-meta" id="student-turma"></span>
          <span class="si-meta" id="student-note"></span>
        </div>
        <div class="si-actions">
          <button id="btn-config-student" class="btn btn-ghost"
            >Configurar Aluno</button
          >
        </div>
      </div>
    </div>
  </section>

  <!-- ── Modal: Configurar/Editar Aluno ─────────────────────────────────── -->
  <div id="student-modal" class="sm-overlay" hidden aria-modal="true" role="dialog" aria-labelledby="sm-title">
    <div class="sm-backdrop" id="sm-backdrop"></div>
    <div class="sm-sheet">
      <div class="sm-header">
        <div class="sm-header-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
        </div>
        <div>
          <h2 id="sm-title" class="sm-title">Dados do Aluno</h2>
          <p class="sm-subtitle">Essas informações aparecem nos relatórios exportados.</p>
        </div>
        <button class="sm-close" id="sm-close" aria-label="Fechar" type="button">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <form id="sm-form" class="sm-body" novalidate autocomplete="off">
        <div class="sm-field" id="sm-field-name">
          <label class="sm-label" for="sm-input-name">
            Nome completo <span class="sm-required" aria-hidden="true">*</span>
          </label>
          <div class="sm-input-wrap">
            <span class="sm-input-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            </span>
            <input class="sm-input" id="sm-input-name" type="text" placeholder="Ex: Ana Beatriz Silva" maxlength="80" required aria-required="true"/>
          </div>
          <p class="sm-error" id="sm-error-name" aria-live="polite" hidden>O nome é obrigatório.</p>
        </div>
        <div class="sm-row">
          <div class="sm-field" id="sm-field-age">
            <label class="sm-label" for="sm-input-age">
              Idade <span class="sm-required" aria-hidden="true">*</span>
            </label>
            <div class="sm-input-wrap">
              <span class="sm-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              </span>
              <input class="sm-input" id="sm-input-age" type="number" placeholder="Ex: 8" min="1" max="30" required aria-required="true"/>
              <span class="sm-input-suffix">anos</span>
            </div>
            <p class="sm-error" id="sm-error-age" aria-live="polite" hidden>Informe a idade em números.</p>
          </div>
          <div class="sm-field">
            <label class="sm-label" for="sm-input-turma">Turma / Série</label>
            <div class="sm-input-wrap">
              <span class="sm-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              </span>
              <input class="sm-input" id="sm-input-turma" type="text" placeholder="Ex: 3º ano A" maxlength="40"/>
            </div>
          </div>
        </div>
        <div class="sm-field">
          <label class="sm-label" for="sm-input-obs">Observações</label>
          <textarea class="sm-input sm-textarea" id="sm-input-obs" placeholder="Informações relevantes para o relatório pedagógico (opcional)..." rows="3" maxlength="300"></textarea>
          <p class="sm-hint">Máx. 300 caracteres</p>
        </div>
        <div class="sm-footer">
          <button type="button" class="sm-btn sm-btn-ghost" id="sm-cancel">Cancelar</button>
          <button type="submit" class="sm-btn sm-btn-primary" id="sm-submit">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            Salvar dados
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Modal: Aluno obrigatório para exportar ──────────────────────────── -->
  <div id="student-required-modal" class="sm-overlay" hidden aria-modal="true" role="alertdialog" aria-labelledby="srm-title">
    <div class="sm-backdrop" id="srm-backdrop"></div>
    <div class="sm-sheet sm-sheet-sm">
      <div class="sm-notice-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
        </svg>
      </div>
      <h2 id="srm-title" class="sm-title" style="text-align:center;margin-top:12px">Dados incompletos</h2>
      <p class="sm-subtitle" style="text-align:center;margin-top:6px">Para exportar o relatório é preciso informar o <strong>nome</strong> e a <strong>idade</strong> do aluno.</p>
      <div class="sm-footer sm-footer-center" style="margin-top:24px">
        <button type="button" class="sm-btn sm-btn-ghost" id="btn-modal-close">Agora não</button>
        <button type="button" class="sm-btn sm-btn-primary" id="btn-modal-config">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          Preencher dados
        </button>
      </div>
    </div>
  </div>

  <!-- ── Modal: Confirmação de limpeza ──────────────────────────────────── -->
  <div id="clear-confirm-modal" class="sm-overlay" hidden aria-modal="true" role="alertdialog" aria-labelledby="ccm-title">
    <div class="sm-backdrop" id="ccm-backdrop"></div>
    <div class="sm-sheet sm-sheet-sm">
      <div class="sm-notice-icon sm-notice-icon--danger" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 6h18M8 6V4h8v2M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
          <path d="M10 11v6M14 11v6"/>
        </svg>
      </div>
      <h2 id="ccm-title" class="sm-title" style="text-align:center;margin-top:12px">Limpar todo o histórico?</h2>
      <p class="sm-subtitle" style="text-align:center;margin-top:6px">Essa ação <strong>não pode ser desfeita</strong>. Todo o histórico de comunicação, rotina e tarefas do Plano do Dia serão apagados permanentemente.</p>
      <div class="sm-footer sm-footer-center" style="margin-top:24px">
        <button type="button" class="sm-btn sm-btn-ghost" id="ccm-cancel">Cancelar</button>
        <button type="button" class="sm-btn sm-btn-danger" id="ccm-confirm">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
          Sim, limpar tudo
        </button>
      </div>
    </div>
  </div>

  <!-- ── Modal: Alerta genérico ─────────────────────────────────────────── -->
  <div id="alert-modal" class="sm-overlay" hidden aria-modal="true" role="alertdialog" aria-labelledby="am-title">
    <div class="sm-backdrop" id="am-backdrop"></div>
    <div class="sm-sheet sm-sheet-sm">
      <div class="sm-notice-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/>
        </svg>
      </div>
      <h2 id="am-title" class="sm-title" style="text-align:center;margin-top:12px">Aviso</h2>
      <p id="am-msg" class="sm-subtitle" style="text-align:center;margin-top:6px"></p>
      <div class="sm-footer sm-footer-center" style="margin-top:24px">
        <button type="button" class="sm-btn sm-btn-primary" id="am-ok">Entendi</button>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <!-- Indicadores rápidos -->
      <div class="grid grid-4" id="kpis">
        <div class="kpi card">
          <span class="kpi-num" id="kpi-total">0</span><span class="kpi-label"
            >Interações</span>
        </div>
        <div class="kpi card">
          <span class="kpi-num" id="kpi-today">0</span><span class="kpi-label"
            >Hoje</span>
        </div>
        <div class="kpi card">
          <span class="kpi-num" id="kpi-words">0</span><span class="kpi-label"
            >Palavras Distintas (total)</span>
        </div>
        <div class="kpi card">
          <span class="kpi-num" id="kpi-top">—</span><span class="kpi-label"
            >Mais Usada</span>
        </div>
      </div>
      <p class="kpi-note" id="kpi-vocab-note">
        Total de palavras distintas: 0 (Histórico: 0, Formação de Palavras: 0)
      </p>

      <div class="toolbar">
        <div class="filters">
          <label class="ctrl"
            ><span>Dia</span><input type="date" id="filter-date" /></label
          >
          <label class="ctrl"
            ><span>Categoria</span>
            <select id="filter-cat">
              <option value="all">Todas</option>
              {categories.map((c) => <option value={c.id}>{c.name}</option>)}
            </select>
          </label>
          <label class="ctrl"
            ><span>Buscar</span><input
              type="search"
              id="filter-search"
              placeholder="palavra..."
            /></label
          >
        </div>
        <div class="actions">
          <button class="btn btn-ghost" id="btn-csv">Exportar CSV</button>
          <button class="btn btn-ghost" id="btn-pdf">Relatório PDF</button>
          <button class="btn btn-ghost danger" id="btn-clear"
            >Limpar Histórico</button
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Dashboard -->
  <section class="section-sm">
    <div class="container">
      <h2 class="section-title" style="font-size:1.6rem">
        Dashboard Pedagógico
      </h2>
      <div class="dash-grid">
        <div class="card chart-card">
          <h3>Emoções mais utilizadas</h3>
          <div class="bars" id="chart-emocoes"></div>
        </div>
        <div class="card chart-card">
          <h3>Necessidades mais comunicadas</h3>
          <div class="bars" id="chart-necessidades"></div>
        </div>
        <div class="card chart-card">
          <h3>Comunicação por período</h3>
          <div class="periods" id="chart-periodo"></div>
        </div>
        <div class="card chart-card">
          <h3>Palavras mais utilizadas</h3>
          <ol class="ranking" id="chart-ranking"></ol>
        </div>
      </div>
    </div>
  </section>

  <section class="section-sm">
    <div class="container">
      <h2 class="section-title" style="font-size:1.6rem">Alfabeto</h2>
      <div class="dash-grid">
        <div class="card chart-card">
          <h3>Letras acessadas</h3>
          <p class="kpi-num" id="alpha-letters-used">0</p>
        </div>
        <div class="card chart-card">
          <h3>Palavras reproduzidas</h3>
          <p class="kpi-num" id="alpha-words-used">0</p>
        </div>
        <div class="card chart-card">
          <h3>Exemplos ouvidos</h3>
          <p class="kpi-num" id="alpha-examples-used">0</p>
        </div>
        <div class="card chart-card">
          <h3>Letras distintas</h3>
          <p class="kpi-num" id="alpha-letters-distinct">0</p>
        </div>
      </div>
      <div class="card chart-card" style="margin-top:18px;">
        <h3>Letras mais usadas</h3>
        <ol class="ranking" id="alpha-top"></ol>
      </div>
      <div class="card chart-card" style="margin-top:18px;">
        <h3>Formação de Palavras</h3>
        <div class="dash-grid" style="grid-template-columns: 1fr 1fr; gap:14px; margin-top:12px;">
          <div class="card chart-card" style="padding:16px;">
            <h4 style="font-size:1rem; margin-bottom:10px;">Palavras escritas</h4>
            <p class="kpi-num" id="alpha-words-written">0</p>
          </div>
          <div class="card chart-card" style="padding:16px;">
            <h4 style="font-size:1rem; margin-bottom:10px;">Palavras distintas</h4>
            <p class="kpi-num" id="alpha-typed-distinct">0</p>
          </div>
        </div>
        <div style="margin-top:16px;">
          <h4 style="font-size:1rem; margin-bottom:10px;">Mais escritas</h4>
          <ol class="ranking" id="alpha-typed-top"></ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Rotina do Dia -->
  <section class="section-sm">
    <div class="container">
      <h2 class="section-title" style="font-size:1.6rem">Rotina do Dia</h2>
      <div class="grid grid-4" id="routine-kpis">
        <div class="kpi card"><span class="kpi-num" id="routine-kpi-total">0</span><span class="kpi-label">Tarefas no dia</span></div>
        <div class="kpi card"><span class="kpi-num" id="routine-kpi-done">0</span><span class="kpi-label">Concluídas</span></div>
        <div class="kpi card"><span class="kpi-num" id="routine-kpi-alarms">0</span><span class="kpi-label">Alarmes disparados</span></div>
        <div class="kpi card"><span class="kpi-num" id="routine-kpi-countdowns">0</span><span class="kpi-label">Contagens regressivas</span></div>
      </div>
      <!-- Barra de progresso do dia -->
      <div class="routine-progress-wrap" id="routine-progress-wrap" style="margin-top:14px;display:none">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <span style="font-size:0.88rem;font-weight:700;color:var(--text-soft)">Progresso do dia</span>
          <span id="routine-progress-pct" style="font-size:0.88rem;font-weight:800;color:var(--blue)">0%</span>
        </div>
        <div style="height:10px;border-radius:999px;background:var(--bg-alt);overflow:hidden">
          <span id="routine-progress-bar" style="display:block;height:100%;width:0%;background:linear-gradient(90deg,#5b8def,#5cc9b0);border-radius:999px;transition:width .6s ease"></span>
        </div>
      </div>
      <!-- Tarefas pendentes do dia -->
      <div id="routine-pending-section" style="margin-top:18px;display:none">
        <h3 style="font-size:1rem;color:var(--text-soft);margin-bottom:10px">⏳ Pendentes hoje</h3>
        <div id="routine-pending-list" class="timeline-list"></div>
      </div>
      <div id="routine-history-list" class="timeline-list" style="margin-top:18px"></div>
      <p id="routine-history-empty" class="empty-state">Nenhuma atividade da rotina registrada ainda. Use o <a href="/dia">Plano do Dia</a> para começar.</p>
    </div>
  </section>

  <!-- Linha do tempo -->
  <section class="section-sm">
    <div class="container">
      <h2 class="section-title" style="font-size:1.6rem">Linha do Tempo</h2>
      <div id="timeline" class="timeline-list"></div>
      <p id="empty-state" class="empty-state">
        Nenhuma interação registrada ainda. Use o <a href="/tablet"
          >Tablet Comunicador</a
        > para começar a registrar.
      </p>
    </div>
  </section>


</Base>

<script define:vars={{ categories }}>
  // Student data: load/save to localStorage under 'nv-student'
  function loadStudent() {
    try {
      return JSON.parse(localStorage.getItem("nv-student") || "null");
    } catch (e) {
      return null;
    }
  }
  function saveStudent(s) {
    localStorage.setItem("nv-student", JSON.stringify(s));
    renderStudent();
  }
  // ── Helpers de modal genérico ─────────────────────────────────────────────
  function openModal(id) {
    const el = document.getElementById(id);
    if (!el) return;
    el.removeAttribute("hidden");
    el.classList.add("sm-entering");
    requestAnimationFrame(() => el.classList.remove("sm-entering"));
    // foco no primeiro elemento focável
    setTimeout(() => {
      const first = el.querySelector("button, input, textarea, select, [tabindex]");
      if (first) first.focus();
    }, 60);
  }
  function closeModal(id) {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.add("sm-leaving");
    el.addEventListener("animationend", () => {
      el.setAttribute("hidden", "");
      el.classList.remove("sm-leaving");
    }, { once: true });
  }
  function showAlert(msg) {
    document.getElementById("am-msg").textContent = msg;
    openModal("alert-modal");
  }

  // ── Modal de aluno ────────────────────────────────────────────────────────
  function openStudentModal() {
    const cur = loadStudent() || {};
    document.getElementById("sm-input-name").value = cur.name || "";
    document.getElementById("sm-input-age").value  = cur.age  || "";
    document.getElementById("sm-input-turma").value = cur.turma || "";
    document.getElementById("sm-input-obs").value  = cur.observacao || "";
    // limpa erros anteriores
    ["sm-error-name", "sm-error-age"].forEach(id => document.getElementById(id).hidden = true);
    ["sm-field-name", "sm-field-age"].forEach(id => document.getElementById(id).classList.remove("sm-field--error"));
    openModal("student-modal");
    setTimeout(() => document.getElementById("sm-input-name").focus(), 80);
  }

  document.getElementById("sm-form").addEventListener("submit", (e) => {
    e.preventDefault();
    const nameVal = document.getElementById("sm-input-name").value.trim();
    const ageVal  = document.getElementById("sm-input-age").value.trim();
    let valid = true;

    if (!nameVal) {
      document.getElementById("sm-error-name").hidden = false;
      document.getElementById("sm-field-name").classList.add("sm-field--error");
      document.getElementById("sm-input-name").focus();
      valid = false;
    } else {
      document.getElementById("sm-error-name").hidden = true;
      document.getElementById("sm-field-name").classList.remove("sm-field--error");
    }

    if (!ageVal || !/^[0-9]+$/.test(ageVal)) {
      document.getElementById("sm-error-age").hidden = false;
      document.getElementById("sm-field-age").classList.add("sm-field--error");
      if (valid) document.getElementById("sm-input-age").focus();
      valid = false;
    } else {
      document.getElementById("sm-error-age").hidden = true;
      document.getElementById("sm-field-age").classList.remove("sm-field--error");
    }

    if (!valid) return;

    saveStudent({
      name: nameVal,
      age: ageVal,
      turma: document.getElementById("sm-input-turma").value.trim(),
      observacao: document.getElementById("sm-input-obs").value.trim(),
    });
    closeModal("student-modal");
  });

  document.getElementById("sm-close").addEventListener("click",  () => closeModal("student-modal"));
  document.getElementById("sm-cancel").addEventListener("click", () => closeModal("student-modal"));
  document.getElementById("sm-backdrop").addEventListener("click", () => closeModal("student-modal"));

  // Fechar com Escape
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    ["student-modal", "student-required-modal", "clear-confirm-modal", "alert-modal"].forEach(id => {
      if (!document.getElementById(id)?.hasAttribute("hidden")) closeModal(id);
    });
  });

  function renderStudent() {
    const s = loadStudent();
    const nameEl  = document.getElementById("student-name");
    const ageEl   = document.getElementById("student-age");
    const turmaEl = document.getElementById("student-turma");
    const noteEl  = document.getElementById("student-note");
    const btn     = document.getElementById("btn-config-student");
    if (!nameEl || !btn) return;
    if (!s || !s.name) {
      nameEl.textContent  = "—";
      ageEl.textContent   = "Nenhum aluno configurado";
      turmaEl.textContent = "";
      noteEl.textContent  = "";
      btn.textContent     = "Configurar aluno";
    } else {
      nameEl.textContent  = s.name;
      ageEl.textContent   = `Idade: ${s.age ? s.age + " anos" : "Não informada"}`;
      turmaEl.textContent = s.turma ? `Turma/Série: ${s.turma}` : "";
      noteEl.textContent  = s.observacao ? `Observação: ${s.observacao}` : "";
      btn.textContent     = "Editar aluno";
    }
    btn.onclick = openStudentModal;
  }

  function configureStudent() { openStudentModal(); }
  function studentExportLabel() {
    const s = loadStudent();
    if (!s || !s.name) return "Aluno não configurado";
    return `${s.name}${s.age ? " · " + s.age + " anos" : ""}${s.turma ? " · " + s.turma : ""}`;
  }
  function studentExportFields() {
    const s = loadStudent();
    if (!s || !s.name) {
      return [
        ["Nome", "Aluno não configurado"],
        ["Idade", ""],
        ["Turma/Série", ""],
        ["Observação", ""],
      ];
    }
    return [
      ["Nome", s.name],
      ["Idade", s.age ? `${s.age} anos` : ""],
      ["Turma/Série", s.turma || ""],
      ["Observação", s.observacao || ""],
    ];
  }
  function studentFileSegment() {
    const s = loadStudent();
    if (!s || !s.name) return "sem-aluno";
    return `${s.name}-${s.age || "idade"}-${s.turma || "turma"}`
      .toLowerCase()
      .replace(/\s+/g, "_")
      .replace(/[^a-z0-9_-]/g, "");
  }
  function load() {
    try {
      return JSON.parse(localStorage.getItem("nv-history") || "[]");
    } catch (e) {
      return [];
    }
  }
  let history = load();

  // ── Lê tarefas do Plano do Dia (neurovoz.tasks.v1) ──────────────────────────
  function loadDayTasks() {
    try {
      const raw = localStorage.getItem("neurovoz.tasks.v1");
      const parsed = raw ? JSON.parse(raw) : [];
      return Array.isArray(parsed) ? parsed : [];
    } catch (e) { return []; }
  }

  // ── Backfill: sincroniza tarefas já concluídas → nv-routine-history ──────────
  // Garante que tarefas marcadas antes de abrir o histórico apareçam aqui.
  function backfillRoutineFromDayTasks() {
    const tasks = loadDayTasks();
    // Lê diretamente do localStorage para evitar recursão com loadRoutineHistory()
    let entries = [];
    try {
      const raw = localStorage.getItem("nv-routine-history");
      const parsed = raw ? JSON.parse(raw) : [];
      entries = Array.isArray(parsed) ? parsed : [];
    } catch (e) { entries = []; }
    const knownIds = new Set(entries.map((e) => e.taskId));
    const EMOJI_RULES = [
      { emoji: "❤️", keywords: ["psicolog","medic","dentist","terapia","terapeut","hospital","exame","consulta","remedio","saude","vacina","fono","neuro"] },
      { emoji: "🍽️", keywords: ["comer","lanch","recreio","almoc","jantar","cafe","refeic","merenda","cozinhar"] },
      { emoji: "🏫", keywords: ["atividade","escola","aula","professor","prof","licao","tarefa de casa","estud","prova","colegio","faculdade"] },
      { emoji: "💼", keywords: ["reuniao","escritorio","trabalho","expediente","cliente","projeto"] },
      { emoji: "🛒", keywords: ["comprar","mercado","supermercado","farmacia","buscar","feira","padaria"] },
      { emoji: "🏃", keywords: ["corrida","correr","academia","treino","exercicio","caminhada","yoga","pilates","natacao","bike"] },
      { emoji: "🛁", keywords: ["banho","tomar banho","higiene","escovar"] },
      { emoji: "💧", keywords: ["agua","beber agua","hidrat"] },
      { emoji: "😴", keywords: ["dormir","sono","soneca","descansar","cochilo"] },
      { emoji: "🧘", keywords: ["meditar","meditac","respirar","mindfulness"] },
      { emoji: "📞", keywords: ["ligar","telefon","chamada","ligacao","videochamada"] },
      { emoji: "💬", keywords: ["mensagem","responder","whats","conversar"] },
      { emoji: "🎉", keywords: ["festa","aniversario","comemora","celebra"] },
      { emoji: "🎮", keywords: ["jogar","game","videogame","brincar"] },
      { emoji: "🚗", keywords: ["dirigir","carro","viagem","viajar","onibus","uber","transporte","metro"] },
      { emoji: "🐶", keywords: ["cachorro","cao","passear com","gato","pet","animal"] },
      { emoji: "🧹", keywords: ["limpar","limpeza","arrumar","organizar","lavar","louca","roupa"] },
      { emoji: "📚", keywords: ["ler","leitura","livro"] },
      { emoji: "💊", keywords: ["remedio","medicament","tomar remedio"] },
      { emoji: "💰", keywords: ["pagar","conta","boleto","banco","dinheiro"] },
      { emoji: "🎵", keywords: ["musica","tocar","instrumento","violao","piano"] },
      { emoji: "✍️", keywords: ["escrever","anotar","diario"] },
    ];
    const normalize = (s) => s.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    const pickEmoji = (title, desc) => {
      const text = " " + normalize(`${title} ${desc ?? ""}`) + " ";
      for (const { emoji, keywords } of EMOJI_RULES) {
        for (const k of keywords) { if (text.includes(k)) return emoji; }
      }
      return "📝";
    };
    const dayKey = (ts) => {
      const d = new Date(ts);
      return new Date(ts - d.getTimezoneOffset() * 60000).toISOString().slice(0, 10);
    };
    const hhmm = (ts) => new Date(ts).toLocaleTimeString("pt-BR", { hour: "2-digit", minute: "2-digit" });

    let changed = false;
    tasks.forEach((t) => {
      if (!t.done || knownIds.has(t.id)) return;
      const completedTs = t.completedAt || t.createdAt || Date.now();
      const date = dayKey(completedTs);
      const icon = pickEmoji(t.title, t.desc);
      entries.push({
        id: `${t.id}@${date}`,
        taskId: t.id,
        type: "completed",
        name: t.title,
        icon,
        date,
        time: t.start || "",
        completedAt: hhmm(completedTs),
        label: `${t.title} — concluída`,
      });
      changed = true;
    });
    if (changed) {
      try { localStorage.setItem("nv-routine-history", JSON.stringify(entries)); } catch {}
    }
    return entries;
  }

  function loadRoutineHistory() {
    backfillRoutineFromDayTasks();
    try {
      return JSON.parse(localStorage.getItem("nv-routine-history") || "[]");
    } catch (e) {
      return [];
    }
  }

  function routineEntryLabel(entry) {
    if (entry.type === "completed") return `${entry.name} — concluída`;
    if (entry.type === "alarm") return entry.label || `Hora de ${entry.name}`;
    if (entry.type === "countdown") return entry.label || `Contagem para ${entry.name}`;
    return entry.label || entry.name || "Evento de rotina";
  }

  function routineEntryTag(entry) {
    if (entry.type === "completed") return "✅ Concluída";
    if (entry.type === "alarm") return "🔔 Alarme";
    if (entry.type === "countdown") return "⏳ Contagem";
    return "📍 Rotina";
  }

  function renderRoutineHistory() {
    const all = loadRoutineHistory();
    const dayTasks = loadDayTasks();
    const list = document.getElementById("routine-history-list");
    const empty = document.getElementById("routine-history-empty");
    if (!list || !empty) return;
    const today = new Date().toISOString().slice(0, 10);
    const todayItems = all.filter((e) => e.date === today);
    const todayDone = todayItems.filter((e) => e.type === "completed").length;
    // Total de tarefas do Plano do Dia como fonte de verdade para o dia atual
    const totalDayTasks = dayTasks.length;
    const totalEl = document.getElementById("routine-kpi-total");
    const doneEl = document.getElementById("routine-kpi-done");
    const alEl = document.getElementById("routine-kpi-alarms");
    const cdEl = document.getElementById("routine-kpi-countdowns");
    if (totalEl) totalEl.textContent = String(totalDayTasks || todayItems.length);
    if (doneEl) doneEl.textContent = String(todayDone);
    if (alEl) alEl.textContent = String(todayItems.filter((e) => e.type === "alarm").length);
    if (cdEl) cdEl.textContent = String(todayItems.filter((e) => e.type === "countdown").length);

    // ── Barra de progresso do dia ──────────────────────────────────────────────
    const progressWrap = document.getElementById("routine-progress-wrap");
    const progressBar = document.getElementById("routine-progress-bar");
    const progressPct = document.getElementById("routine-progress-pct");
    if (totalDayTasks > 0 && progressWrap && progressBar && progressPct) {
      const pct = Math.round((todayDone / totalDayTasks) * 100);
      progressWrap.style.display = "block";
      progressBar.style.width = pct + "%";
      progressPct.textContent = pct + "%";
    } else if (progressWrap) {
      progressWrap.style.display = "none";
    }

    // ── Tarefas pendentes do dia ───────────────────────────────────────────────
    const pendingSection = document.getElementById("routine-pending-section");
    const pendingList = document.getElementById("routine-pending-list");
    const doneTaskIds = new Set(all.filter(e => e.type === "completed").map(e => e.taskId));
    const pendingTasks = dayTasks.filter((t) => !t.done && !doneTaskIds.has(t.id));
    if (pendingTasks.length > 0 && pendingSection && pendingList) {
      pendingSection.style.display = "block";
      pendingList.innerHTML = pendingTasks.map((t) => {
        const timeLabel = t.start ? (t.end ? `${t.start}–${t.end}` : `Começa ${t.start}`) : "Sem horário";
        return `<div class="tl-item" style="border-left-color:#94a3b8;opacity:0.8">
          <span class="tl-time" style="color:#94a3b8">${t.start || "--:--"}</span>
          <span class="tl-icon">📝</span>
          <span class="tl-content"><strong>${t.title}</strong>${t.desc ? `<span class="tl-sentence">${t.desc}</span>` : ""}<span class="tl-sentence">${timeLabel}</span></span>
          <span class="tl-cat" style="background:#94a3b81a;color:#64748b">⏳ Pendente</span>
        </div>`;
      }).join("");
    } else if (pendingSection) {
      pendingSection.style.display = "none";
    }

    if (!all.length) {
      list.innerHTML = "";
      empty.style.display = "block";
      return;
    }
    empty.style.display = "none";
    const groups = {};
    all.forEach((e) => {
      const d = e.date || "sem-data";
      (groups[d] = groups[d] || []).push(e);
    });
    list.innerHTML = Object.entries(groups)
      .sort((a, b) => (a[0] < b[0] ? 1 : -1))
      .map(([day, items]) => {
        const dayLabel = day === "sem-data"
          ? "Sem data"
          : new Date(day + "T00:00:00").toLocaleDateString("pt-BR", {
              weekday: "long", day: "2-digit", month: "long",
            });
        return `<div class="tl-day"><h4 class="tl-date">${dayLabel}</h4>${items
          .map((e) => {
            const color = e.type === "completed" ? "#2ecc71" : e.type === "alarm" ? "#f39c12" : "#5b8def";
            return `<div class="tl-item" style="border-left-color:${color}">
              <span class="tl-time">${e.completedAt || e.time || "--:--"}</span>
              <span class="tl-icon">${e.icon || "📍"}</span>
              <span class="tl-content"><strong>${routineEntryLabel(e)}</strong><span class="tl-sentence">${e.time ? `Horário previsto: ${e.time}` : "Sem horário"}</span></span>
              <span class="tl-cat" style="background:${color}1a;color:${color}">${routineEntryTag(e)}</span>
            </div>`;
          })
          .join("")}</div>`;
      })
      .join("");
  }

  function studentInfoComplete() {
    const s = loadStudent();
    return !!(s && s.name && s.age && /^[0-9]+$/.test(s.age));
  }

  const catName = (id) =>
    (categories.find((c) => c.id === id) || {}).name || id;
  const catColor = (id) =>
    (categories.find((c) => c.id === id) || {}).color || "#5b8def";

  function period(ts) {
    const h = new Date(ts).getHours();
    if (h < 6) return "Madrugada";
    if (h < 12) return "Manhã";
    if (h < 18) return "Tarde";
    return "Noite";
  }

  function filtered() {
    const date = document.getElementById("filter-date").value;
    const cat = document.getElementById("filter-cat").value;
    const q = document
      .getElementById("filter-search")
      .value.trim()
      .toLowerCase();
    return history.filter((h) => {
      if (date) {
        const d = new Date(h.time).toISOString().slice(0, 10);
        if (d !== date) return false;
      }
      if (cat !== "all" && h.category !== cat) return false;
      if (q && !h.label.toLowerCase().includes(q)) return false;
      return true;
    });
  }

  function countBy(items, key) {
    const map = {};
    items.forEach((i) => {
      map[i[key]] = (map[i[key]] || 0) + 1;
    });
    return Object.entries(map).sort((a, b) => b[1] - a[1]);
  }

  function renderBars(elId, entries, opts = {}) {
    const el = document.getElementById(elId);
    if (!entries.length) {
      el.innerHTML = '<p class="no-data">Sem dados ainda.</p>';
      return;
    }
    const max = entries[0][1];
    el.innerHTML = entries
      .slice(0, 6)
      .map(([label, val]) => {
        const item = history.find((h) => h.label === label);
        const icon = item ? item.icon : "";
        const color =
          opts.color || (item ? catColor(item.category) : "#5b8def");
        return `<div class="bar-row">
        <span class="bar-label">${icon} ${label}</span>
        <span class="bar-track"><span class="bar-fill" style="width:${(val / max) * 100}%;background:${color}"></span></span>
        <span class="bar-val">${val}</span>
      </div>`;
      })
      .join("");
  }

  function renderDashboard() {
    const all = history;

    // KPIs
    document.getElementById("kpi-total").textContent = all.length;
    const today = new Date().toISOString().slice(0, 10);
    document.getElementById("kpi-today").textContent = all.filter(
      (h) => new Date(h.time).toISOString().slice(0, 10) === today,
    ).length;
    const alphabetEvents = loadAlphabetHistory();
    const typedWords = alphabetEvents.filter(
      (e) => e.type === "wordbuilder" && e.action === "say" && e.word,
    );
    const combinedVocabulary = new Set([
      ...all.map((h) => h.label),
      ...typedWords.map((e) => e.word),
    ]).size;
    const historyVocabulary = new Set(all.map((h) => h.label)).size;
    const typedVocabulary = new Set(typedWords.map((e) => e.word)).size;
    document.getElementById("kpi-words").textContent = String(combinedVocabulary);
    const vocabNote = document.getElementById("kpi-vocab-note");
    if (vocabNote) {
      vocabNote.textContent = `Total de palavras distintas: ${combinedVocabulary} (Histórico: ${historyVocabulary}, Formação de Palavras: ${typedVocabulary})`;
    }
    const top = countBy(all, "label")[0];
    document.getElementById("kpi-top").textContent = top ? top[0] : "—";

    // Emoções
    renderBars(
      "chart-emocoes",
      countBy(
        all.filter((h) => h.category === "emocoes"),
        "label",
      ),
    );
    // Necessidades (núcleo + alimentação + higiene + saúde)
    const needCats = ["nucleo", "alimentacao", "higiene", "saude"];
    renderBars(
      "chart-necessidades",
      countBy(
        all.filter((h) => needCats.includes(h.category)),
        "label",
      ),
    );
    // Ranking geral
    const ranking = countBy(all, "label").slice(0, 8);
    const rk = document.getElementById("chart-ranking");
    rk.innerHTML = ranking.length
      ? ranking
          .map(([label, val], i) => {
            const item = all.find((h) => h.label === label);
            return `<li><span class="rk-pos">${i + 1}</span><span class="rk-label">${item?.icon || ""} ${label}</span><span class="rk-val">${val}×</span></li>`;
          })
          .join("")
      : '<p class="no-data">Sem dados ainda.</p>';

    // Período
    const periods = { Madrugada: 0, Manhã: 0, Tarde: 0, Noite: 0 };
    all.forEach((h) => periods[period(h.time)]++);
    const maxP = Math.max(1, ...Object.values(periods));
    const icons = { Madrugada: "🌙", Manhã: "🌅", Tarde: "☀️", Noite: "🌙" };
    document.getElementById("chart-periodo").innerHTML = Object.entries(periods)
      .map(
        ([p, v]) =>
          `<div class="period-col">
        <span class="period-bar" style="height:${(v / maxP) * 100}%"></span>
        <span class="period-val">${v}</span>
        <span class="period-name">${icons[p]} ${p}</span>
      </div>`,
      )
      .join("");
  }

  function loadAlphabetHistory() {
    try {
      return JSON.parse(localStorage.getItem("nv-learning-history") || "[]");
    } catch (e) {
      return [];
    }
  }

  function renderAlphabetInfo() {
    const allEvents = loadAlphabetHistory();
    const events = allEvents.filter((e) => e.type === "alphabet");
    const letters = events.filter((e) => e.action === "letter");
    const words = events.filter((e) => e.action === "word");
    const examples = events.filter((e) => e.action === "example");
    const distinctLetters = new Set(events.map((e) => e.letter)).size;

    document.getElementById("alpha-letters-used").textContent = letters.length;
    document.getElementById("alpha-words-used").textContent = words.length;
    document.getElementById("alpha-examples-used").textContent = examples.length;
    document.getElementById("alpha-letters-distinct").textContent = distinctLetters;

    const top = countBy(events, "letter").slice(0, 8);
    const alphaTop = document.getElementById("alpha-top");
    if (alphaTop) {
      alphaTop.innerHTML = top.length
        ? top
            .map(
              ([letter, count]) =>
                `<li><span class="rk-pos">${count}</span><span class="rk-label">${letter}</span></li>`,
            )
            .join("")
        : '<p class="no-data">Ainda não há interações com o alfabeto.</p>';
    }

    const typedWords = allEvents.filter((e) => e.type === "wordbuilder" && e.action === "say" && e.word);
    const totalTyped = typedWords.length;
    const distinctTyped = new Set(typedWords.map((e) => e.word)).size;
    const typedTop = countBy(typedWords, "word").slice(0, 8);

    const typedCountEl = document.getElementById("alpha-words-written");
    if (typedCountEl) typedCountEl.textContent = String(totalTyped);
    const typedDistinctEl = document.getElementById("alpha-typed-distinct");
    if (typedDistinctEl) typedDistinctEl.textContent = String(distinctTyped);
    const typedListEl = document.getElementById("alpha-typed-top");
    if (typedListEl) {
      typedListEl.innerHTML = typedTop.length
        ? typedTop
            .map(
              ([word, count]) =>
                `<li><span class="rk-pos">${count}</span><span class="rk-label">${word}</span></li>`,
            )
            .join("")
        : '<p class="no-data">Nenhuma palavra escrita ainda.</p>';
    }
  }

  function renderTimeline() {
    const items = filtered().slice().reverse();
    const el = document.getElementById("timeline");
    const empty = document.getElementById("empty-state");
    if (!items.length) {
      el.innerHTML = "";
      empty.style.display = "block";
      return;
    }
    empty.style.display = "none";

    // agrupar por dia
    const groups = {};
    items.forEach((h) => {
      const d = new Date(h.time).toLocaleDateString("pt-BR", {
        weekday: "long",
        day: "2-digit",
        month: "long",
      });
      (groups[d] = groups[d] || []).push(h);
    });

    el.innerHTML = Object.entries(groups)
      .map(
        ([day, list]) => `
      <div class="tl-day">
        <h4 class="tl-date">${day}</h4>
        ${list
          .map((h) => {
            const time = new Date(h.time).toLocaleTimeString("pt-BR", {
              hour: "2-digit",
              minute: "2-digit",
            });
            return `<div class="tl-item" style="border-left-color:${catColor(h.category)}">
            <span class="tl-time">${time}</span>
            <span class="tl-icon">${h.icon}</span>
            <span class="tl-content"><strong>${h.label}</strong>${h.sentence && h.sentence !== h.label ? `<span class="tl-sentence">${h.sentence}</span>` : ""}</span>
            <span class="tl-cat" style="background:${catColor(h.category)}1a;color:${catColor(h.category)}">${catName(h.category)}</span>
          </div>`;
          })
          .join("")}
      </div>`,
      )
      .join("");
  }

  function renderAll() {
    renderDashboard();
    renderAlphabetInfo();
    renderTimeline();
    renderRoutineHistory();
  }

  ["filter-date", "filter-cat", "filter-search"].forEach((id) =>
    document.getElementById(id).addEventListener("input", renderTimeline),
  );

  // Limpar
  document.getElementById("btn-clear").addEventListener("click", () => {
    openModal("clear-confirm-modal");
  });
  document.getElementById("ccm-cancel").addEventListener("click", () => closeModal("clear-confirm-modal"));
  document.getElementById("ccm-backdrop").addEventListener("click", () => closeModal("clear-confirm-modal"));
  document.getElementById("ccm-confirm").addEventListener("click", () => {
    closeModal("clear-confirm-modal");
    localStorage.removeItem("nv-history");
    localStorage.removeItem("nv-routine-history");
    localStorage.removeItem("neurovoz.tasks.v1");
    history = [];
    renderAll();
  });

  function hasExportData() {
    const routine = loadRoutineHistory();
    return history.length > 0 || routine.length > 0;
  }

  function showStudentRequiredModal() { openModal("student-required-modal"); }
  function hideStudentRequiredModal() { closeModal("student-required-modal"); }

  document.getElementById("btn-modal-config").addEventListener("click", () => {
    closeModal("student-required-modal");
    setTimeout(() => openStudentModal(), 240);
  });
  document.getElementById("btn-modal-close").addEventListener("click", hideStudentRequiredModal);
  document.getElementById("srm-backdrop").addEventListener("click", hideStudentRequiredModal);

  // Alert modal
  document.getElementById("am-ok").addEventListener("click", () => closeModal("alert-modal"));
  document.getElementById("am-backdrop").addEventListener("click", () => closeModal("alert-modal"));

  // CSV
  document.getElementById("btn-csv").addEventListener("click", () => {
    if (!hasExportData()) {
      showAlert("Não há dados para exportar.");
      return;
    }
    if (!studentInfoComplete()) {
      showStudentRequiredModal();
      return;
    }
    const rows = [
      ...studentExportFields(),
      ["Exportado em", new Date().toLocaleString("pt-BR")],
      [],
    ];
    if (history.length) {
      rows.push(["Data", "Hora", "Comando", "Categoria", "Frase"]);
      history.forEach((h) => {
        const d = new Date(h.time);
        rows.push([
          d.toLocaleDateString("pt-BR"),
          d.toLocaleTimeString("pt-BR"),
          h.label,
          catName(h.category),
          (h.sentence || "").replace(/,/g, ";"),
        ]);
      });
    }
    // Append routine history if present
    const routine = loadRoutineHistory();
    const dayTasks = loadDayTasks();
    if (dayTasks && dayTasks.length) {
      rows.push([]);
      rows.push(["Plano do Dia — Estado Atual"]);
      rows.push(["Título", "Descrição", "Início", "Término", "Status", "Concluída em"]);
      dayTasks.forEach((t) => {
        const completedAt = t.done && t.completedAt
          ? new Date(t.completedAt).toLocaleTimeString("pt-BR", { hour: "2-digit", minute: "2-digit" })
          : "";
        rows.push([
          t.title || "",
          (t.desc || "").replace(/,/g, ";"),
          t.start || "",
          t.end || "",
          t.done ? "Concluída" : "Pendente",
          completedAt,
        ]);
      });
    }
    if (routine && routine.length) {
      rows.push([]);
      rows.push(["Rotina do Dia — Histórico"]);
      rows.push(["Data", "Hora", "Atividade", "Tipo", "Detalhe"]);
      routine.forEach((e) => {
        rows.push([
          e.date || "",
          e.completedAt || e.time || "",
          e.name || "",
          e.type || "",
          (routineEntryLabel(e) || "").replace(/,/g, ";"),
        ]);
      });
    }
    const csv = rows.map((r) => r.map((c) => `"${c}"`).join(",")).join("\n");
    const blob = new Blob(["\uFEFF" + csv], {
      type: "text/csv;charset=utf-8;",
    });
    const filename = `neurovoz-historico-${studentFileSegment()}-${new Date().toISOString().slice(0, 10)}.csv`;
    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = filename;
    a.click();
  });

  // Relatório PDF (impressão)
  document.getElementById("btn-pdf").addEventListener("click", () => {
    if (!hasExportData()) {
      showAlert("Não há dados para o relatório.");
      return;
    }
    if (!studentInfoComplete()) {
      showStudentRequiredModal();
      return;
    }
    const emocoes = countBy(
      history.filter((h) => h.category === "emocoes"),
      "label",
    ).slice(0, 5);
    const ranking = countBy(history, "label").slice(0, 10);
    const periods = { Madrugada: 0, Manhã: 0, Tarde: 0, Noite: 0 };
    history.forEach((h) => periods[period(h.time)]++);

    const student = loadStudent();
