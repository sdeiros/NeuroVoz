          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
          <span>NeuroVoz</span>
        </div>
        <div class="pdf-content">
          <h1>Relatório Pedagógico — NeuroVoz</h1>
          <p class="sub">Nome: <strong>${student?.name || "Aluno não configurado"}</strong></p>
          <p class="sub">Idade: <strong>${student?.age ? `${student.age} anos ` : "Não informado "}</strong>Turma/Série: <strong>${student?.turma || "Não informada"}</strong></p>
          <section class="summary">
            <p><strong>Gerado em:</strong> ${new Date().toLocaleString("pt-BR")}</p>
            <p><strong>Total de Interações Registradas:</strong> ${totalInteractions}</p>
            <p><strong>Inclui:</strong> Histórico, Alfabeto e Formação de Palavras</p>
          </section>
          <h2>Frequência por Período</h2>
          <table>
            <thead><tr><th>Período</th><th>Interações</th></tr></thead>
            <tbody>
              ${Object.entries(periods)
                .map(([p, v]) => `<tr><td>${p}</td><td>${v}</td></tr>`)
                .join("")}
            </tbody>
          </table>
          <h2>Emoções Predominantes</h2>
          <ul>${emocoes.length ? emocoes.map(([l, v]) => `<li>${l}: ${v}×</li>`).join("") : "<li>Sem Registros de Emoções.</li>"}</ul>
          <h2>Palavras / Necessidades mais Comunicadas</h2>
          <table><tr><th>#</th><th>Palavra</th><th>Frequência</th></tr>
          ${ranking.map(([l, v], i) => `<tr><td>${i + 1}</td><td>${l}</td><td>${v}×</td></tr>`).join("")}</table>
        </div>
        ${pdfFooter(1)}
      </section>

      <section class="pdf-page">
        <div class="pdf-watermark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
          <span>NeuroVoz</span>
        </div>
        <div class="pdf-content">
          <h2 style="margin-top:0">Alfabeto</h2>
          <p><strong>Letras acessadas:</strong> ${alphaLetters.length}</p>
          <p><strong>Palavras reproduzidas:</strong> ${alphaWords.length}</p>
          <p><strong>Exemplos ouvidos:</strong> ${alphaExamples.length}</p>
          <p><strong>Letras distintas:</strong> ${alphaDistinctLetters}</p>
          <h3>Top letras</h3>
          <table><tr><th>#</th><th>Letra</th><th>Frequência</th></tr>
          ${alphaLetterTop.length ? alphaLetterTop.map(([letter, count], i) => `<tr><td>${i + 1}</td><td>${letter}</td><td>${count}×</td></tr>`).join("") : `<tr><td colspan="3">Nenhuma letra registrada ainda.</td></tr>`}</table>
          <h2>Formação de Palavras</h2>
          <p><strong>Palavras escritas:</strong> ${typedWordsTotal}</p>
          <p><strong>Palavras distintas escritas:</strong> ${typedWordsDistinct}</p>
          <h3>Top palavras escritas</h3>
          <table><tr><th>#</th><th>Palavra</th><th>Frequência</th></tr>
          ${typedWordTop.length ? typedWordTop.map(([word, count], i) => `<tr><td>${i + 1}</td><td>${word}</td><td>${count}×</td></tr>`).join("") : `<tr><td colspan="3">Nenhuma palavra escrita ainda.</td></tr>`}</table>
          <h2>Evolução do Vocabulário</h2>
          <p>Total de Palavras Distintas Utilizadas: <strong>${combinedVocabulary}</strong> (Histórico: ${historyVocabulary}, Formação de Palavras: ${typedVocabulary}).</p>
          <p style="margin-top:30px;color:#8898b2;font-size:13px">Dados armazenados localmente, em conformidade com práticas éticas de privacidade.</p>
        </div>
        ${pdfFooter(2)}
      </section>
      <section class="pdf-page">
        <div class="pdf-watermark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
          <span>NeuroVoz</span>
        </div>
        <div class="pdf-content">
          <h2 style="margin-top:0">Rotina do Dia — Histórico de Atividades</h2>
          <p class="sub">Inclui atividades concluídas, alarmes disparados no horário e contagens regressivas. Os dados ficam armazenados localmente no dispositivo.</p>
          ${routineHistoryAll.length
            ? Object.entries(routineByDate)
                .sort((a, b) => (a[0] < b[0] ? 1 : -1))
                .map(([day, items]) => {
                  const dayLabel = day === "sem-data"
                    ? "Sem data"
                    : new Date(day + "T00:00:00").toLocaleDateString("pt-BR", { weekday: "long", day: "2-digit", month: "long", year: "numeric" });
                  return `<h3 style="text-transform:capitalize">${dayLabel}</h3>
                    <table>
                      <thead><tr><th>Hora</th><th>Atividade</th><th>Tipo</th><th>Detalhe</th></tr></thead>
                      <tbody>
                        ${items.map((e) => `<tr><td>${e.completedAt || e.time || "--:--"}</td><td>${(e.icon || "📍") + " " + (e.name || "")}</td><td>${routineEntryTag(e)}</td><td>${routineEntryLabel(e)}</td></tr>`).join("")}
                      </tbody>
                    </table>`;
                })
                .join("")
            : '<p class="no-data">Nenhuma atividade da rotina registrada.</p>'}
        </div>
        ${pdfFooter(3)}
      </section>
      <script>window.onload = () => setTimeout(() => window.print(), 400);<\/script>
      </body></html>`);
    win.document.title = pdfTitle;
    win.document.close();
  });

  renderAll();
  renderStudent();
</script>

