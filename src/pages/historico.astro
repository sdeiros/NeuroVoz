        .pdf-footer { flex: 0 0 auto; display: grid; grid-template-columns: auto 1fr auto auto; align-items: center; gap: 10px; min-height: 18mm; margin-top: 10mm; padding-top: 8px; border-top: 1px solid #dbe7f1; background: rgba(255, 255, 255, 0.96); color: #5a6b85; font-size: 9.5px; position: relative; z-index: 1; }
