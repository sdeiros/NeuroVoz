---
import Base from '../layouts/Base.astro';
---

<Base title="Assistente Visual de Tempo — NeuroVoz" description="Temporizador visual para apoiar crianças em transições, com widget persistente, modal interativo e celebrações personalizadas.">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Assistente Visual de Tempo</span>
      <h1 class="page-title">Gerencie o tempo das atividades com calma</h1>
      <p class="page-lead">Defina duração, nome, ícone, cor e tema. O temporizador continua funcionando enquanto você navega pelo NeuroVoz.</p>
    </div>
  </section>

  <section class="section">
    <div class="container timer-layout">
      <div class="timer-panel panel">
        <div class="panel-head">
          <span class="eyebrow">Configuração</span>
          <h2 class="section-title">Criar um novo temporizador</h2>
          <p class="section-lead">Escolha a atividade, duração e estilo para tornar a transição mais visual e calmante.</p>
        </div>

        <div class="field">
          <label for="activity-name">Nome da atividade</label>
          <input id="activity-name" type="text" placeholder="Ex.: Hora do estudo" />
        </div>

        <div class="row2">
          <div class="field">
            <label for="activity-icon">Ícone da atividade</label>
            <select id="activity-icon">
              <option value="📚">📚 Estudo</option>
              <option value="🧩">🧩 Atividade</option>
              <option value="🎮">🎮 Brincadeira</option>
              <option value="🦷">🦷 Higiene</option>
              <option value="🛁">🛁 Banho</option>
              <option value="🍎">🍎 Lanche</option>
              <option value="🚀">🚀 Espaço</option>
              <option value="🦄">🦄 Mágica</option>
            </select>
          </div>
          <div class="field">
            <label for="activity-color">Cor do temporizador</label>
            <input id="activity-color" type="color" value="#5b8def" />
          </div>
        </div>

        <div class="field">
          <label for="activity-theme">Tema de celebração</label>
          <select id="activity-theme">
            <option value="dinossauros">🦖 Dinossauros</option>
            <option value="carros">🚗 Carros</option>
            <option value="flores">🌸 Flores</option>
            <option value="estrelas">⭐ Estrelas</option>
            <option value="confetes">🎉 Confetes</option>
            <option value="unicornio">🦄 Unicórnios</option>
            <option value="espaco">🚀 Espaço</option>
            <option value="animais">🐶 Animais</option>
          </select>
        </div>

        <div class="row3 timer-duration-row">
          <div class="field">
            <label for="hours">Horas</label>
            <input id="hours" type="number" min="0" max="12" value="0" />
          </div>
          <div class="field">
            <label for="minutes">Minutos</label>
            <input id="minutes" type="number" min="0" max="59" value="5" />
          </div>
          <div class="field">
            <label for="seconds">Segundos</label>
            <input id="seconds" type="number" min="0" max="59" value="0" />
          </div>
        </div>

        <div class="timer-actions">
          <button type="button" class="btn btn-primary" id="btn-start">Iniciar temporizador</button>
          <button type="button" class="btn btn-ghost" id="btn-pause">Pausar</button>
          <button type="button" class="btn btn-ghost hidden" id="btn-resume">Continuar</button>
          <button type="button" class="btn btn-mint" id="btn-reset">Reiniciar</button>
          <button type="button" class="btn btn-ghost" id="btn-end">Encerrar</button>
        </div>

        <div class="timer-summary card">
          <div class="summary-row">
            <div>
              <span class="summary-label">Atividade</span>
              <p id="summary-activity">Nenhuma atividade ativa</p>
            </div>
            <div>
              <span class="summary-label">Status</span>
              <p id="summary-status">Aguardando</p>
            </div>
          </div>
          <div class="summary-row">
            <div>
              <span class="summary-label">Tempo restante</span>
              <p id="summary-remaining">00:00:00</p>
            </div>
            <div>
              <span class="summary-label">Tema</span>
              <p id="summary-theme">—</p>
            </div>
          </div>
          <div class="timer-bar"><div class="timer-bar-fill" id="summary-progress"></div></div>
        </div>
      </div>

      <div class="timer-aside">
        <div class="panel card">
          <div class="panel-head">
            <span class="eyebrow">Histórico</span>
            <h2 class="panel-title">Atividades concluídas</h2>
          </div>
          <ul class="history-list" id="timer-history"></ul>
          <button type="button" class="btn btn-ghost btn-block" id="btn-clear-history">Limpar histórico</button>
        </div>
      </div>
    </div>
  </section>
</Base>

<script type="module">
  const KEY = 'nv-timer';
  const HISTORY_KEY = 'nv-timer-history';

  const formFields = {
    activity: document.getElementById('activity-name'),
    icon: document.getElementById('activity-icon'),
    color: document.getElementById('activity-color'),
    theme: document.getElementById('activity-theme'),
    hours: document.getElementById('hours'),
    minutes: document.getElementById('minutes'),
    seconds: document.getElementById('seconds'),
  };

  const buttons = {
    start: document.getElementById('btn-start'),
    pause: document.getElementById('btn-pause'),
    resume: document.getElementById('btn-resume'),
    reset: document.getElementById('btn-reset'),
    end: document.getElementById('btn-end'),
    clearHistory: document.getElementById('btn-clear-history'),
  };

  const summary = {
    activity: document.getElementById('summary-activity'),
    status: document.getElementById('summary-status'),
    remaining: document.getElementById('summary-remaining'),
    theme: document.getElementById('summary-theme'),
    progress: document.getElementById('summary-progress'),
  };

  const historyList = document.getElementById('timer-history');

  function loadTimer() {
    try { return JSON.parse(localStorage.getItem(KEY) || 'null'); } catch (e) { return null; }
  }
  function saveTimer(timer) { localStorage.setItem(KEY, JSON.stringify(timer)); window.NVTimer?.refreshUI(); updatePage(); }
  function clearTimer() { localStorage.removeItem(KEY); window.NVTimer?.refreshUI(); updatePage(); }
  function loadHistory() {
    try { return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); } catch (e) { return []; }
  }
  function saveHistory(history) { localStorage.setItem(HISTORY_KEY, JSON.stringify(history)); }

  function formatTime(totalMillis) {
    const seconds = Math.max(0, Math.ceil(totalMillis / 1000));
    const h = Math.floor(seconds / 3600).toString().padStart(2, '0');
    const m = Math.floor((seconds % 3600) / 60).toString().padStart(2, '0');
    const s = (seconds % 60).toString().padStart(2, '0');
    return `${h}:${m}:${s}`;
  }

  function parseDuration() {
    const h = Number(formFields.hours.value) || 0;
    const m = Number(formFields.minutes.value) || 0;
    const s = Number(formFields.seconds.value) || 0;
    return (h * 3600 + m * 60 + s) * 1000;
  }

  function buildTimerObject() {
    return {
      id: `timer-${Date.now()}`,
      name: formFields.activity.value.trim() || 'Atividade',
      icon: formFields.icon.value,
      color: formFields.color.value,
      theme: formFields.theme.value,
      duration: parseDuration(),
      startAt: Date.now(),
      status: 'running',
      pausedRemaining: null,
      createdAt: Date.now(),
    };
  }

  function getRemaining(timer) {
    if (!timer) return 0;
    if (timer.status === 'paused') return timer.pausedRemaining || 0;
    if (timer.status === 'running') {
      const elapsed = Date.now() - timer.startAt;
      return Math.max(0, timer.duration - elapsed);
    }
    return 0;
  }

  function updatePage() {
    const timer = loadTimer();
    const remaining = getRemaining(timer);
    if (!timer) {
      summary.activity.textContent = 'Nenhuma atividade ativa';
      summary.status.textContent = 'Aguardando';
      summary.remaining.textContent = '00:00:00';
      summary.theme.textContent = '—';
      summary.progress.style.width = '0%';
      buttons.pause.disabled = true;
      buttons.reset.disabled = true;
      buttons.end.disabled = true;
      return;
    }

    summary.activity.textContent = `${timer.icon} ${timer.name}`;
    summary.status.textContent = timer.status === 'running' ? 'Em andamento' : timer.status === 'paused' ? 'Pausado' : 'Concluído';
    summary.remaining.textContent = formatTime(remaining);
    summary.theme.textContent = timer.theme.replace(/-/g, ' ');
    summary.progress.style.width = timer.duration ? `${100 * (1 - remaining / timer.duration)}%` : '0%';
    buttons.pause.disabled = timer.status !== 'running';
    buttons.resume.disabled = timer.status !== 'paused';
    buttons.reset.disabled = timer.status === 'running';
    buttons.end.disabled = timer.status === 'finished';

    if (timer.status === 'finished') {
      summary.status.textContent = 'Finalizado';
      summary.progress.style.width = '100%';
    }
  }

  function addHistoryEntry(timer) {
    const history = loadHistory();
    const finishedAt = new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
    history.unshift({ id: timer.id, name: timer.name, icon: timer.icon, theme: timer.theme, finishedAt, duration: formatTime(timer.duration) });
    saveHistory(history.slice(0, 20));
    renderHistory();
  }

  function renderHistory() {
    const history = loadHistory();
    historyList.innerHTML = history.length ? history.map((item) => `
      <li class="history-item">
        <span class="history-icon">${item.icon}</span>
        <div>
          <strong>${item.name}</strong>
          <span>${item.finishedAt} — ${item.duration}</span>
        </div>
      </li>
    `).join('') : '<li class="history-empty">Nenhum histórico registrado ainda.</li>';
  }

  buttons.start.addEventListener('click', () => {
    const duration = parseDuration();
    if (!duration || duration <= 0) {
      alert('Defina uma duração válida para iniciar o temporizador.');
      return;
    }
    const timer = buildTimerObject();
    saveTimer(timer);
    window.NVTimer?.setTimer(timer);
  });

  buttons.pause.addEventListener('click', () => {
    const timer = loadTimer();
    if (!timer || timer.status !== 'running') return;
    timer.pausedRemaining = getRemaining(timer);
    timer.status = 'paused';
    saveTimer(timer);
    window.NVTimer?.refreshUI();
  });

  buttons.resume.addEventListener('click', () => {
    const timer = loadTimer();
    if (!timer || timer.status !== 'paused') return;
    const remaining = timer.pausedRemaining || 0;
    // restore startAt so that elapsed + remaining = duration
    timer.startAt = Date.now() - (timer.duration - remaining);
    timer.status = 'running';
    timer.pausedRemaining = null;
    saveTimer(timer);
    window.NVTimer?.refreshUI();
  });

  buttons.reset.addEventListener('click', () => {
    const timer = loadTimer();
    if (!timer) return;
    timer.startAt = Date.now();
    timer.status = 'running';
    timer.pausedRemaining = null;
    saveTimer(timer);
    window.NVTimer?.refreshUI();
  });

  buttons.end.addEventListener('click', () => {
    const timer = loadTimer();
    if (!timer) return;
    timer.status = 'finished';
    saveTimer(timer);
    addHistoryEntry(timer);
    window.NVTimer?.refreshUI();
  });

  buttons.clearHistory.addEventListener('click', () => {
    if (confirm('Limpar todo o histórico de temporizadores?')) {
      saveHistory([]);
      renderHistory();
    }
  });

  function loadFormFromTimer() {
    const timer = loadTimer();
    if (!timer) return;
    formFields.activity.value = timer.name;
    formFields.icon.value = timer.icon;
    formFields.color.value = timer.color;
    formFields.theme.value = timer.theme;
    const totalSeconds = Math.floor(timer.duration / 1000);
    formFields.hours.value = String(Math.floor(totalSeconds / 3600));
    formFields.minutes.value = String(Math.floor((totalSeconds % 3600) / 60));
    formFields.seconds.value = String(totalSeconds % 60);
  }

  window.addEventListener('DOMContentLoaded', () => {
    renderHistory();
    updatePage();
    loadFormFromTimer();
    setInterval(updatePage, 800);
  });
</script>

<style>
  .timer-layout { display: grid; grid-template-columns: 1.5fr 0.9fr; gap: 24px; }
  .timer-panel { display: flex; flex-direction: column; gap: 20px; }
  .panel-head { display: grid; gap: 12px; }
  .panel-title { font-size: clamp(1.4rem, 3vw, 1.8rem); margin: 0; }
  .timer-duration-row { grid-template-columns: repeat(3, minmax(100px, 1fr)); }
  .row2, .row3 { display: grid; gap: 16px; }
  .timer-actions { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
  .timer-actions .btn { min-height: 52px; }
  .timer-summary { background: var(--surface); border: 1px solid var(--border); padding: 20px; }
  .summary-row { display: flex; justify-content: space-between; gap: 18px; margin-bottom: 16px; }
  .summary-label { font-size: 0.82rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .summary-row p { margin-top: 6px; font-size: 1rem; color: var(--text); }
  .timer-bar { width: 100%; height: 12px; border-radius: 999px; background: var(--bg-alt); overflow: hidden; }
  .timer-bar-fill { width: 0%; height: 100%; border-radius: 999px; background: linear-gradient(90deg, var(--blue), var(--mint)); transition: width 0.35s ease; }
  .timer-aside { display: flex; flex-direction: column; gap: 20px; }
  .history-list { list-style: none; display: grid; gap: 12px; margin: 0 0 20px; padding: 0; }
  .history-item { display: grid; grid-template-columns: auto 1fr; gap: 12px; padding: 14px 16px; border-radius: var(--radius); background: var(--surface-2); border: 1px solid var(--border); }
  .history-icon { display: grid; place-items: center; width: 42px; height: 42px; border-radius: 14px; background: var(--blue-soft); font-size: 1.3rem; }
  .history-item strong { display: block; font-size: 0.98rem; margin-bottom: 4px; }
  .history-item span { color: var(--text-soft); font-size: 0.9rem; }
  .history-empty { padding: 24px 16px; color: var(--text-muted); border-radius: var(--radius); background: var(--surface-2); }

  @media (max-width: 980px) { .timer-layout { grid-template-columns: 1fr; } }
</style>
