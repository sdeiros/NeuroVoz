---
import Base from '../layouts/Base.astro';

const team = [
  { name: 'Davi Medeiros da Silva',                   initials: 'DM', instagram: 'sdeiros', photo: null, role: 'Estudante de Psicologia, Artista e Técnico de Informática' },
  { name: 'Hierro Cunha Braga',                       initials: 'HB', instagram: 'hierrobraga', photo: null, role: 'Estudante de Psicologia' },
  { name: 'João Carlos Nascimento de Souza',          initials: 'JC', instagram: 'xjoka_', photo: null, role: 'Estudante de Psicologia' },
  { name: 'João Guilherme Fernandes da Silva',        initials: 'JG', instagram: null, photo: null, role: 'Estudante de Psicologia com Formação de Professor Normalista' },
  { name: 'Maria Eduarda Maia Furtado Marins',        initials: 'ME', instagram: 'maia.madu', photo: null, role: 'Estudante de Psicologia e Mediadora' },
  { name: 'Maria Heloisa Mendes de Souza',            initials: 'MH', instagram: 'mhelo__mendes', photo: null, role: 'Estudante de Psicologia' },
  { name: 'Milena Cellos Andrade',                    initials: 'MC', instagram: 'mi_cellos', photo: null, role: 'Estudante de Psicologia e Influenciadora' },
  { name: 'Simone Sanches da Silva Ferreira',         initials: 'SS', instagram: 'simonesanchesferreira', photo: null, role: 'Estudante de Psicologia' },
];

// Gera uma cor de fundo para o avatar a partir das iniciais
const avatarColors = [
  '#5b8def', '#5cc9b0', '#ff9b85', '#ffd166',
  '#8fb4f5', '#a8e6d6', '#c3a6ff', '#ffb3c6',
];
---

<Base
  title="Sobre o NeuroVoz — Quem somos"
  description="Conheça a equipe por trás do NeuroVoz — estudantes de Psicologia do IBMR Barra da Tijuca comprometidos com inclusão e comunicação alternativa."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Sobre o projeto</span>
      <h1 class="page-title">Quem fez o NeuroVoz</h1>
      <p class="page-lead">Uma plataforma criada com propósito: dar voz a crianças que têm muito a dizer.</p>
    </div>
  </section>

  <!-- Sobre o app -->
  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text reveal">
          <span class="eyebrow">O projeto</span>
          <h2 class="section-title">O que é o NeuroVoz</h2>
          <p>O <strong>NeuroVoz</strong> é uma plataforma educacional e acessível sobre o Transtorno do Espectro Autista (TEA) e Comunicação Aumentativa e Alternativa (CAA), desenvolvida como projeto acadêmico por estudantes de Psicologia.</p>
          <p>O objetivo é reunir, em um único lugar, conteúdo científico acessível sobre o autismo e ferramentas práticas que apoiem crianças com dificuldades na comunicação verbal — e as pessoas que cuidam delas: famílias, educadores e terapeutas.</p>
          <p>Tudo funciona diretamente no navegador, sem cadastro, sem custo e com privacidade total — nenhum dado é enviado para servidores externos.</p>
          <div class="about-tags">
            <span class="tag">100% Gratuito</span>
            <span class="tag">Sem Cadastro</span>
            <span class="tag">Funciona Offline</span>
            <span class="tag">Privacidade Total</span>
            <span class="tag">WCAG 2.2</span>
          </div>
        </div>
        <div class="about-values reveal">
          <div class="value-card">
            <span class="value-icon">🧠</span>
            <h3>Embasamento Científico</h3>
            <p>Conteúdo baseado em literatura especializada em TEA, CAA e educação inclusiva.</p>
          </div>
          <div class="value-card">
            <span class="value-icon">♿</span>
            <h3>Acessibilidade Real</h3>
            <p>Alto contraste, fonte ajustável, leitor de tela e design inclusivo por padrão.</p>
          </div>
          <div class="value-card">
            <span class="value-icon">🤝</span>
            <h3>Foco na Prática</h3>
            <p>Ferramentas que educadores e famílias podem usar imediatamente, sem treinamento complexo.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Equipe -->
  <section class="section band">
    <div class="container">
      <div class="team-header reveal">
        <span class="eyebrow">A equipe</span>
        <h2 class="section-title">Nossa equipe multi-perfil</h2>
        <p class="section-lead">
          Além de estudantes de Psicologia do
          <strong>Instituto Brasileiro de Medicina e Reabilitação (IBMR)</strong>,
          alguns membros também atuam como mediador, artista, técnico de informática e influenciador.
        </p>
      </div>

      <div class="team-grid">
        {team.map((member, i) => (
          <div class="member-card reveal">
            <div class="member-avatar" style={`background:${avatarColors[i % avatarColors.length]}`}>
              {member.photo ? (
                <img class="member-photo" src={member.photo} alt={`Foto de ${member.name}`} />
              ) : (
                <>
                  <span class="member-initials">{member.initials}</span>
                  <div class="avatar-overlay">
                    <span class="photo-hint">Foto em breve</span>
                  </div>
                </>
              )}
            </div>
            <div class="member-info">
              <h3 class="member-name">{member.name}</h3>
              <p class="member-role">{member.role || 'Estudante de Psicologia'}</p>
              <p class="member-inst">IBMR — Barra da Tijuca, RJ</p>
              {member.instagram && (
                <a
                  href={`https://instagram.com/${member.instagram}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="member-ig"
                  aria-label={`Instagram de ${member.name}`}
                >
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                  @{member.instagram}
                </a>
              )}
              {!member.instagram && (
                <span class="member-ig-placeholder">Instagram em breve</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Instituição -->
  <section class="section">
    <div class="container">
      <div class="inst-box reveal">
        <div class="inst-logo" aria-hidden="true">🏛️</div>
        <div>
          <h2 class="section-title" style="margin-top:0">Instituto Brasileiro de Medicina e Reabilitação</h2>
          <p class="section-lead" style="max-width:100%">
            O IBMR é uma instituição de ensino superior localizada na Barra da Tijuca, Rio de Janeiro,
            com cursos nas áreas de saúde, reabilitação e ciências humanas. O curso de Psicologia forma
            profissionais com visão integral do ser humano e compromisso com a saúde mental e a inclusão social.
          </p>
          <p class="inst-note">
            Campus Barra da Tijuca · Rio de Janeiro, RJ
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero { background: linear-gradient(180deg, var(--bg-alt), var(--bg)); padding: 56px 0 40px; }
  .page-title { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; margin: 12px 0 10px; }
  .page-lead { color: var(--text-soft); font-size: 1.15rem; max-width: 620px; }

  /* ── About grid ─────────────────────────────────────────────────────────── */
  .about-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 48px; align-items: start; }
  .about-text p { color: var(--text-soft); line-height: 1.75; margin-bottom: 14px; }
  .about-text strong { color: var(--text); }
  .about-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .tag { background: var(--bg-alt); border: 1px solid var(--border); border-radius: 999px; padding: 5px 14px; font-family: var(--font-head); font-weight: 700; font-size: 0.8rem; color: var(--text-soft); }

  .about-values { display: flex; flex-direction: column; gap: 16px; }
  .value-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; box-shadow: var(--shadow-sm); }
  .value-icon { font-size: 1.7rem; display: block; margin-bottom: 8px; }
  .value-card h3 { font-size: 1rem; margin-bottom: 6px; }
  .value-card p { color: var(--text-soft); font-size: 0.92rem; }

  /* ── Team ────────────────────────────────────────────────────────────────── */
  .band { background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .team-header { margin-bottom: 40px; }
  .team-header .section-lead { max-width: 640px; }

  .team-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 22px; }

  .member-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .member-card:hover { transform: translateY(-4px); box-shadow: var(--shadow); }

  .member-avatar {
    position: relative;
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .member-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .member-initials {
    font-family: var(--font-head);
    font-weight: 900;
    font-size: 2.8rem;
    color: rgba(255,255,255,0.9);
    letter-spacing: -0.02em;
    user-select: none;
  }
  .avatar-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.28) 100%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 10px;
  }
  .photo-hint {
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(255,255,255,0.75);
    font-family: var(--font-head);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .member-info { padding: 18px 18px 20px; }
  .member-name { font-size: 1rem; margin-bottom: 4px; line-height: 1.3; }
  .member-role { font-size: 0.85rem; color: var(--blue); font-weight: 700; font-family: var(--font-head); margin-bottom: 2px; }
  .member-inst { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 12px; }
  .member-ig {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--text-soft); font-size: 0.82rem; font-weight: 700;
    border: 1.5px solid var(--border); border-radius: 999px;
    padding: 4px 12px; transition: border-color .15s, color .15s;
  }
  .member-ig:hover { border-color: #e1306c; color: #e1306c; }
  .member-ig-placeholder {
    display: inline-block; font-size: 0.78rem; color: var(--text-muted);
    font-style: italic;
  }

  /* ── Institution ─────────────────────────────────────────────────────────── */
  .inst-box { display: flex; gap: 28px; align-items: flex-start; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 36px; box-shadow: var(--shadow-sm); }
  .inst-logo { font-size: 3rem; flex-shrink: 0; line-height: 1; }
  .inst-note { font-family: var(--font-head); font-weight: 700; color: var(--text-muted); font-size: 0.88rem; margin-top: 10px; }

  /* ── CTA ─────────────────────────────────────────────────────────────────── */
  .cta-box { background: linear-gradient(135deg, var(--blue), var(--mint)); color: #fff; border-radius: var(--radius-xl); padding: 56px 32px; text-align: center; }
  .cta-box h2 { color: #fff; font-size: clamp(1.8rem, 4vw, 2.6rem); }
  .cta-box p { font-size: 1.1rem; margin: 12px 0 28px; opacity: 0.95; }
  .cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 860px) {
    .about-grid { grid-template-columns: 1fr; }
    .inst-box { flex-direction: column; }
  }
</style>
